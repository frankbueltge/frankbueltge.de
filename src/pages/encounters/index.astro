---
// site-v2 work order §3: the hub (/) becomes the entrance and now only shows a condensed NOW
// section; the full encounter experience — score map, legend, station register, event table —
// moves here, to its stable URL.
// 2026-07-17: the "second encounter" moment arrived (the ledger holds four) — the register
// below lists every recorded encounter from src/data/begegnungen/register.json, which the
// ecology export chain regenerates after every engine session and every nightly scribe run.
// The entrance keeps the one encounter with an AUTHORED score (the selection rule, now named
// in src/config/naming.ts); a newer encounter takes the entrance when its score is authored.
import Page from '@/layouts/Page.astro'
import BegegnungEntrance from '@/components/pages/BegegnungEntrance.astro'
import { currentEntrance } from '@/lib/begegnungen'
import register from '@/data/begegnungen/register.json'

const entrance = currentEntrance
interface RegisterEntry {
  encounter_id: string
  title: string | null
  status: { as_of?: string; statusLine?: string } | null
  approval: string | null
  authored_by: string | null
  participants: { id: string; role: string | null }[]
  record_url: string
  // Machine-OBSERVED receiver-work premiere status (17.07., "Beobachten & anstoßen"): derived
  // by the ecology export from the receiver engine's works/, strictly separate from the scribe's
  // editorial title/status. Present only for encounters whose receiver is one of the cloned
  // engine collectives; absent for datavism/data-snack (honestly not observable), and in the
  // determinism test (no engines) — so this stays optional.
  observed?: {
    receiver_collective: string
    engine_repo: string
    work_slug: string
    premiered: boolean
    work_dir: string | null
    premiered_on: string | null
    in_production_uri: string
  }
}
const entries = register as RegisterEntry[]

// --- Die Ökologie-Karte (17.07., Frank: "datavism oder data snack tauchen da gar nicht auf")
// Alle sechs Praktiken als Knoten, jede Begegnung als gerichtete Kante source→receiver —
// gebaut aus register.json, also automatisch aktuell mit jedem Export. Ulysses' und Franks
// kantenlose Knoten sind kein Fehler, sondern die Verfassung: dokumentiertes Schweigen bzw.
// noch keine Begegnung als Partei — sichtbar, nie als Defizit gerendert (§7.2, spec 03 §8.1).
const normId = (id: string) =>
  id === 'frank-bueltge' ? 'frank' : id === 'data-snack-plenum' ? 'data-snack' : id
const NODES: Record<string, { x: number; y: number; label: string }> = {
  meridian: { x: 130, y: 84, label: 'Meridian · field' },
  ensemble: { x: 360, y: 56, label: 'Ensemble · studio' },
  ulysses: { x: 590, y: 84, label: 'Ulysses · atelier' },
  datavism: { x: 130, y: 246, label: 'datavism.org' },
  frank: { x: 360, y: 282, label: 'Frank · conductor' },
  'data-snack': { x: 590, y: 246, label: 'data-snack.com' },
}
interface Edge { from: string; to: string; nr: string; idx: number }
const pairIdx = new Map<string, number>()
const edges: Edge[] = []
for (const e of entries) {
  const nr = e.encounter_id.match(/^enc-\d{4}-(\d{3})/)?.[1] ?? e.encounter_id
  const src = e.participants.filter((p) => p.role === 'source').map((p) => normId(p.id))
  const rcv = e.participants.filter((p) => p.role === 'receiver').map((p) => normId(p.id))
  for (const f of src) for (const t of rcv) {
    if (!NODES[f] || !NODES[t]) continue
    const key = [f, t].sort().join('|')
    const idx = pairIdx.get(key) ?? 0
    pairIdx.set(key, idx + 1)
    edges.push({ from: f, to: t, nr, idx })
  }
}
const edgeSvg = edges.map(({ from, to, nr, idx }) => {
  const a = NODES[from], b = NODES[to]
  const mx = (a.x + b.x) / 2, my = (a.y + b.y) / 2
  const dx = b.x - a.x, dy = b.y - a.y, len = Math.hypot(dx, dy) || 1
  const off = 16 + idx * 20
  const cx = mx - (dy / len) * off, cy = my + (dx / len) * off
  const lx = mx - (dy / len) * (off * 0.72), ly = my + (dx / len) * (off * 0.72)
  return (
    `<path d="M ${a.x} ${a.y} Q ${cx} ${cy} ${b.x} ${b.y}" fill="none" stroke="currentColor" stroke-width="1" opacity="0.45" marker-end="url(#eco-arrow)"/>` +
    `<text x="${lx}" y="${ly}" text-anchor="middle" font-size="10" opacity="0.75">${nr}</text>`
  )
}).join('')
const nodeSvg = Object.entries(NODES).map(([id, n]) => {
  const connected = edges.some((e) => e.from === id || e.to === id)
  return (
    `<circle cx="${n.x}" cy="${n.y}" r="5" fill="${connected ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="1.2" opacity="${connected ? '0.9' : '0.5'}"/>` +
    `<text x="${n.x}" y="${n.y + (n.y > 160 ? 22 : -14)}" text-anchor="middle" font-size="11" opacity="0.85">${n.label}</text>`
  )
}).join('')
const ecologyMapSvg =
  `<svg viewBox="0 0 720 320" role="img" aria-label="Map of the ecology: six practices, ${entries.length} recorded encounters as directed edges" style="width:100%;height:auto;font-family:inherit">` +
  `<defs><marker id="eco-arrow" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 8 4 L 0 8 z" fill="currentColor" opacity="0.55"/></marker></defs>` +
  edgeSvg + nodeSvg + `</svg>`
---
<Page title={`${entrance.headline} | Frank Bültge`} description={entrance.status.statusLine}>
  <BegegnungEntrance />

  <section class="mx-auto w-full max-w-4xl px-6 pb-16" aria-labelledby="register-heading">
    <h2 id="register-heading" class="font-mono text-xs uppercase tracking-[0.18em] text-fg-faint">
      The register — every recorded encounter
    </h2>
    <p class="mt-3 text-sm text-fg-muted">
      The entrance above shows the encounter with an authored score; the ledger records
      {entries.length} encounters, kept current by the nightly scribe. Each record links to the
      public register (every quote pinned to a source commit, machine-verified).
    </p>
    <figure class="mt-6 font-mono text-fg-muted" set:html={ecologyMapSvg} />
    <p class="mt-2 font-mono text-xs text-fg-faint">
      the ecology map — every recorded encounter as a directed edge (source → receiver), numbered
      by record · an unfilled node is not a failure: Ulysses' silence is documented non-relation,
      and the conductor has no recorded encounter as a party yet
    </p>
    <div class="mt-5 overflow-x-auto">
      <table class="w-full border-collapse text-left font-mono text-xs">
        <thead>
          <tr class="text-fg-faint">
            <th class="border-t border-line/60 py-2 pr-4 font-semibold">encounter</th>
            <th class="border-t border-line/60 py-2 pr-4 font-semibold">status</th>
            <th class="border-t border-line/60 py-2 pr-4 font-semibold">participants</th>
            <th class="border-t border-line/60 py-2 font-semibold">record</th>
          </tr>
        </thead>
        <tbody class="text-fg-muted">
          {entries.map((e) => (
            <tr>
              <td class="border-t border-line/60 py-2 pr-4">
                <span class="text-fg">{e.title ?? e.encounter_id}</span>
                <span class="block text-fg-faint">{e.encounter_id}{e.approval === 'draft' ? ' · draft' : ''}</span>
              </td>
              <td class="border-t border-line/60 py-2 pr-4">
                {e.status?.statusLine ?? '—'}
                {e.status?.as_of && <span class="block text-fg-faint">as of {e.status.as_of}</span>}
                {e.observed?.premiered && (
                  <span class="block text-fg">
                    ▲ receiver work premiered{e.observed.premiered_on ? ` ${e.observed.premiered_on}` : ''} (observed){/premiere pending/i.test(e.title ?? '') ? ' — record catching up' : ''}
                  </span>
                )}
              </td>
              <td class="border-t border-line/60 py-2 pr-4">{e.participants.map((p) => p.id).join(' · ')}</td>
              <td class="border-t border-line/60 py-2">
                <a href={e.record_url} target="_blank" rel="noreferrer" class="underline hover:text-fg">record ↗</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Page>
