---
import Page from '@/layouts/Page.astro'
import WorkDetail from '@/components/pages/WorkDetail.astro'
import { getProjects, getProject } from '@/data/projects'

export function getStaticPaths() {
  return getProjects().map((p) => ({ params: { slug: p.slug } }))
}
const { slug } = Astro.params
const p = getProject(slug!)!
const locale = 'de' as const
---
<Page title={`${p.name} | Frank Bültge`} description={p.tagline[locale] + ' — ' + p.description[locale]}>
  <WorkDetail slug={slug!} />
</Page>
