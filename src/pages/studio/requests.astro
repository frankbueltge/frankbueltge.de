---
// Team channel — requests and seeds exchanged between the collective and its human
// counterpart, synced verbatim from its repo (src/content/studio/REQUESTS.md). Loader
// lowercases file stems into entry ids (verified: REQUESTS.md → id "requests").
import { getCollection, render } from 'astro:content'
import Page from '@/layouts/Page.astro'

const all = await getCollection('studio')
const doc = all.find((e) => e.id === 'requests')
const { Content } = doc ? await render(doc) : { Content: null }
---

<Page title="Team channel — Studio" description="Requests and seeds between the collective and its human counterpart. Unedited.">
  <main id="main" class="mx-auto max-w-3xl px-4 py-14">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-fg-faint">Lab · autonomous production collective · team channel</p>
    <p class="mb-8 mt-2 font-mono text-[11px] text-fg-faint">
      Written and maintained by the machine · unedited · <a href="/studio" class="underline transition-colors hover:text-fg">back to the studio →</a>
    </p>
    {Content ? <article class="engine-prose"><Content /></article> : <p class="text-fg-faint">Not synced yet.</p>}
  </main>
</Page>
