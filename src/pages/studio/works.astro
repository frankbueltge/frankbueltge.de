---
// /studio/works — what has premiered. Everything here passed the full three-voice gate;
// the honest empty state stays honest (a premiere is an event, not a ritual). Interactive
// works run in the same isolated sandbox the old page used.
import Page from '@/layouts/Page.astro'
import Frame from '@/components/studio/surface/Frame.astro'
import { sortWorks } from '@/lib/atelier/sort'
import { loadChronicle, entriesForWork } from '@/lib/studio/chronicle'
import { STUDIO_NARRATIVE } from '@/config/studio-wording'

const repo = 'https://github.com/frankbueltge/studio'
const htmlMeta = import.meta.glob('/src/content/studio/works/*/meta.json', {
  eager: true, import: 'default',
}) as Record<string, any>

const works = sortWorks(
  Object.entries(htmlMeta).map(([path, meta]) => ({
    slug: path.replace('/src/content/studio/works/', '').replace('/meta.json', ''),
    kind: 'html' as const,
    date: meta.date as string | undefined,
    meta,
  })),
)

const chronicle = loadChronicle()
const withBadges = works.map((w) => {
  const hist = entriesForWork(chronicle, w.slug)
  const latest = hist[hist.length - 1]
  return { ...w, badge: latest ? { label: `S${latest.collective_session} · ${latest.move}`, anchor: latest.anchor } : undefined }
})

const kicker = ['Studio · works', 'studio (Ensemble)', `${works.length} premiered`]
const statusHtml = `<b>${works.length} work${works.length === 1 ? '' : 's'} premiered</b> · everything here survived the gate the playbill records`
---

<Page
  title="Studio — works | Frank Bültge"
  description="The Studio's premiered works — everything here passed the full three-voice gate, the hostile critique published either way."
>
  <Frame active="works" kicker={kicker} h1="What has premiered." statusHtml={statusHtml} back>
    <p class="st-room-intro">{STUDIO_NARRATIVE.rooms.works}</p>

    {works.length === 0 && (
      <p class="st-room-intro">
        No premiered works yet. The first production is in the workshop behind its critic's gate —
        a premiere is an event, not a ritual. The <a href="/studio/history" class="underline">playbill</a> is the record.
      </p>
    )}

    {/*
      Exhibition model (Frank, 2026-07-21): these works are full-viewport experiences — a
      kiosk, a console, an instrument. They do not survive being crammed into a fixed-height
      preview iframe (the old 600px box forced internal scrolling and staged every work as a
      thumbnail). Each card is a door: the wall label here, the work itself at full stage under
      its own standalone route /studio/werke-html/<slug>/ (no site chrome, the whole viewport).
    */}
    {withBadges.map(({ slug, meta, badge }) => (
      <article class="st-work-card" id={slug}>
        <div class="st-work-head">
          <h3>
            {meta.title ?? slug}
            {meta.date && <span class="st-work-date">{meta.date}</span>}
          </h3>
          {badge && <a class="st-work-badge" href={`/studio/history#${badge.anchor}`}>{badge.label} — on the record →</a>}
        </div>
        {(meta.embodies ?? meta.verkoerpert) && <p>{meta.embodies ?? meta.verkoerpert}</p>}
        {meta.medium && <p class="st-work-medium">{meta.medium}</p>}
        <div class="st-work-actions">
          <a class="st-work-enter" href={`/studio/werke-html/${slug}/`}>Enter the work <span aria-hidden="true">→</span></a>
          <a class="st-work-source" href={`${repo}/tree/main/works/${slug}`} target="_blank" rel="noreferrer">Source code ↗</a>
        </div>
      </article>
    ))}
  </Frame>
</Page>
