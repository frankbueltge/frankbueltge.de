---
// Temporäre Prototyp-Seite (nur lokal, noindex): WebGL-Klimapuls im Mono-Skin,
// im Vollbild zum Beurteilen. Fliegt wieder raus, sobald entschieden ist.
import '@/styles/global.css'
import HeroFieldGL from '@/components/HeroFieldGL.astro'
---

<!doctype html>
<html lang="de" data-skin="mono">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>proto · WebGL-Puls</title>
  </head>
  <body style="margin:0; background: rgb(var(--rgb-bg)); overflow:hidden;">
    <main style="position:fixed; inset:0;">
      <HeroFieldGL />
      <p
        style="position:absolute; left:24px; bottom:18px; margin:0; font-family: ui-monospace, monospace; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color: rgb(var(--rgb-accent) / 0.7); pointer-events:none;"
      >
        proto · NASA GISTEMP 1880–heute · WebGL · Maus bewegen
      </p>
    </main>
  </body>
</html>
