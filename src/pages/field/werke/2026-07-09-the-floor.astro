---
import Page from '@/layouts/Page.astro'
import Work from '@/components/field/werke/2026-07-09-the-floor/index.astro'
import meta from '@/components/field/werke/2026-07-09-the-floor/meta.json'
const m = meta as { title?: string; embodies?: string; verkoerpert?: string }
const title = `${m.title ?? '2026-07-09-the-floor'} — Field | Frank Bültge`
---
<Page title={title} description={m.embodies ?? m.verkoerpert ?? m.title ?? '2026-07-09-the-floor'}>
  <main id="main" class="mx-auto max-w-3xl px-4 py-14">
    <Work />
  </main>
</Page>
