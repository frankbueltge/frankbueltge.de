---
// /atelier — der Eingang (Stufe 0, 2026-07-20, Franks Auftrag: verständliche Haustür).
// Ein erklärender Absatz und vier Türen; keine Rail — die Rail gehört den Zimmern, jede
// Tür unten führt in eines. Das Blatt (die bisherige Eingangsseite) lebt unverändert als
// Zimmer unter /atelier/sheet weiter. Wortlaute: ATELIER_NARRATIVE.entrance (draft bis
// Franks Merge dieses PRs).
import Page from '@/layouts/Page.astro'
import { ATELIER_NARRATIVE, ATELIER_DRAFT_LABEL } from '@/config/atelier-wording'
import '@/styles/atelier-sheet.css'

const E = ATELIER_NARRATIVE.entrance
const isDraft = ATELIER_NARRATIVE.approval !== 'approved'

// Live counts — same read-only mirrors the sheet uses.
const projectScores = import.meta.glob('/src/content/atelier/projects/*/SCORE.md', {
  eager: true, query: '?raw', import: 'default',
}) as Record<string, string>
const activeProjects = Object.values(projectScores).filter((raw) =>
  /^status:\s*ACTIVE\s*$/m.test(raw.split('\n---')[0]),
).length
const htmlMeta = import.meta.glob('/src/content/atelier/works/*/meta.json', { eager: true, import: 'default' })
const nativeMeta = import.meta.glob('/src/components/atelier/werke/*/meta.json', { eager: true, import: 'default' })
const worksCount = Object.keys(htmlMeta).length + Object.keys(nativeMeta).length

const doors = [
  {
    href: '/atelier/projects',
    label:
      activeProjects > 0
        ? `now — ${activeProjects} project${activeProjects === 1 ? '' : 's'} in progress`
        : 'now — no project in progress',
    text: E.doors.now,
  },
  { href: '/atelier/works', label: `works — ${worksCount} so far`, text: E.doors.works },
  { href: '/atelier/foundation', label: 'what this is', text: E.doors.foundation },
  { href: '/atelier/sheet', label: 'the working sheet', text: E.doors.sheet },
]
---

<Page
  title="Atelier · Ulysses — machine-participatory artistic research | Frank Bültge"
  description={E.lede}
>
  <main id="main" class="atelier-surface">
    <p class="at-kicker">
      <span>{E.kicker}</span>
      <span>irrtum-als-methode</span>
      {isDraft && <span class="at-chip" title={ATELIER_DRAFT_LABEL}>wording draft</span>}
    </p>
    <h1 class="at-h1">{E.h1}</h1>
    <p class="at-entrance-lede">{E.lede}</p>

    <nav class="at-doors" aria-label="Doors into the atelier">
      {doors.map((d) => (
        <a class="at-door-card" href={d.href}>
          <span class="d-label">{d.label} →</span>
          <span class="d-text">{d.text}</span>
        </a>
      ))}
    </nav>

    <p class="at-quiet">
      deeper:
      <a href="/atelier/journal">journal archive (nightly phase)</a> ·
      <a href="/atelier/protocol">constitution</a> ·
      <a href="/atelier/apparatus">apparatus</a> ·
      <a href="/atelier/requests">team channel</a>
    </p>

    <footer class="at-foot">
      <span>{ATELIER_NARRATIVE.framingFoot}</span>
    </footer>
  </main>
</Page>

<style>
  .at-entrance-lede {
    max-width: 62ch;
    margin: 1.25rem 0 2rem;
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .at-doors {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin: 0 0 1.5rem;
  }
  @media (min-width: 640px) {
    .at-doors {
      grid-template-columns: 1fr 1fr;
    }
  }
  .at-door-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.9rem 1rem;
    border: 1px solid currentColor;
    text-decoration: none;
    color: inherit;
  }
  .at-door-card:hover .d-label {
    text-decoration: underline;
  }
  .d-label {
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }
  .d-text {
    font-size: 0.8rem;
    line-height: 1.5;
    opacity: 0.75;
  }
  .at-quiet {
    font-size: 0.75rem;
    opacity: 0.7;
    margin-bottom: 2.5rem;
  }
  .at-quiet a {
    text-decoration: underline;
    color: inherit;
  }
</style>
