---
// site-v2 work order §5 (decisions doc 2026-07-16 §1.7): the hub-era nav — Encounters, the
// three practice doors, Holdings, Atlas, Projects, About. The Middle has no nav entry of its
// own (Encounters is its register; as a hub door it is called The Middle, decisions doc §1.7).
// The language toggle is gone — German is dropped site-wide (§1.5, work order §6); this file
// used to carry a `hasAlternate`/`otherUrl` pair deciding when to show a DE/EN switch, which no
// longer applies to a single-locale site.
import { t } from '@/i18n/ui'
import type { Locale } from '@/lib/site'

const locale = (Astro.currentLocale ?? 'en') as Locale
const nav = [
  { href: '/begegnungen', label: 'Encounters' },
  { href: '/atelier', label: 'Atelier' },
  { href: '/field', label: 'Field' },
  { href: '/studio', label: 'Studio' },
  { href: '/bestaende', label: 'Holdings' },
  { href: '/atlas', label: 'Atlas' },
  { href: '/work', label: 'Projects' },
  { href: '/about', label: 'About' },
]
---

<header class="keep-dark sticky top-0 z-30 flex h-12 items-center justify-between border-b border-line bg-bg/80 px-4 backdrop-blur-md sm:h-10">
  <a href="/" class="group flex items-center gap-2.5" aria-label={t(locale, 'nav.overview')}>
    <span class="h-[7px] w-[7px] rounded-full bg-cyan"></span>
    <span class="text-[14px] font-semibold tracking-tight transition-opacity group-hover:opacity-70">
      Frank Bültge
    </span>
  </a>

  <div class="flex items-center gap-4 sm:gap-5">
    <!-- desktop nav -->
    <nav class="hidden items-center gap-5 text-sm text-fg-muted sm:flex">
      {nav.map((item) => <a href={item.href} class="transition-colors hover:text-fg">{item.label}</a>)}
    </nav>

    <!-- theme toggle: cycles auto → light → dark → auto. Auto (default) follows the OS.
         The icon shows the current MODE (monitor = auto, sun = light, moon = dark); it is
         driven by [data-theme-mode] on <html>, set by the controller in Base.astro. -->
    <button
      type="button"
      data-theme-toggle
      aria-label={t(locale, 'theme.toggle')}
      title={t(locale, 'theme.toggle')}
      class="-mr-1 flex h-8 w-8 items-center justify-center rounded-md text-fg-faint transition-colors hover:text-fg"
    >
      <svg class="i-auto" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="1.5" /><path d="M8 20h8M12 16v4" /></svg>
      <svg class="i-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><circle cx="12" cy="12" r="4.2" /><path d="M12 2.5v2M12 19.5v2M4.6 4.6l1.4 1.4M18 18l1.4 1.4M2.5 12h2M19.5 12h2M4.6 19.4l1.4-1.4M18 6l1.4-1.4" /></svg>
      <svg class="i-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z" /></svg>
    </button>

    <!-- mobile menu: native <details> disclosure (works without JS) -->
    <details data-menu class="relative sm:hidden">
      <summary
        class="i-summary -mr-1 flex h-9 w-9 cursor-pointer items-center justify-center rounded-md text-fg-muted transition-colors hover:text-fg"
        aria-label={t(locale, 'nav.menu')}
      >
        <svg class="i-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
        <svg class="i-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
      </summary>
      <nav class="absolute right-0 top-[calc(100%+10px)] flex w-44 flex-col overflow-hidden rounded-xl border border-line bg-panel/95 p-1.5 shadow-2xl backdrop-blur-md">
        {nav.map((item) => (
          <a href={item.href} class="rounded-lg px-3 py-2.5 text-sm text-fg-muted transition-colors hover:bg-panel-2 hover:text-fg">{item.label}</a>
        ))}
      </nav>
    </details>
  </div>
</header>

<style>
  /* hamburger ⇄ close icon swap driven purely by the open state */
  .i-close { display: none; }
  details[open] .i-menu { display: none; }
  details[open] .i-close { display: block; }
  summary { list-style: none; }
  summary::-webkit-details-marker { display: none; }
</style>

<script>
  // Close the mobile menu on outside-tap or Escape.
  const menu = document.querySelector<HTMLDetailsElement>('[data-menu]')
  if (menu) {
    document.addEventListener('click', (e) => {
      if (menu.open && !menu.contains(e.target as Node)) menu.open = false
    })
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.open) menu.open = false
    })
  }
  // The theme toggle is wired centrally in Base.astro (single source of truth).
</script>
