---
import { t } from '@/i18n/ui'
import { SITE, type Locale } from '@/lib/site'

const locale = (Astro.currentLocale ?? 'de') as Locale
---

<!-- Phase 0 skeleton hero. The decoupled WebGL canvas + the scroll "data journey" land in Phase 2;
     this is the crawlable, server-rendered content layer it will sit behind. -->
<main id="main" class="relative flex flex-1 items-center overflow-hidden">
  <div class="mx-auto w-full max-w-5xl px-6 py-24 sm:py-32">
    <p class="mb-4 font-mono text-xs uppercase tracking-[0.28em] text-accent-soft">
      <span class="mr-2 inline-block h-[6px] w-[6px] rounded-full bg-cyan align-middle"></span>
      {t(locale, 'hero.eyebrow')} · {t(locale, 'system.live')}
    </p>
    <h1 class="text-[clamp(48px,10vw,128px)] font-bold leading-[0.92] tracking-[-0.04em]">
      Frank Bültge
    </h1>
    <p class="mt-6 max-w-2xl text-pretty text-lg text-fg-muted sm:text-xl">
      <strong class="font-semibold text-fg">{t(locale, 'hero.roleLead')}</strong>{t(locale, 'hero.roleRest')}
    </p>

    <div class="mt-10 flex flex-wrap gap-3 text-sm">
      <a href={SITE.projects.dataSnack} target="_blank" rel="noreferrer"
         class="rounded-full border border-line bg-panel-2/60 px-4 py-2 text-fg-muted transition-colors hover:border-fg-muted hover:text-fg">data-snack.com ↗</a>
      <a href={SITE.projects.datavism} target="_blank" rel="noreferrer"
         class="rounded-full border border-line bg-panel-2/60 px-4 py-2 text-fg-muted transition-colors hover:border-fg-muted hover:text-fg">datavism.org ↗</a>
      <a href={SITE.social.linkedin} target="_blank" rel="noreferrer"
         class="rounded-full border border-line bg-panel-2/60 px-4 py-2 text-fg-muted transition-colors hover:border-fg-muted hover:text-fg">LinkedIn ↗</a>
    </div>

    <p class="mt-16 font-mono text-xs text-fg-faint">{t(locale, 'soon')}</p>
  </div>
</main>
