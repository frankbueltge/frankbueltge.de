---
// site-v2 work order §5 (decisions doc 2026-07-16 §1.7): a trimmed footer — Contact, Impressum,
// Datenschutz, the license line, GitHub. The previous four-column footer (Explore/Projects/
// Connect) duplicated what the hub-era TopBar nav + hub's own "where works travel"/"also on
// this site" sections already cover; this keeps only what belongs on every single page.
import { SITE } from '@/lib/site'
import { NAMING } from '@/config/naming'

const year = 2026
---

<footer class="mt-24 border-t border-line/60 footer-dark">
  <div class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-14 sm:flex-row sm:items-start sm:justify-between">
    <div class="flex items-center gap-3">
      <img src="/logo.webp" alt="" width="48" height="48" class="h-12 w-12 rounded-full" />
      <span class="text-sm font-semibold">Frank Bültge</span>
    </div>

    <nav aria-label="Footer" class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-fg-muted">
      <a href="/contact" class="transition-colors hover:text-fg">Contact</a>
      <a href="/impressum" class="transition-colors hover:text-fg">Impressum</a>
      <a href="/datenschutz" class="transition-colors hover:text-fg">Datenschutz</a>
      <a href={SITE.social.github} target="_blank" rel="noreferrer" class="transition-colors hover:text-fg">GitHub</a>
    </nav>
  </div>

  <div class="mx-auto flex max-w-5xl flex-col gap-2 px-6 pb-10 font-mono text-xs text-fg-faint sm:flex-row sm:items-center sm:justify-between">
    <span>© {year} {SITE.name}</span>
    <span>{NAMING.footer.licenseLine}</span>
  </div>
</footer>

<style>
  /* The footer is a permanent dark island: pure-black ground with the dark
     palette's text tokens, so it stays black + legible even under the light theme. */
  .footer-dark {
    background-color: #000;
    /* establish the footer's own text colour from its (forced-dark) tokens, so bare text
       like the "Frank Bültge" name is light-on-black even under the light theme (otherwise
       it inherits the light theme's dark body colour → invisible). */
    color: var(--color-fg);
    --color-fg: #f4f4f5;
    --color-fg-muted: #a3a3a8;
    --color-fg-faint: #8b8b92;
    --color-line: #242427;
    --color-accent: #c2c2c8;
  }
</style>
