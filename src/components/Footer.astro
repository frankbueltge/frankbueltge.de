---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { t } from '@/i18n/ui'
import { SITE, type Locale } from '@/lib/site'

const locale = (Astro.currentLocale ?? 'de') as Locale
const L = (p: string) => getRelativeLocaleUrl(locale, p)
const year = 2026
const explore = [
  { href: L('/work'), label: t(locale, 'nav.work') },
  { href: L('/lab'), label: t(locale, 'nav.lab') },
  { href: L('/about'), label: t(locale, 'nav.about') },
  { href: L('/contact'), label: t(locale, 'nav.contact') },
]
---

<footer class="mt-24 border-t border-line/60">
  <div class="mx-auto grid max-w-5xl gap-10 px-6 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div class="sm:col-span-2 lg:col-span-1">
      <p class="text-sm font-semibold">Frank Bültge</p>
      <p class="mt-3 max-w-xs text-sm text-fg-muted">{t(locale, 'footer.tagline')}</p>
    </div>

    <nav aria-label={t(locale, 'footer.explore')}>
      <h2 class="font-mono text-xs uppercase tracking-widest text-fg-faint">{t(locale, 'footer.explore')}</h2>
      <ul class="mt-4 space-y-2 text-sm text-fg-muted">
        {explore.map((i) => <li><a href={i.href} class="transition-colors hover:text-fg">{i.label}</a></li>)}
      </ul>
    </nav>

    <nav aria-label={t(locale, 'footer.projects')}>
      <h2 class="font-mono text-xs uppercase tracking-widest text-fg-faint">{t(locale, 'footer.projects')}</h2>
      <ul class="mt-4 space-y-2 text-sm text-fg-muted">
        <li><a href={SITE.projects.dataSnack} target="_blank" rel="noreferrer" class="transition-colors hover:text-fg">data-snack.com</a></li>
        <li><a href={L('/work/datavism')} class="transition-colors hover:text-fg">datavism.org</a></li>
        <li><a href={L('/work/sip')} class="transition-colors hover:text-fg">SIP</a></li>
      </ul>
    </nav>

    <nav aria-label={t(locale, 'footer.connect')}>
      <h2 class="font-mono text-xs uppercase tracking-widest text-fg-faint">{t(locale, 'footer.connect')}</h2>
      <ul class="mt-4 space-y-2 text-sm text-fg-muted">
        <li><a href={SITE.social.linkedin} target="_blank" rel="noreferrer" class="transition-colors hover:text-fg">LinkedIn</a></li>
        <li><a href={SITE.social.github} target="_blank" rel="noreferrer" class="transition-colors hover:text-fg">GitHub</a></li>
        <li><a href={`mailto:${SITE.email}`} class="transition-colors hover:text-fg">{SITE.email}</a></li>
      </ul>
    </nav>
  </div>

  <div class="mx-auto flex max-w-5xl flex-col gap-3 px-6 pb-10 text-xs text-fg-faint sm:flex-row sm:items-center sm:justify-between">
    <p>© {year} {SITE.name}. {t(locale, 'footer.rights')}</p>
    <div class="flex items-center gap-4">
      <a href={L('/impressum')} class="transition-colors hover:text-fg">{t(locale, 'footer.impressum')}</a>
      <a href={L('/datenschutz')} class="transition-colors hover:text-fg">{t(locale, 'footer.privacy')}</a>
    </div>
  </div>
</footer>
