---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { t } from '@/i18n/ui'
import type { Locale } from '@/lib/site'
import { dashboard as D } from '@/data/dashboard'
import { getProjects } from '@/data/projects'
import { getLabPosts } from '@/lib/lab'
import HeroField from '@/components/HeroField.astro'

const locale = (Astro.currentLocale ?? 'de') as Locale
const L = (p: string) => getRelativeLocaleUrl(locale, p)
const projects = getProjects()
const lab = (await getLabPosts(locale)).slice(0, 3)
const fmt = (iso: string) => new Date(iso).toLocaleDateString(locale === 'de' ? 'de-DE' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' })

// pipeline icons (inline, crisp)
const icons: Record<string, string> = {
  sources: '<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"/>',
  ingest: '<path d="M12 3v8m0 0l-3-3m3 3l3-3"/><rect x="4" y="13" width="16" height="7" rx="2"/>',
  warehouse: '<path d="M6 3h9l3 3v15H6z"/><path d="M9 8h6M9 12h6M9 16h4"/>',
  model: '<circle cx="6" cy="6" r="2.5"/><circle cx="18" cy="6" r="2.5"/><circle cx="12" cy="18" r="2.5"/><path d="M6 8.5v2a2 2 0 002 2h8a2 2 0 002-2v-2M12 14.5v1"/>',
  ai: '<path d="M12 3a9 9 0 109 9"/><path d="M12 7v5l3 2"/><path d="M16 3l2 2 2-2"/>',
  decision: '<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M7 14l3-3 2 2 4-5"/>',
}

// focus donut segments
let acc = 0
const donut = D.focus.segments.map((s) => { const offset = -acc; acc += s.value; return { ...s, dash: `${s.value} ${100 - s.value}`, offset } })
---

<main id="main" class="grid-paper min-w-0 flex-1 px-[clamp(20px,3vw,40px)] pb-16 pt-[clamp(16px,3vw,28px)]">
  <div class="mx-auto grid max-w-6xl grid-cols-12 gap-4">

    <!-- HERO (generative field behind name) -->
    <section class="dcard relative col-span-12 flex min-h-[clamp(360px,56vh,560px)] items-end overflow-hidden rounded-[18px] border border-line bg-panel panel-raised">
      <HeroField />
      <div aria-hidden class="pointer-events-none absolute inset-0" style="background: linear-gradient(90deg, rgb(var(--rgb-bg)) 2%, rgb(var(--rgb-bg)/0.55) 30%, transparent 70%), linear-gradient(0deg, rgb(var(--rgb-bg)) 2%, transparent 42%);"></div>
      <div class="absolute right-5 top-5 flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-fg-muted">
        <span class="dot-live h-[7px] w-[7px] rounded-full"></span>{t(locale, 'system.live')}
      </div>
      <div class="relative z-[2] p-[clamp(20px,4vw,44px)]">
        <p class="mb-3 font-mono text-xs uppercase tracking-[0.28em] text-accent-soft">{t(locale, 'hero.eyebrow')}</p>
        <h1 class="glow-text text-[clamp(44px,8vw,104px)] font-bold leading-[0.9] tracking-[-0.04em]"><span class="text-gradient">Frank Bültge</span></h1>
        <p class="mt-5 max-w-xl text-pretty text-base text-fg-muted sm:text-lg">
          <strong class="font-semibold text-fg">{t(locale, 'hero.roleLead')}</strong>{t(locale, 'hero.roleRest')}
        </p>
      </div>
    </section>

    <!-- PIPELINE -->
    <section class="dcard col-span-12 overflow-hidden rounded-[14px] border border-line bg-panel panel-raised px-6 py-5 lg:col-span-8">
      <div class="mb-5 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2 text-[13px] font-semibold"><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-fg-faint">fig.01</span>{D.pipeline.title[locale]}</div>
        <span class="font-mono text-[11px] text-fg-faint">{D.pipeline.meta[locale]}</span>
      </div>
      <div class="flex flex-wrap items-start justify-start gap-3 min-[620px]:flex-nowrap min-[620px]:gap-0">
        {D.pipeline.nodes.map((n, i) => (
          <div class="contents">
            {i > 0 && <div class={`conn conn-${i} mt-7 hidden h-0.5 flex-none basis-[24px] self-start min-[620px]:block`}></div>}
            <div class="group flex min-w-0 basis-[calc(33.33%-8px)] flex-col items-center gap-2 rounded-[10px] px-1 py-1.5 text-center min-[620px]:flex-1 min-[620px]:basis-auto">
              <div class="grid h-[46px] w-[46px] place-items-center rounded-xl border border-line bg-panel-2 text-accent-soft transition group-hover:border-accent group-hover:text-cyan">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[n.icon]} />
              </div>
              <div class="text-[12.5px] font-semibold leading-tight">{n.name[locale]}</div>
              <div class="font-mono text-[10px] leading-tight text-fg-faint">{n.sub[locale]}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- NOW -->
    <section class="dcard col-span-12 overflow-hidden rounded-[14px] border border-line bg-panel panel-raised p-5 sm:col-span-6 lg:col-span-4">
      <div class="mb-4 flex items-center gap-2 text-[13px] font-semibold"><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-fg-faint">now</span>{D.now.title[locale]}</div>
      <div class="text-lg font-semibold tracking-tight">{D.now.name}</div>
      <p class="mt-1 text-[13px] text-fg-muted">{D.now.sub[locale]}</p>
      <div class="mt-4 border-t border-line/60">
        {D.now.rows.map((r) => (
          <div class="flex items-center justify-between border-b border-line/60 py-2.5 text-[13px]">
            <span class="flex items-center gap-2 text-fg-muted"><span class="h-[6px] w-[6px] rounded-full bg-green"></span>{r.k[locale]}</span>
            <span class="font-mono text-[11px] text-green">{r.v}</span>
          </div>
        ))}
      </div>
      <a href={L('/work/sip')} class="mt-4 inline-flex items-center gap-1.5 text-[13px] font-medium text-accent-soft transition-colors hover:text-cyan">SIP →</a>
    </section>

    <!-- CAPABILITIES -->
    <section id="capabilities" class="dcard col-span-12 overflow-hidden rounded-[14px] border border-line bg-panel panel-raised p-5 sm:col-span-6 lg:col-span-5">
      <div class="mb-5 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2 text-[13px] font-semibold"><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-fg-faint">fig.02</span>{D.capabilities.title[locale]}</div>
        <span class="font-mono text-[11px] text-fg-faint">{D.capabilities.meta[locale]}</span>
      </div>
      <div class="flex flex-col gap-3.5">
        {D.capabilities.items.map((it) => (
          <div>
            <div class="mb-1.5 flex items-baseline justify-between">
              <span class="text-[13.5px] font-medium">{it.name[locale]}</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-fg-faint">{it.tag}</span>
            </div>
            <div class="h-[7px] overflow-hidden rounded bg-panel-2">
              <div class={`cap-fill h-full rounded ${it.cy ? 'bg-gradient-to-r from-accent to-cyan' : 'bg-gradient-to-r from-accent to-accent-soft'}`} style={`width:${it.v}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FOCUS DONUT -->
    <section class="dcard col-span-12 overflow-hidden rounded-[14px] border border-line bg-panel panel-raised p-5 sm:col-span-6 lg:col-span-3">
      <div class="mb-4 flex items-center gap-2 text-[13px] font-semibold"><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-fg-faint">fig.03</span>{D.focus.title[locale]}</div>
      <div class="flex items-center gap-4">
        <div class="relative h-[112px] w-[112px] flex-none">
          <svg width="112" height="112" viewBox="0 0 42 42" class="-rotate-90">
            <circle cx="21" cy="21" r="15.915" fill="none" style="stroke:var(--color-panel-2)" stroke-width="5" />
            {donut.map((s) => <circle cx="21" cy="21" r="15.915" fill="none" style={`stroke:${s.color}`} stroke-width="5" stroke-dasharray={s.dash} stroke-dashoffset={s.offset} />)}
          </svg>
          <div class="absolute inset-0 grid place-items-center text-center"><div><b class="text-lg font-bold">4</b><span class="block font-mono text-[9px] uppercase tracking-[0.1em] text-fg-faint">{D.focus.center[locale]}</span></div></div>
        </div>
        <ul class="flex flex-col gap-2 text-[13px]">
          {donut.map((s) => <li class="flex items-center gap-2 text-fg-muted"><span class="h-[9px] w-[9px] rounded-[3px]" style={`background:${s.color}`}></span><b class="font-medium text-fg">{s.label[locale]}</b></li>)}
        </ul>
      </div>
    </section>

    <!-- SELECTED WORK -->
    <section class="dcard col-span-12 overflow-hidden rounded-[14px] border border-line bg-panel panel-raised p-5 lg:col-span-4">
      <div class="mb-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2 text-[13px] font-semibold"><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-fg-faint">fig.04</span>{t(locale, 'dash.selectedWork')}</div>
        <a href={L('/work')} class="font-mono text-[11px] text-fg-faint transition-colors hover:text-fg">{t(locale, 'dash.viewAll')} →</a>
      </div>
      <div class="flex flex-col">
        {projects.map((p, i) => (
          <a href={L(`/work/${p.slug}`)} class={`group grid grid-cols-[1fr_auto] items-center gap-3 py-3 ${i > 0 ? 'border-t border-line/60' : ''}`}>
            <div>
              <div class="flex items-center gap-1.5 text-sm font-semibold">{p.name}<span class="text-fg-faint transition group-hover:translate-x-0.5 group-hover:text-cyan">→</span></div>
              <div class="mt-0.5 font-mono text-[11px] text-fg-faint">{p.year}</div>
            </div>
            <span class={`whitespace-nowrap font-mono text-[10px] uppercase tracking-wider ${p.badge === 'live' ? 'text-cyan' : 'text-accent-soft'}`}>{p.badge === 'live' ? t(locale, 'badge.live') : t(locale, 'badge.dev')}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- LAB FEED -->
    {lab.length > 0 && (
      <section class="dcard col-span-12 overflow-hidden rounded-[14px] border border-line bg-panel panel-raised p-5">
        <div class="mb-3 flex items-center justify-between gap-3">
          <div class="flex items-center gap-2 text-[13px] font-semibold"><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-fg-faint">fig.05</span>{t(locale, 'dash.latestLab')}</div>
          <a href={L('/lab')} class="font-mono text-[11px] text-fg-faint transition-colors hover:text-fg">{t(locale, 'dash.viewAll')} →</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          {lab.map(({ entry, slug }) => (
            <a href={L(`/lab/${slug}`)} class="group flex flex-col rounded-xl border border-line/60 bg-panel-2/40 p-4 transition-colors hover:border-fg-muted/40">
              <span class="font-mono text-[11px] text-fg-faint">{fmt(entry.data.date)}</span>
              <span class="mt-2 text-sm font-semibold leading-snug transition-colors group-hover:text-accent-soft">{entry.data.title}</span>
              <span class="mt-2 line-clamp-2 text-xs leading-relaxed text-fg-muted">{entry.data.description}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</main>
