---
// Kartenschlüssel der Partitur (Practices · Signs · Currents) — extrahiert aus
// BegegnungEntrance.astro (Hub-Umbau 2026-07-16, Frank: „grammatik legende darunter"):
// EIN Bauteil für /encounters und den Hub. Muss innerhalb eines .score-map-Scopes
// gerendert werden (Farb-Token + Zeichen-Styles, src/styles/score-map.css).
import type { ScoreExport } from '@/lib/begegnungen/score'

interface Props {
  score: ScoreExport
}
const { score } = Astro.props
const lanes = score.participants.filter((p) => p.lane)
const practiceLanes = lanes.filter((p) => p.role !== 'conductor')
const conductorLane = lanes.find((p) => p.role === 'conductor')
const nonParticipants = score.non_participants ?? []
---

<aside class="score-legend" aria-label="Map key">
  <div class="score-lg-col">
    <h3>Practices</h3>
    {practiceLanes.map((p) => (
      <div class="score-lg-row">
        <i class:list={['score-sw', `pr-${p.lane}`]}></i>
        <span>
          {p.lane?.toUpperCase()} — {p.role}{p.local_status && <> · {p.local_status}</>}
        </span>
      </div>
    ))}
    {conductorLane && (
      <div class="score-lg-row">
        <i class:list={['score-sw', `pr-${conductorLane.lane}`]}></i>
        <span>
          {conductorLane.lane?.toUpperCase()} ({conductorLane.actor_id}) — {conductorLane.role}
          {conductorLane.local_status && <> · {conductorLane.local_status}</>}
        </span>
      </div>
    )}
    {nonParticipants.map((np) => (
      <div class="score-lg-row">
        <i class="score-sw pr-ulysses"></i>
        <span>{np.collective_id.toUpperCase()} — documented non-participant in this encounter (designed non-relation; drawn as absence, not as edge)</span>
      </div>
    ))}
  </div>

  <div class="score-lg-col">
    <h3>Signs</h3>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><path class="mk pr-meridian" d="M14 4 V26"/><path class="mk mk-lt pr-meridian" d="M21 4 V26"/><path class="mk pr-meridian" d="M21 15 H33"/></svg><span>contract.* — threshold: an offer under conditions</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><rect class="mk-fill pr-ensemble" x="15" y="7" width="16" height="16"/></svg><span>object.* — a work enters, conditions included</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><rect class="mk-hatch pr-ensemble" x="8" y="8" width="11" height="14"/><rect class="mk-hatch pr-ensemble" x="27" y="8" width="11" height="14"/><path class="mk-void" d="M23 4 V26"/></svg><span>translation.* — declared loss: a designed gap, not an error</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><path class="mk pr-conductor" d="M23 4 L34 15 L23 26 L12 15 Z" fill="none"/></svg><span>correction.issued — in transit, not yet accepted</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><path class="mk pr-meridian" d="M12 17 L19 24 L34 6" fill="none"/></svg><span>correction.applied — arrived and worked in</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><path class="mk-stem pr-ensemble" d="M23 2 V16"/><circle class="mk mk-punch pr-ensemble" cx="23" cy="23" r="6"/></svg><span>derivative.* — offspring on a stem</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><circle class="mk mk-unknown" cx="23" cy="15" r="9" fill="none"/></svg><span>unknown family — documented fallback, never guessed</span></div>
  </div>

  <div class="score-lg-col">
    <h3>Currents</h3>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><path class="flow flow-down pr-ensemble" d="M6 6 C 18 26, 30 26, 40 8"/></svg><span>downstream ↓ — transfer, source to receiver</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><path class="flow flow-up pr-conductor" d="M6 24 C 18 4, 30 4, 40 22"/></svg><span>upstream ↑ — correction against the stream</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><path class="obl pr-meridian" d="M4 15 H42"/></svg><span>obligation — sustained until the as-of edge</span></div>
    <div class="score-lg-row"><svg viewBox="0 0 46 30" class="score-mini"><circle class="ring pr-meridian" cx="14" cy="15" r="7" fill="none"/><circle class="ring pr-ensemble" cx="34" cy="15" r="7" fill="none"/></svg><span>divergence — open rings that never converge</span></div>
    <p class="score-lg-note">
      Narrative badges ①–⑥ give the telling's order; the map keeps the ledger's. Same ledger ⇒
      same map, byte for byte. No force layout, no randomness, no clock.
    </p>
  </div>
</aside>
