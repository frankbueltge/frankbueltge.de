---
// Slim home: the climate-ridgeline hero (real data) + a provisional statement,
// a visible data-source caption (integrity), and a Lab placeholder. Replaces the
// retired BI dashboard. Copy here is provisional — the manifesto matures later.
import { t } from '@/i18n/ui'
import type { Locale } from '@/lib/site'
import HeroField from '@/components/HeroField.astro'
import snapshot from '@/data/climate/global-temp-anomalies.json'
import type { ClimateSeries } from '@/lib/climate'

const locale = (Astro.currentLocale ?? 'de') as Locale
const series = snapshot as ClimateSeries
const meta = series.meta
const firstYear = series.years[0]?.year
const lastYear = series.years.at(-1)?.year

const copy = {
  de: {
    statement: 'Daten sichtbar machen — offene Daten, künstlerische Experimente, harte Fakten.',
    caption: `globale Temperatur-Anomalie ${firstYear}–${lastYear} · ${meta?.source} · Basis ${meta?.baseline}`,
    labTitle: 'Lab',
    labText: 'Kleine, faktenbasierte Daten-Experimente — wächst. Erstes Stück: 147 Jahre globale Temperatur als Ridgeline oben — jede Linie ein Jahr; die ältesten (1880, kühl) blass im Hintergrund, die jüngsten (warm) hell und dicht im Vordergrund.',
  },
  en: {
    statement: 'Making data visible — open data, artistic experiments, hard facts.',
    caption: `global temperature anomaly ${firstYear}–${lastYear} · ${meta?.source} · baseline ${meta?.baseline}`,
    labTitle: 'Lab',
    labText: 'Small, fact-based data experiments — growing. First piece: 147 years of global temperature as a ridgeline above — one line per year; the oldest (1880, cool) faint in the back, the most recent (warm) bright and dense in front.',
  },
}[locale]
---

<main id="main" class="grid-paper min-w-0 flex-1 px-[clamp(20px,3vw,40px)] pb-16 pt-[clamp(16px,3vw,28px)]">
  <div class="mx-auto grid max-w-6xl grid-cols-12 gap-4">

    <!-- HERO — climate ridgeline behind the name -->
    <section class="relative col-span-12 flex min-h-[clamp(420px,64vh,640px)] items-end overflow-hidden rounded-[18px] border border-line bg-panel panel-raised">
      <HeroField />
      <div aria-hidden class="pointer-events-none absolute inset-0" style="background: linear-gradient(90deg, rgb(var(--rgb-bg)) 2%, rgb(var(--rgb-bg)/0.55) 30%, transparent 70%), linear-gradient(0deg, rgb(var(--rgb-bg)) 2%, transparent 42%);"></div>
      <div class="absolute right-5 top-5 flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-fg-muted">
        <span class="dot-live h-[7px] w-[7px] rounded-full"></span>{t(locale, 'system.live')}
      </div>
      <div class="relative z-[2] p-[clamp(20px,4vw,44px)]">
        <p class="mb-3 font-mono text-xs uppercase tracking-[0.28em] text-accent-soft">{t(locale, 'hero.eyebrow')}</p>
        <h1 class="glow-text text-[clamp(44px,8vw,104px)] font-bold leading-[0.9] tracking-[-0.04em]"><span class="text-gradient">Frank Bültge</span></h1>
        <p class="mt-5 max-w-xl text-pretty text-base text-fg-muted sm:text-lg">
          <strong class="font-semibold text-fg">{t(locale, 'hero.roleLead')}</strong>{t(locale, 'hero.roleRest')}
        </p>
        <p class="mt-3 max-w-xl text-pretty text-sm text-fg-muted">{copy.statement}</p>
      </div>
    </section>

    <!-- data-source caption (integrity: real, cited, with baseline) -->
    <p class="col-span-12 font-mono text-[11px] leading-relaxed text-fg-faint">
      {copy.caption} ·
      <a href={meta?.url} target="_blank" rel="noopener" class="underline decoration-line underline-offset-2 transition-colors hover:text-fg">NASA GISTEMP v4</a>
    </p>

    <!-- Lab placeholder -->
    <section class="col-span-12 mt-6 rounded-[14px] border border-line bg-panel panel-raised p-6">
      <div class="mb-2 flex items-center gap-2 text-[13px] font-semibold"><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-fg-faint">lab</span>{copy.labTitle}</div>
      <p class="max-w-2xl text-sm text-fg-muted">{copy.labText}</p>
    </section>

  </div>
</main>
