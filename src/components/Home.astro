---
// Experimente zuerst: Hero (Klimapuls) → lebendes Protokoll → Experimente → eigene Projekte.
// Spec: docs/superpowers/specs/2026-06-12-startseite-design.md
import { getRelativeLocaleUrl } from 'astro:i18n'
import { t } from '@/i18n/ui'
import type { Locale } from '@/lib/site'
import HeroField from '@/components/HeroField.astro'
import ProtokollTeaser from '@/components/ProtokollTeaser.astro'
import WerkeStrip from '@/components/WerkeStrip.astro'
import { projects } from '@/data/projects'

const locale = (Astro.currentLocale ?? 'en') as Locale

const featured = [...projects].sort((a, b) => a.order - b.order)
---

<main id="main" class="grid-paper min-w-0 flex-1 px-[clamp(20px,3vw,40px)] pb-16 pt-[clamp(16px,3vw,28px)]">
  <div class="mx-auto grid max-w-6xl grid-cols-12 gap-4">

    <!-- HERO — climate ridgeline behind the name -->
    <section class="relative col-span-12 flex min-h-[clamp(420px,64vh,640px)] items-end overflow-hidden rounded-[18px] border border-line bg-panel panel-raised">
      <HeroField />
      <div aria-hidden class="hero-gradient pointer-events-none absolute inset-0"></div>
      <div class="absolute right-5 top-5 flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-fg-muted">
        <span class="dot-live h-[7px] w-[7px] rounded-full"></span>{t(locale, 'system.live')}
      </div>
      <div class="relative z-[2] p-[clamp(20px,4vw,44px)]">
        <h1 class="glow-text text-[clamp(44px,8vw,104px)] font-bold leading-[0.9] tracking-[-0.04em]"><span class="text-gradient">Frank Bültge</span></h1>
        <p class="mt-5 max-w-xl text-pretty text-base text-fg-muted sm:text-lg">
          <strong class="font-semibold text-fg">{t(locale, 'hero.roleLead')}</strong>{t(locale, 'hero.roleRest')}
        </p>
      </div>
    </section>

    <!-- Das lebende Protokoll — erneuert sich mit jedem nächtlichen Pipeline-Commit -->
    <section class="col-span-12 mt-6 rounded-[14px] border border-line bg-panel panel-raised p-[clamp(20px,3.5vw,36px)]">
      <ProtokollTeaser locale={locale} />
    </section>

    <!-- Experimente -->
    <section class="col-span-12 mt-4">
      <WerkeStrip locale={locale} />
    </section>

    <!-- Eigene Projekte / Side Projects -->
    <section class="col-span-12 mt-4 rounded-[14px] border border-line bg-panel panel-raised p-6">
      <p class="mb-1 font-mono text-xs uppercase tracking-[0.2em] text-fg-faint">{t(locale, 'home.beruflich')}</p>
      <p class="mb-4 max-w-2xl text-sm text-fg-muted">{t(locale, 'home.beruflichLead')}</p>
      <ul class="space-y-2">
        {featured.map((p) => (
          <li class="text-sm">
            <a href={p.url ?? getRelativeLocaleUrl(locale, `/work/${p.slug}`)} class="font-semibold transition-opacity hover:opacity-70">{p.name}</a>
            <span class="text-fg-muted"> — {p.tagline[locale]}</span>
          </li>
        ))}
      </ul>
      <a href={getRelativeLocaleUrl(locale, '/lab')} class="mt-4 inline-block text-sm text-fg-muted transition-colors hover:text-fg">
        → {t(locale, 'home.toLab')}
      </a>
    </section>

  </div>
</main>

<style>
  /* Hero-Gradient: bewusst als CSS-Klasse statt inline-style (CSP-sicher). */
  .hero-gradient {
    background:
      linear-gradient(90deg, rgb(var(--rgb-bg)) 2%, rgb(var(--rgb-bg)/0.55) 30%, transparent 70%),
      linear-gradient(0deg, rgb(var(--rgb-bg)) 2%, transparent 42%);
  }
</style>
