---
// Ridgeline ("Joy Division") field driven by REAL data: NASA GISTEMP global
// monthly temperature anomalies (1880–present). One ridge per year (oldest at
// the back/top), month → x-axis, anomaly → height. Heights are a faithful global
// normalization (see src/lib/climate.ts) — warming shows up because recent years
// carry higher anomalies, so their ridges sit higher and crowd the front.
//
// The GEOMETRY is the data; the STYLING is the skin. Reads CSS colour vars plus
// --puls-mode (solid | glow | raw | ascii) and re-dresses on theme/skin change.
// Pauses off-screen; renders a single static frame under prefers-reduced-motion.
import snapshot from '@/data/climate/global-temp-anomalies.json'
import { seriesToRidges, type ClimateSeries } from '@/lib/climate'

const ridges = seriesToRidges(snapshot as ClimateSeries)
const ridgeHeights = ridges.map((r) => r.heights)
---

<canvas data-herofield aria-hidden="true" class="absolute inset-0 h-full w-full"></canvas>
<script type="application/json" data-ridges set:html={JSON.stringify(ridgeHeights)}></script>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('[data-herofield]')
  const ctx = canvas?.getContext('2d')
  const ridgesEl = document.querySelector('[data-ridges]')
  if (canvas && ctx && ridgesEl) {
    const ridges: number[][] = JSON.parse(ridgesEl.textContent || '[]')
    const ROWS = ridges.length

    const cssVar = (n: string, fb: [number, number, number]): [number, number, number] => {
      const v = getComputedStyle(document.documentElement).getPropertyValue(n).trim().split(/\s+/).map(Number)
      return v.length === 3 && v.every(Number.isFinite) ? (v as [number, number, number]) : fb
    }
    const cssStr = (n: string, fb: string): string => getComputedStyle(document.documentElement).getPropertyValue(n).trim() || fb

    let accent = cssVar('--rgb-accent', [124, 92, 252])
    let accentSoft = cssVar('--rgb-accent-soft', [167, 139, 250])
    let cyan = cssVar('--rgb-cyan', [34, 211, 238])
    let bg = cssVar('--rgb-bg', [8, 9, 13])
    let mode = cssStr('--puls-mode', 'glow')

    // Per-skin render config: line weight, neon glow, dash pattern, dot style.
    type DotStyle = 'bloom' | 'flat' | 'none'
    const cfg = (m: string): { lw: number; glow: number; dash: number[]; dots: DotStyle } => {
      switch (m) {
        case 'solid': return { lw: 2.4, glow: 0, dash: [], dots: 'flat' }
        case 'raw': return { lw: 1.7, glow: 0, dash: [], dots: 'none' }
        case 'ascii': return { lw: 1.1, glow: 0, dash: [2, 3], dots: 'flat' }
        case 'glow': return { lw: 1.4, glow: 9, dash: [], dots: 'bloom' }
        default: return { lw: 1.3, glow: 0, dash: [], dots: 'bloom' }
      }
    }

    // Live (rendered) vs target render params. A skin change sets the targets in
    // reReadVars(); the draw loop eases the live values toward them so the ridgeline
    // colour / weight / glow cross-fades in sync with the CSS skin transition.
    // (dash & dots are discrete — they swap immediately on the new mode.)
    let tAccent = cssVar('--rgb-accent', accent)
    let tAccentSoft = cssVar('--rgb-accent-soft', accentSoft)
    let tCyan = cssVar('--rgb-cyan', cyan)
    let tBg = cssVar('--rgb-bg', bg)
    let lwCur = cfg(mode).lw, lwTgt = lwCur
    let glowCur = cfg(mode).glow, glowTgt = glowCur

    const STEP = 8
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t
    const approach = (cur: [number, number, number], tgt: [number, number, number], k: number): [number, number, number] =>
      [cur[0] + (tgt[0] - cur[0]) * k, cur[1] + (tgt[1] - cur[1]) * k, cur[2] + (tgt[2] - cur[2]) * k]

    const sampleRidge = (row: number, x: number): number => {
      const h = ridges[row]
      if (!h || !h.length) return 0
      const f = Math.max(0, Math.min(1, x)) * (h.length - 1)
      const lo = Math.floor(f)
      const hi = Math.min(h.length - 1, lo + 1)
      return lerp(h[lo], h[hi], f - lo)
    }

    const blend = (a: number[], b: number[], k: number): number[] => [Math.round(lerp(a[0], b[0], k)), Math.round(lerp(a[1], b[1], k)), Math.round(lerp(a[2], b[2], k))]
    const palette = (): number[][] => [accent, accentSoft, cyan, blend(accent, cyan, 0.5), blend(cyan, [236, 248, 255], 0.45)].map((c) => [Math.round(c[0]), Math.round(c[1]), Math.round(c[2])])

    let W = 0, H = 0
    type Dot = { row: number; x: number; speed: number; ci: number; size: number }
    const newDot = (stagger = false): Dot => ({ row: 2 + Math.floor(Math.random() * (ROWS - 3)), x: stagger ? Math.random() : -0.02, speed: 0.04 + Math.random() * 0.13, ci: Math.floor(Math.random() * 5), size: 1.8 + Math.random() * 2 })
    let dots: Dot[] = []

    const resize = () => {
      const r = canvas.getBoundingClientRect()
      const dpr = Math.min(window.devicePixelRatio || 1, 2)
      W = r.width; H = r.height
      canvas.width = Math.round(W * dpr); canvas.height = Math.round(H * dpr)
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
    }

    // Layout: rows march downward; oldest (cold, low) at the top, newest (warm,
    // high) crowding the front. Warming reads as the ribbon rising toward the front.
    const yFor = (p01: number, i: number) => {
      const top = H * 0.12
      const gap = (H * 0.82) / ROWS
      const amp = H * 0.16
      return top + i * gap - sampleRidge(i, p01) * amp
    }

    const draw = (dt: number) => {
      if (W === 0 || H === 0) return
      ctx.clearRect(0, 0, W, H)
      // Ease the live colours / weight / glow toward the current skin's targets.
      const k = 1 - Math.exp(-dt / 0.18) // ~0.6s settle; 0 when dt is 0 (static)
      accent = approach(accent, tAccent, k)
      accentSoft = approach(accentSoft, tAccentSoft, k)
      cyan = approach(cyan, tCyan, k)
      bg = approach(bg, tBg, k)
      lwCur += (lwTgt - lwCur) * k
      glowCur += (glowTgt - glowCur) * k
      const pal = palette()
      const c = cfg(mode)
      for (const d of dots) { d.x += d.speed * dt; if (d.x > 1.02) Object.assign(d, newDot()) }

      for (let i = 0; i < ROWS; i++) {
        const depth = i / (ROWS - 1)
        const pts: number[][] = []
        for (let px = -STEP; px <= W + STEP; px += STEP) pts.push([px, yFor(px / W, i)])
        // occlusion fill (extends below the frame; never stroked, never blurred)
        ctx.shadowBlur = 0
        ctx.setLineDash([])
        ctx.beginPath()
        ctx.moveTo(pts[0][0], pts[0][1])
        for (let k = 1; k < pts.length; k++) ctx.lineTo(pts[k][0], pts[k][1])
        ctx.lineTo(W + STEP, H + 2)
        ctx.lineTo(-STEP, H + 2)
        ctx.closePath()
        ctx.fillStyle = `rgb(${Math.round(bg[0])} ${Math.round(bg[1])} ${Math.round(bg[2])})`
        ctx.fill()
        // the line — older rows dim/accent, newer rows bright/cyan
        const r = Math.round(lerp(accent[0], cyan[0], depth)), g = Math.round(lerp(accent[1], cyan[1], depth)), b = Math.round(lerp(accent[2], cyan[2], depth))
        const stroke = `rgb(${r} ${g} ${b} / ${(0.18 + depth * 0.62).toFixed(2)})`
        ctx.beginPath()
        ctx.moveTo(pts[0][0], pts[0][1])
        for (let k = 1; k < pts.length; k++) ctx.lineTo(pts[k][0], pts[k][1])
        ctx.strokeStyle = stroke
        ctx.lineWidth = lwCur
        ctx.setLineDash(c.dash)
        if (glowCur > 0.05) { ctx.shadowBlur = glowCur; ctx.shadowColor = `rgb(${r} ${g} ${b})` }
        ctx.stroke()
        ctx.shadowBlur = 0
        ctx.setLineDash([])
        // travelling glow dots on THIS row
        if (c.dots !== 'none') {
          for (const d of dots) {
            if (d.row !== i) continue
            const fade = Math.min(1, Math.min(d.x + 0.02, 1.02 - d.x) * 12)
            if (fade <= 0) continue
            const cx = d.x * W, cy = yFor(d.x, d.row), alpha = fade * (0.5 + depth * 0.45)
            const col = pal[d.ci % pal.length]
            if (c.dots === 'bloom') {
              ctx.globalCompositeOperation = 'lighter'
              ctx.fillStyle = `rgb(${col[0]} ${col[1]} ${col[2]} / ${(alpha * 0.16).toFixed(3)})`
              ctx.beginPath(); ctx.arc(cx, cy, d.size + 4.5, 0, Math.PI * 2); ctx.fill()
              ctx.globalCompositeOperation = 'source-over'
            }
            ctx.fillStyle = `rgb(${col[0]} ${col[1]} ${col[2]} / ${alpha.toFixed(2)})`
            ctx.beginPath(); ctx.arc(cx, cy, d.size, 0, Math.PI * 2); ctx.fill()
          }
        }
      }
    }

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches

    const reReadVars = () => {
      tAccent = cssVar('--rgb-accent', tAccent)
      tAccentSoft = cssVar('--rgb-accent-soft', tAccentSoft)
      tCyan = cssVar('--rgb-cyan', tCyan)
      tBg = cssVar('--rgb-bg', tBg)
      mode = cssStr('--puls-mode', mode) // dash/dots swap now; lw/glow/colours ease
      const c = cfg(mode)
      lwTgt = c.lw; glowTgt = c.glow
      // No motion → no tween: snap the live values so the static repaint is correct.
      if (reduce) { accent = tAccent; accentSoft = tAccentSoft; cyan = tCyan; bg = tBg; lwCur = lwTgt; glowCur = glowTgt }
    }

    resize()
    if (reduce) {
      draw(0)
    } else {
      dots = Array.from({ length: 10 }, () => newDot(true))
      let raf = 0, last = performance.now(), visible = true
      const FRAME = 1000 / 30
      let lastDraw = 0
      const loop = (now: number) => {
        raf = requestAnimationFrame(loop)
        if (!visible) { last = now; return }
        if (now - lastDraw >= FRAME) {
          const dt = Math.min(now - last, 100) * 0.001
          last = now; lastDraw = now
          draw(dt)
        }
      }
      raf = requestAnimationFrame(loop)
      new IntersectionObserver(([e]) => { visible = e.isIntersecting; if (visible) last = performance.now() }).observe(canvas)
    }

    new ResizeObserver(() => { resize(); if (reduce) draw(0) }).observe(canvas)
    // Re-dress on theme/skin change (colours + --puls-mode). Animated mode picks
    // up the new closure vars on the next frame; static mode repaints here.
    new MutationObserver(() => { reReadVars(); if (reduce) draw(0) })
      .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'data-skin'] })
  }
</script>
