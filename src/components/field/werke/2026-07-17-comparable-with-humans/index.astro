  .cw-bar-panel { display: flex; gap: 1rem; align-items: flex-start; }
  .cw-bar-val { font-size: 2.6rem; color: #1f5f7a; font-variant-numeric: tabular-nums; line-height: 1; }
  .cw-bar-txt { font-size: 0.84rem; color: #34424a; }
  .cw-zoneB-note { font-size: 0.78rem; color: #56656d; margin: 0.9rem 0 0; }

  .cw-reading { margin: 0.4rem 0 1.4rem; }
  .cw-reading h2, .cw-foot h2 { font-size: 1.02rem; margin: 0 0 0.7rem; }
  .cw-reading ol { padding-left: 1.2rem; font-size: 0.86rem; }
  .cw-reading li { margin-bottom: 0.8rem; }

  .cw-foot { border-top: 1px solid #ddd; padding-top: 1rem; }
  .cw-foot ul { padding-left: 1.1rem; font-size: 0.79rem; color: #444; }
  .cw-foot li { margin-bottom: 0.5rem; }
