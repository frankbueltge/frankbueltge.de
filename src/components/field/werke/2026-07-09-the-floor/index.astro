---
import data from './data.json'

// ---- source fields (all display numbers trace back to these) ----------
const years = data.series.years
const pueSeries = data.series.fleet_pue.values
const emissions = data.series.scope2_location_based_tco2e.values
const industryAvg = data.disclosed_totals_2024.industry_avg_pue_2024
const floor = data.pue_definition.floor

const arithmetic = data.arithmetic
const headroom = arithmetic.remaining_headroom
const singleYearGrowth = arithmetic.single_year_growth
const verdictRatio = arithmetic.verdict_ratio
const breakeven = arithmetic.breakeven
const perYearBreakeven = arithmetic.per_year_breakeven

const claim = data.the_claim_under_trial
const honesty = data.honesty_and_self_implication
const reports = data.subject.reports
const pueDef = data.pue_definition
const priorArt = data.prior_art

const postscript = data.subsequent_disclosure
const vintage2026 = postscript.inventory_2026_vintage

// time axis: gauge + bars now run 2019–2025, the extra year drawn from the
// subject's next disclosure (postscript), not the original report series
const years7 = [...years, 2025]
const pueSeries7 = [...pueSeries, postscript.fleet_pue_2025]

// ---- chart geometry (visual layout constants, not measured facts) -----
// Scale chosen to (a) hold the industry average (1.56) near the top for
// contrast and (b) leave room below the floor for growth up to 40%.
const TOP_VALUE = 1.60
const BOTTOM_VALUE = 0.75
const CH = 400
const CW = 260
const PAD_X = 24

function yFor(v: number) {
  return ((TOP_VALUE - v) / (TOP_VALUE - BOTTOM_VALUE)) * CH
}

const floorY = yFor(floor)
const industryY = yFor(industryAvg)

const plotW = CW - PAD_X * 2
const stepX = plotW / (years7.length - 1)
const pueXY = years7.map((yr, i) => ({
  year: yr,
  value: pueSeries7[i],
  x: PAD_X + i * stepX,
  y: yFor(pueSeries7[i]),
}))
// solid path for 2019–2024 (the report the claim under trial comes from);
// the 2024→2025 leg is drawn separately, dashed, as the next disclosure
const pathD = pueXY.slice(0, -1).map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`).join(' ')
const lastTwo = pueXY.slice(-2)
const lastSegD = `M ${lastTwo[0].x.toFixed(2)} ${lastTwo[0].y.toFixed(2)} L ${lastTwo[1].x.toFixed(2)} ${lastTwo[1].y.toFixed(2)}`

const gaugeTicks = [1.60, 1.40, 1.20, 1.00, 0.80].map((v) => ({ v, y: yFor(v) }))

// the row of impossible points — one required-PUE marker per disclosed year
// (session 18: replaces the single fixed 2024 annotation)
const breakevenMarkers = perYearBreakeven.rows.map((r) => {
  const idx = years7.indexOf(r.year)
  const x = pueXY[idx].x
  return {
    year: r.year,
    x,
    y: yFor(r.required_pue),
    required_pue: r.required_pue,
    // the open marker flags a different growth-scope basis (total vs data-center
    // electricity) — same discipline as the emissions panel's vintage flag
    scopeDistinct: Boolean(r.scope_distinct),
    label: `'${String(r.year).slice(-2)} → ${r.required_pue.toFixed(2)}`,
  }
})

// ---- emissions column chart -------------------------------------------
// 2019–2024 stay on the 2025-report vintage (data.series, untouched); 2025 is
// appended from the 2026 report's restated inventory and visually flagged
const emissions7 = [...emissions, vintage2026.scope2_location_based_tco2e_2019_2025[6]]
const maxEmission = Math.max(...emissions7)
const BAR_BASE_Y = CH - 20
const BAR_MAX_H = 360
const barSlot = plotW / years7.length
const barW = barSlot * 0.6
const bars = years7.map((yr, i) => {
  const value = emissions7[i]
  const isVintage2026 = i === years7.length - 1
  const h = (value / maxEmission) * BAR_MAX_H
  return {
    year: yr,
    value,
    displayM: (value / 1e6).toFixed(2),
    x: PAD_X + i * barSlot + (barSlot - barW) / 2,
    w: barW,
    y: BAR_BASE_Y - h,
    h,
    isVintage2026,
  }
})
// one decimal so the rendered figure (120.5%) agrees with the prose everywhere
// (computed on the original 2019–2024, 2025-report-vintage series only)
const emissionGrowthDisplay = (((emissions[emissions.length - 1] - emissions[0]) / emissions[0]) * 100).toFixed(1)
// growth figures on the 2026-report vintage — explicit data fields, verified in claims ledger
const vintage2425Pct = vintage2026.growth_2024_2025_this_vintage_pct
const vintage1924Pct = vintage2026.growth_2019_2024_this_vintage_pct

// ---- breakeven slider defaults (server-rendered; correct with JS off) --
// default = the 2024 row: matches the pre-session-18 server default exactly
const default2024Row = perYearBreakeven.rows.find((r) => r.year === 2024)
const basePue = breakeven.base_pue // 1.10
const defaultGrowth = breakeven.google_2024_growth_pct // 27
const defaultRequired = breakeven.required_pue_at_2024_growth // 0.87, from data
const defaultBaseMeaning = default2024Row ? default2024Row.base_meaning : ''
// marker position uses the unrounded value so the no-JS position matches what
// the client script computes on hydration
const defaultRequiredRaw = basePue / (1 + defaultGrowth / 100)
const defaultImpossible = defaultRequired < floor
const defaultMarkerX = pueXY[years7.indexOf(2024)].x

// per-year rows handed to the client for the year-preset buttons; the client
// reads this JSON island rather than recomputing anything itself
const breakevenRowsForClient = perYearBreakeven.rows.map((r) => ({
  year: r.year,
  growth_pct: r.growth_pct,
  base_pue: r.base_pue,
  base_meaning: r.base_meaning,
  required_pue: r.required_pue,
  x: pueXY[years7.indexOf(r.year)].x,
}))
const breakevenDataJSON = JSON.stringify(breakevenRowsForClient)

const concession = claim.concession
---

<section class="floor-instrument">
  <header class="head">
    <p class="eyebrow">instrument on trial — {data.instrument_on_trial}</p>
    <h1>The Floor</h1>
    <p class="dek">
      {pueDef.formula} · a ratio with a hard floor of {floor.toFixed(2)} plotted against the absolute it is framed as offsetting.
    </p>
  </header>

  <div class="grid">
    <!-- ============ LEFT: PUE gauge ============ -->
    <figure class="panel gauge-panel">
      <figcaption>Fleet PUE, 2019–2025 <span class="src">(owned &amp; operated campuses)</span></figcaption>
      <svg class="gauge" viewBox={`0 0 ${CW} ${CH}`} role="img" aria-label={`PUE gauge showing fleet PUE hugging the 1.00 floor, 2019 to 2025 (seven years), moved 0.01 overall; three per-year required-PUE markers below the floor — ${breakevenMarkers.map((m) => m.required_pue.toFixed(2)).join(', ')}`}>
        <defs>
          <pattern id="hatch" width="8" height="8" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
            <rect width="8" height="8" class="hatch-bg" />
            <line x1="0" y1="0" x2="0" y2="8" class="hatch-line" />
          </pattern>
        </defs>

        <!-- impossible band -->
        <rect x={PAD_X - 6} y={floorY} width={plotW + 12} height={CH - floorY} fill="url(#hatch)" class="impossible-band" />
        <rect x={PAD_X - 6} y={floorY} width={plotW + 12} height={CH - floorY} class="impossible-band-outline" />
        <text x={PAD_X} y={floorY + 20} class="band-label">IMPOSSIBLE — PUE &lt; 1.00</text>

        <!-- gridlines / ticks -->
        {gaugeTicks.map((t) => (
          <g>
            <line x1={PAD_X - 6} y1={t.y} x2={CW - PAD_X + 6} y2={t.y} class="tick-line" />
            <text x={CW - PAD_X + 8} y={t.y + 4} class="tick-label">{t.v.toFixed(2)}</text>
          </g>
        ))}

        <!-- floor line -->
        <line x1={PAD_X - 10} y1={floorY} x2={CW - PAD_X + 10} y2={floorY} class="floor-line" />
        <text x={PAD_X - 10} y={floorY - 8} class="floor-label">PHYSICAL FLOOR · PUE cannot cross</text>

        <!-- industry average, for scale -->
        <line x1={PAD_X} y1={industryY} x2={CW - PAD_X} y2={industryY} class="industry-line" />
        <text x={PAD_X} y={industryY - 6} class="industry-label">industry avg {industryAvg.toFixed(2)}</text>

        <!-- fleet PUE path: solid 2019–2024 (claim-under-trial report), dashed 2024→2025 (next disclosure) -->
        <path d={pathD} class="pue-path" />
        <path d={lastSegD} class="pue-path pue-path--vintage2026" />
        {pueXY.slice(0, -1).map((p) => (
          <g>
            <circle cx={p.x} cy={p.y} r="3.2" class="pue-dot" />
          </g>
        ))}
        <circle cx={pueXY[pueXY.length - 1].x} cy={pueXY[pueXY.length - 1].y} r="3.4" class="pue-dot pue-dot--vintage2026" />
        <text x={pueXY[0].x} y={pueXY[0].y - 10} class="pue-path-label">1.10 flat, 2019–2023</text>
        <text x={pueXY[pueXY.length - 2].x} y={pueXY[pueXY.length - 2].y + 16} class="pue-path-label">1.09, 2024</text>
        <text x={pueXY[pueXY.length - 1].x} y={pueXY[pueXY.length - 1].y - 10} class="pue-path-label pue-path-label--vintage2026" text-anchor="end">1.09, 2025 (2026 report)</text>

        <!-- the row of impossible points: one required-PUE marker per disclosed year -->
        {breakevenMarkers.map((m) => (
          <g>
            <polygon points={`${m.x},${m.y - 4} ${m.x + 4},${m.y} ${m.x},${m.y + 4} ${m.x - 4},${m.y}`} class:list={["breakeven-dot", { "breakeven-dot--scope": m.scopeDistinct }]} />
            <text x={m.x} y={m.y - 8} class="breakeven-label" text-anchor="middle">{m.scopeDistinct ? `${m.label}*` : m.label}</text>
          </g>
        ))}

        <!-- live slider marker (JS enhancement only) -->
        <circle id="live-marker" cx={defaultMarkerX} cy={yFor(defaultRequiredRaw)} r="5" class:list={["live-marker", { impossible: defaultImpossible }]} />

        <!-- year labels -->
        {pueXY.map((p) => (
          <text x={p.x} y={CH - 4} class="year-label">{p.year}</text>
        ))}
      </svg>
      <p class="panel-note">Seven years. The metric moved 0.01. Remaining headroom to the floor: {headroom.value_pct.toFixed(1)}% — a fixed ceiling on the ratio, spent once.</p>
      <p class="panel-note">{perYearBreakeven.reading}</p>
    </figure>

    <!-- ============ RIGHT: rising absolute ============ -->
    <figure class="panel bars-panel">
      <figcaption>Disclosed absolute — location-based Scope&nbsp;2 <span class="src">(tCO₂e, 2019–2025, two report vintages)</span></figcaption>
      <svg class="bars" viewBox={`0 0 ${CW} ${CH}`} role="img" aria-label={`Rising column chart of Scope 2 location-based emissions, 2019 to 2025; 2019 to 2024 up ${emissionGrowthDisplay} percent on the 2025-report vintage; 2025 shown on the 2026-report inventory vintage`}>
        <line x1={PAD_X - 6} y1={BAR_BASE_Y} x2={CW - PAD_X + 6} y2={BAR_BASE_Y} class="baseline" />
        {bars.map((b) => (
          <g>
            <rect x={b.x} y={b.y} width={b.w} height={b.h} class:list={["bar", { "bar--vintage2026": b.isVintage2026 }]} />
            <text x={b.x + b.w / 2} y={b.y - 6} class="bar-value">{b.displayM}M</text>
            <text x={b.x + b.w / 2} y={CH - 4} class:list={["year-label", { "year-label--vintage2026": b.isVintage2026 }]}>{b.isVintage2026 ? `${b.year}*` : b.year}</text>
          </g>
        ))}
      </svg>
      <p class="panel-note">2019 → 2024: {(emissions[0]).toLocaleString('en-US')} → {(emissions[emissions.length - 1]).toLocaleString('en-US')} tCO₂e — up {emissionGrowthDisplay}%. Location-based — the meter of physical grid draw, per instrument 012, "The Two Meters".</p>
      <p class="panel-note panel-note--caveat">Scope caveat: this series covers Google's purchased electricity broadly (the report attributes ~95% of Scope 2 to "data centers and offices") — a wider set of buildings than the PUE line's owned-and-operated fleet. For the footprint outside the fleet, no PUE-like ratio is disclosed at all.</p>
      <p class="panel-note panel-note--caveat">Vintage note: the 2025 column (marked *) is from the 2026 report's inventory, which also recalculates 2019–2024 — verbatim, "In 2025, we recalculated certain previously reported metrics" — so the two vintages are never merged into one series. On the 2026-report vintage, 2025 is +{vintage2425Pct}% over that report's own restated 2024 (numerically near the separately disclosed 37% electricity growth — distinct quantities; the proximity is not a claimed relationship), and the 2019→2024 span restates to +{vintage1924Pct}% — smaller than the +{emissionGrowthDisplay}% shown, which is the report-under-trial's own vintage. See honesty item 9.</p>
    </figure>
  </div>

  <!-- ============ verdict line ============ -->
  <p class="verdict">
    Remaining headroom {headroom.value_pct.toFixed(1)}% (a fixed ceiling on the ratio) · One year's growth {singleYearGrowth.value_pct}% · The lever's whole future is less than a third of a single year — and the six-year disclosed absolute is up {emissionGrowthDisplay}%.
    <span class="verdict-note">{headroom.computation} · {verdictRatio.computation}</span>
  </p>

  <!-- ============ exhibit: the claim under trial ============ -->
  <section class="exhibit">
    <p class="exhibit-tag">Exhibit — Figure 4, {reports[0].title} ({reports[0].published})</p>
    <blockquote>{claim.figure4_framing_verbatim}</blockquote>
    <blockquote class="exhibit-secondary">{claim.growth_verbatim}.</blockquote>
    <ul class="exhibit-headlines">
      {claim.supporting_efficiency_headlines.map((h) => (<li>{h}</li>))}
    </ul>
    <p class="exhibit-concession">{concession}</p>
  </section>

  <!-- ============ the trial move: breakeven slider ============ -->
  <section class="trial">
    <h2>The trial move — set a year's growth, read the required PUE</h2>
    <p class="trial-formula">{breakeven.formula}</p>

    <div class="year-presets" role="group" aria-label="Jump to a disclosed year">
      {perYearBreakeven.rows.map((r) => (
        <button type="button" class:list={["year-preset", { "year-preset--active": r.year === 2024 }]} data-year={r.year}>
          {r.year} · {r.growth_pct}%
        </button>
      ))}
    </div>

    <div class="slider-row">
      <label for="growth-slider">This year's total electricity growth</label>
      <input id="growth-slider" type="range" min="0" max="40" step="1" value={defaultGrowth} />
      <span id="growth-readout" class="readout">{defaultGrowth}%</span>
    </div>
    <p class="base-line"><span id="base-readout" class="base-value">base {basePue.toFixed(2)} ({defaultBaseMeaning})</span></p>
    <p class="required-row">
      Required PUE to hold energy flat:
      <span id="required-pue" class:list={["required-value", { impossible: defaultImpossible }]}>{defaultRequired.toFixed(2)}</span>
      <span id="required-status" class:list={["required-status", { impossible: defaultImpossible }]}>
        {defaultImpossible ? 'IMPOSSIBLE — below the physical floor' : 'within physical bounds'}
      </span>
    </p>
    <p class="trial-note">
      Fixed point: Google's actual 2024 growth, {breakeven.google_2024_growth_pct}%, requires PUE ≈{breakeven.required_pue_at_2024_growth.toFixed(2)} to hold flat —
      {breakeven.crosses_floor_note} {breakeven.even_lower_note}
    </p>
    <p class="trial-note">{breakeven.robustness_note}</p>

    <script type="application/json" id="breakeven-data" set:html={breakevenDataJSON}></script>
  </section>

  <!-- ============ postscript: the year after ============ -->
  <section class="postscript">
    <h2>Postscript — the subject's next disclosure (added in the shipping gauntlet)</h2>
    <p>
      <a href={postscript.report.official_url}>{postscript.report.title}</a> ({postscript.report.published}, covers {postscript.report.covers}), fetched {postscript.report.fetched}:
      <em>"{postscript.pue_verbatim}"</em> — and <em>"{postscript.growth_verbatim}"</em>.
    </p>
    <p>
      PUE unchanged at {postscript.fleet_pue_2025.toFixed(2)}; growth {postscript.growth_2025_pct}%. Required PUE to hold that year flat:
      {postscript.required_pue_computation} ({postscript.growth_wording_caveat})
    </p>
    <p>
      Its inventory also recalculates prior years — verbatim, "In 2025, we recalculated certain previously reported metrics" — and its 2025 location-based Scope&nbsp;2 is {vintage2026.scope2_location_based_tco2e_2019_2025[6].toLocaleString('en-US')} tCO₂e.
    </p>
  </section>

  <!-- ============ prior art ============ -->
  <section class="prior-art">
    <h2>Prior art — what was already established</h2>
    <p>{priorArt.note}</p>
    <ul class="prior-art-list">
      {priorArt.entries.map((e) => (
        <li><strong>{e.who}</strong> — {e.what} <a href={e.url}>{e.url}</a></li>
      ))}
    </ul>
    <p class="prior-art-contribution"><em>{priorArt.original_contribution}</em></p>
  </section>

  <!-- ============ honesty panel ============ -->
  <section class="honesty">
    <h2>Honesty &amp; self-implication</h2>
    <ol>
      {honesty.map((h) => (<li>{h}</li>))}
    </ol>
  </section>

  <!-- ============ sources footer ============ -->
  <footer class="sources">
    <p>Sources — the subject's own disclosures:</p>
    <ul>
      {reports.map((r) => (
        <li>{r.title} ({r.published}, covers {r.covers}) — <a href={r.official_url ?? r.pdf_mirror_extracted}>{r.official_url ?? r.pdf_mirror_extracted}</a></li>
      ))}
    </ul>
    <p class="sources-note">All figures above are Google's own reported numbers or deterministic arithmetic on them (floor = 1.00 by definition; no modeling, no external estimate).</p>
  </footer>
</section>

<script>
// @ts-nocheck — engine work script shielded from the site TS gate (sandboxed display code, vetted by the collective gauntlet + checkForbidden + astro build). A missing type annotation must never turn the whole site build red — see work 011, 2026-07-06.
  // The only interactive script in this work. It powers the breakeven slider
  // and the year-preset buttons — a progressive enhancement. Everything else
  // (the gauge, the row of impossible points, the columns, the verdict, the
  // prior-art and honesty panels) is fully legible with this disabled.
  const FLOOR = 1.00

  // must mirror the server-rendered chart scale exactly
  const TOP_VALUE = 1.60
  const BOTTOM_VALUE = 0.75
  const CHART_H = 400

  function yFor(v) {
    return ((TOP_VALUE - v) / (TOP_VALUE - BOTTOM_VALUE)) * CHART_H
  }

  const dataEl = document.getElementById('breakeven-data')
  let perYearRows = []
  if (dataEl && dataEl.textContent) {
    perYearRows = JSON.parse(dataEl.textContent)
  }

  const slider = document.getElementById('growth-slider')
  const readout = document.getElementById('growth-readout')
  const requiredEl = document.getElementById('required-pue')
  const statusEl = document.getElementById('required-status')
  const marker = document.getElementById('live-marker')
  const baseReadout = document.getElementById('base-readout')
  const presetButtons = document.querySelectorAll('.year-preset')

  const defaultRow = perYearRows.find((r) => r.year === 2024) || perYearRows[perYearRows.length - 1]
  let currentBase = defaultRow ? defaultRow.base_pue : 1.10
  let currentBaseMeaning = defaultRow ? defaultRow.base_meaning : ''
  let currentX = defaultRow && typeof defaultRow.x === 'number' ? defaultRow.x : null

  function setActivePreset(year) {
    presetButtons.forEach((btn) => {
      const btnYear = Number(btn.getAttribute('data-year'))
      btn.classList.toggle('year-preset--active', year !== null && btnYear === year)
    })
  }

  function update() {
    if (!slider) return
    const growth = Number(slider.value)
    const raw = currentBase / (1 + growth / 100)
    const impossible = raw < FLOOR
    const display = raw.toFixed(2)

    if (readout) readout.textContent = `${growth}%`
    if (requiredEl) {
      requiredEl.textContent = display
      requiredEl.classList.toggle('impossible', impossible)
    }
    if (statusEl) {
      statusEl.textContent = impossible ? 'IMPOSSIBLE — below the physical floor' : 'within physical bounds'
      statusEl.classList.toggle('impossible', impossible)
    }
    if (marker) {
      const clamped = Math.max(BOTTOM_VALUE, Math.min(TOP_VALUE, raw))
      marker.setAttribute('cy', String(yFor(clamped)))
      if (currentX !== null) marker.setAttribute('cx', String(currentX))
      marker.classList.toggle('impossible', impossible)
    }
    if (baseReadout) baseReadout.textContent = `base ${currentBase.toFixed(2)} (${currentBaseMeaning})`
  }

  presetButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const year = Number(btn.getAttribute('data-year'))
      const row = perYearRows.find((r) => r.year === year)
      if (!row || !slider) return
      currentBase = row.base_pue
      currentBaseMeaning = row.base_meaning
      currentX = typeof row.x === 'number' ? row.x : currentX
      slider.value = String(row.growth_pct)
      setActivePreset(year)
      update()
    })
  })

  if (slider) {
    slider.addEventListener('input', () => {
      setActivePreset(null)
      update()
    })
    setActivePreset(2024)
    update()
  }
</script>

<style>
  .floor-instrument {
    --paper: #efe9db;
    --ink: #1c1a15;
    --ink-soft: #4a4437;
    --rule: rgba(28, 26, 21, 0.28);
    --rule-faint: rgba(28, 26, 21, 0.14);
    --danger: #8c2a1f;
    --danger-bg: rgba(140, 42, 31, 0.10);
    --teal: #1f5c4a;
    --steel: #3a4a63;
    --amber: #8a6a1f;
    font-family: ui-monospace, "IBM Plex Mono", "Consolas", "Liberation Mono", "SFMono-Regular", monospace;
    background: var(--paper);
    color: var(--ink);
    padding: 2rem;
    border: 1px solid var(--rule);
    line-height: 1.5;
    max-width: 980px;
    margin: 0 auto;
  }

  .head {
    border-bottom: 2px solid var(--ink);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.7rem;
    color: var(--ink-soft);
    margin: 0 0 0.4rem;
  }
  .head h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
    letter-spacing: 0.02em;
  }
  .dek {
    margin: 0;
    font-size: 0.9rem;
    color: var(--ink-soft);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
  }

  .panel {
    border: 1px solid var(--rule);
    padding: 0.9rem 0.9rem 1.1rem;
    margin: 0;
  }
  .panel figcaption {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
    color: var(--ink-soft);
  }
  .src { text-transform: none; letter-spacing: 0; }

  svg.gauge, svg.bars {
    width: 100%;
    height: auto;
    display: block;
  }

  .hatch-bg { fill: var(--danger-bg); }
  .hatch-line { stroke: var(--danger); stroke-width: 1; opacity: 0.5; }
  .impossible-band-outline { fill: none; stroke: var(--danger); stroke-width: 1; stroke-dasharray: 2 2; }
  .band-label {
    font-size: 8px;
    fill: var(--danger);
    letter-spacing: 0.02em;
    font-weight: 700;
