---
// INSTRUMENT 006 — The Fairness Trap (Meridian, 2026-07-01)
//
// Data: ProPublica, "How We Analyzed the COMPAS Recidivism Algorithm" (May 2016)
// Larson, Mattu, Kirchner & Angwin — Broward County, FL, 2013–2014, general recidivism
// Source: propublica.org/article/how-we-analyzed-the-compas-recidivism-algorithm
// Confusion matrices reproduced exactly from published methodology table.
// Confirmed independently in: Dressel & Farid, Science Advances 4(1), 2018 (doi:10.1126/sciadv.aao5580)
//
// Chouldechova impossibility theorem:
// Chouldechova A. (2017). "Fair prediction with disparate impact: A study of bias in
// recidivism prediction instruments." Big Data 5(2):153–163. doi:10.1089/big.2016.0047

// --- Raw confusion matrix data (ProPublica, general recidivism, n=6,150 after race filter) ---
// Rows: actual outcome (no reoffend / reoffend)
// Cols: COMPAS prediction (low risk / high risk; medium+high treated as "high" per ProPublica)

const B = { TN: 990,  FP: 805, FN: 532, TP: 1369 }; // Black defendants
const W = { TN: 1139, FP: 349, FN: 461, TP: 505  }; // White defendants

const bN = B.TN + B.FP + B.FN + B.TP;  // 3696
const wN = W.TN + W.FP + W.FN + W.TP;  // 2454

// Key metrics
const bFPR  = B.FP / (B.TN + B.FP);           // false positive rate (wrongly labeled high)
const wFPR  = W.FP / (W.TN + W.FP);
const bFNR  = B.FN / (B.FN + B.TP);           // false negative rate (wrongly cleared)
const wFNR  = W.FN / (W.FN + W.TP);
const bPPV  = B.TP / (B.FP + B.TP);           // positive predictive value (precision)
const wPPV  = W.TP / (W.FP + W.TP);
const bBase = (B.FN + B.TP) / bN;             // actual recidivism base rate
const wBase = (W.FN + W.TP) / wN;

// Chouldechova (2017) impossibility theorem:
// If PPV is equal across groups with different base rates p_A ≠ p_B,
// then FPR cannot be equal. The constraint on FPR given equal PPV:
//   FPR_B / FPR_W = [p_B · (1 - p_W)] / [p_W · (1 - p_B)]
// This is a fixed ratio determined entirely by the base rates — independent of the model.
const chouldechova_ratio = (bBase * (1 - wBase)) / (wBase * (1 - bBase));
// With base rates 51.4% (Black) and 39.4% (White): ratio ≈ 1.63
// COMPAS actual ratio: bFPR / wFPR ≈ 1.91 (slightly above constraint because PPV ≠ exactly equal)

// Format helpers
const pct = (v: number, d = 1) => `${(v * 100).toFixed(d)}%`;
const pp  = (v: number) => `${(v * 100).toFixed(1)}pp`;

// ── SVG: Confusion matrix builder ──────────────────────────────────────────────────────
function buildMatrix(
  title: string,
  cells: { TN: number; FP: number; FN: number; TP: number },
  fpr: number, ppv: number, fnr: number, base: number
): string {
  const CW = 106, CH = 64;
  const LW = 44;  // left label column width
  const TH = 26;  // top header height
  const W  = LW + 2 * CW + 2;
  const H  = TH + 2 * CH + 2 + 42;

  const x0 = LW;
  const x1 = LW + CW;
  const y0 = TH;
  const y1 = TH + CH;

  const cell = (x: number, y: number, n: number, label: string, fill: string, textColor = '#222') => `
    <rect x="${x}" y="${y}" width="${CW}" height="${CH}" fill="${fill}" stroke="#d0d0d0" stroke-width="0.75" rx="2"/>
    <text x="${x + CW / 2}" y="${y + 26}" text-anchor="middle" font-size="17" font-weight="700" fill="${textColor}" font-family="monospace">${n.toLocaleString()}</text>
    <text x="${x + CW / 2}" y="${y + 44}" text-anchor="middle" font-size="9.5" fill="${textColor === '#222' ? '#666' : textColor}" font-family="sans-serif">${label}</text>
  `;

  return `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}" style="display:block;overflow:visible">
    <text x="${W / 2}" y="17" text-anchor="middle" font-size="12" font-weight="700" fill="#1a1a1a" font-family="sans-serif">${title}</text>
    <!-- column headers (COMPAS verdict) -->
    <text x="${x0 + CW / 2}" y="${TH - 5}" text-anchor="middle" font-size="10" fill="#555" font-family="sans-serif">Low risk</text>
    <text x="${x1 + CW / 2}" y="${TH - 5}" text-anchor="middle" font-size="10" fill="#555" font-family="sans-serif">High risk</text>
    <!-- row headers (actual outcome) -->
    <text x="${x0 - 4}" y="${y0 + 30}" text-anchor="end" font-size="10" fill="#555" font-family="sans-serif">No</text>
    <text x="${x0 - 4}" y="${y0 + 42}" text-anchor="end" font-size="10" fill="#555" font-family="sans-serif">reoffend</text>
    <text x="${x0 - 4}" y="${y1 + 35}" text-anchor="end" font-size="10" fill="#555" font-family="sans-serif">Reoffend</text>
    <!-- cells: TN, FP, FN, TP -->
    ${cell(x0, y0, cells.TN, 'correctly cleared', '#d8f5e6')}
    ${cell(x1, y0, cells.FP, 'wrongly flagged', '#f8d7da', '#8b1a1a')}
    ${cell(x0, y1, cells.FN, 'missed risk',       '#fff3cd')}
    ${cell(x1, y1, cells.TP, 'correctly flagged', '#c3e6cb')}
    <!-- metric strip -->
    <text x="2"       y="${H - 12}" font-size="10" fill="#333" font-family="sans-serif">FPR <tspan font-weight="700" fill="${fpr > 0.35 ? '#8b1a1a' : '#2a6a3f'}">${pct(fpr)}</tspan></text>
    <text x="${W / 2}" y="${H - 12}" text-anchor="middle" font-size="10" fill="#333" font-family="sans-serif">PPV <tspan font-weight="700">${pct(ppv)}</tspan></text>
    <text x="${W}"    y="${H - 12}" text-anchor="end" font-size="10" fill="#333" font-family="sans-serif">base <tspan font-weight="700">${pct(base)}</tspan></text>
  </svg>`;
}

const bMatrixSVG = buildMatrix(`Black defendants (n = ${bN.toLocaleString()})`, B, bFPR, bPPV, bFNR, bBase);
const wMatrixSVG = buildMatrix(`White defendants (n = ${wN.toLocaleString()})`, W, wFPR, wPPV, wFNR, wBase);

// ── SVG: Dual metric bar chart ────────────────────────────────────────────────────
// Two paired bars: FPR (Black vs White) and PPV (Black vs White)
// FPR shows disparity; PPV shows parity. Same data — different verdicts.

const BARCHART_W = 480;
const BARCHART_H = 280;
const BAR_ML = 70, BAR_MB = 50, BAR_MT = 35;
const BAR_PW = BARCHART_W - BAR_ML - 20;
const BAR_PH = BARCHART_H - BAR_MB - BAR_MT;

// Metric data: [ { label, Black, White, max, title, verdict, note } ]
const metrics = [
  {
    title: 'False Positive Rate',
    subtitle: '(ProPublica criterion)',
    bVal: bFPR, wVal: wFPR,
    max: 0.60,
    verdict: 'DISPARATE',
    verdictColor: '#8b1a1a',
    note: `Δ = ${pp(bFPR - wFPR)} — Black defendants wrongly flagged at nearly 2× the rate`
  },
  {
    title: 'Positive Predictive Value',
    subtitle: '(Northpointe criterion)',
    bVal: bPPV, wVal: wPPV,
    max: 1.00,
    verdict: 'NEAR PARITY',
    verdictColor: '#2a6a3f',
    note: `Δ = ${pp(bPPV - wPPV)} — When COMPAS flags someone, accuracy is similar across groups`
  }
];

function buildBarChart(): string {
  const panelH = BAR_PH / 2 - 12;
  const barH = 22;

  let svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${BARCHART_W}" height="${BARCHART_H}" style="display:block;max-width:100%">`;
  svg += `<text x="${BARCHART_W / 2}" y="22" text-anchor="middle" font-size="12" font-weight="700" fill="#1a1a1a" font-family="sans-serif">Same data — two metrics — two verdicts</text>`;

  metrics.forEach((m, i) => {
    const yBase = BAR_MT + i * (panelH + 28) + 16;
    const maxW = BAR_PW - 80;

    const bBarW = (m.bVal / m.max) * maxW;
    const wBarW = (m.wVal / m.max) * maxW;

    // Panel background
    svg += `<rect x="${BAR_ML - 8}" y="${yBase}" width="${BAR_PW + 28}" height="${panelH}" fill="${i === 0 ? '#fdf4f4' : '#f4faf4'}" rx="3" stroke="${m.verdictColor}" stroke-width="0.5" stroke-opacity="0.4"/>`;

    // Panel title
    svg += `<text x="${BAR_ML}" y="${yBase + 14}" font-size="11" font-weight="700" fill="#1a1a1a" font-family="sans-serif">${m.title}</text>`;
    svg += `<text x="${BAR_ML}" y="${yBase + 26}" font-size="9.5" fill="#777" font-family="sans-serif">${m.subtitle}</text>`;

    // Verdict badge
    svg += `<text x="${BARCHART_W - 16}" y="${yBase + 18}" text-anchor="end" font-size="11" font-weight="800" fill="${m.verdictColor}" font-family="sans-serif">${m.verdict}</text>`;

    // Black bar
    const by1 = yBase + 35;
    svg += `<rect x="${BAR_ML}" y="${by1}" width="${bBarW}" height="${barH}" fill="${i === 0 ? '#8b1a1a' : '#2a6a4a'}" rx="2"/>`;
    svg += `<text x="${BAR_ML - 4}" y="${by1 + 15}" text-anchor="end" font-size="10" fill="#333" font-family="sans-serif">Black</text>`;
    svg += `<text x="${BAR_ML + bBarW + 5}" y="${by1 + 15}" font-size="11" font-weight="700" fill="${i === 0 ? '#8b1a1a' : '#2a6a4a'}" font-family="monospace">${pct(m.bVal)}</text>`;

    // White bar
    const by2 = by1 + barH + 8;
    svg += `<rect x="${BAR_ML}" y="${by2}" width="${wBarW}" height="${barH}" fill="${i === 0 ? '#c07070' : '#6aaa7a'}" rx="2"/>`;
    svg += `<text x="${BAR_ML - 4}" y="${by2 + 15}" text-anchor="end" font-size="10" fill="#333" font-family="sans-serif">White</text>`;
    svg += `<text x="${BAR_ML + wBarW + 5}" y="${by2 + 15}" font-size="11" font-weight="700" fill="${i === 0 ? '#c07070' : '#6aaa7a'}" font-family="monospace">${pct(m.wVal)}</text>`;

    // Note
    svg += `<text x="${BAR_ML}" y="${by2 + barH + 14}" font-size="9.5" fill="#666" font-family="sans-serif" font-style="italic">${m.note}</text>`;
  });

  svg += `</svg>`;
  return svg;
}

const barChartSVG = buildBarChart();

// ── Pattern table ──────────────────────────────────────────────────────────────────────────
const totalN = bN + wN;
---

