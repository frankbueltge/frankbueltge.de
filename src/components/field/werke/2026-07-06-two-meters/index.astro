---
// Instrument (draft): The Two Meters
// A twin utility-bill / invoice register. For each company and disclosed year,
// two invoices for the same electricity consumption: METER A -- AS REPORTED
// (market-based) and METER B -- AS THE GRID SAW IT (location-based). Every
// figure below is read from ./data.json; this file only formats and lays it out.
// Meridian / 2026-07-06

import data from "./data.json";

interface MeterInfo {
  label: string;
  invoice_subline: string;
  explanation: string;
  explanation_status: string;
}
interface Meters {
  market_based: MeterInfo;
  location_based: MeterInfo;
}
interface DerivationFormulas {
  gap: string;
  ratio: string;
  trend: string;
  worked_examples: string[];
}
interface CompanyRow {
  year: string;
  market_based: number;
  location_based: number;
  gap: number;
  ratio: number;
}
interface TrendFirstToLast {
  market_based_pct: number;
  location_based_pct: number;
  window_label: string;
  window_note?: string;
  sentence: string;
}
interface Quote {
  text: string;
  attribution: string;
  note?: string;
}
interface Company {
  name: string;
  year_basis: string;
  year_basis_display: string;
  source: string;
  source_url: string;
  rows: CompanyRow[];
  trend_first_to_last: TrendFirstToLast;
  exhibit: string;
  headline_quote?: Quote;
  goal_anchor_quote?: Quote;
}
interface Finding {
  points: string[];
  conjecture_flag: string;
}
interface Crosscheck {
  name: string;
  url: string;
  verbatim: string;
  recomputation_quote: string;
  divergences_found: string;
}
interface InstrumentOnTrial {
  name: string;
  what_it_requires_verbatim: string;
  what_it_promises_verbatim: string;
  stated_benefits_verbatim: string[];
  what_it_leaves_free_verbatim: string;
  source_url: string;
  reading: string;
  the_test_applied: string;
}
interface DataShape {
  title: string;
  subtitle: string;
  unit: string;
  instrument_on_trial: InstrumentOnTrial;
  meters: Meters;
  derivation_formulas: DerivationFormulas;
  companies: Company[];
  finding: Finding;
  independent_crosscheck: Crosscheck;
  caveats: string[];
  seed_note: string;
}

const d = data as DataShape;
const instrument = d.instrument_on_trial;
const meters = d.meters;
const companies = d.companies;
const finding = d.finding;
const crosscheck = d.independent_crosscheck;

function fmt(n: number): string {
  return n.toLocaleString("en-US");
}

function fmtRatio(n: number): string {
  return n.toFixed(1) + "×";
}

function fmtPct(n: number): string {
  const prefix = n > 0 ? "+" : "";
  return prefix + n.toFixed(1) + "%";
}
---

<section class="two-meters">
  <header class="head-block">
    <div class="kicker">MERIDIAN &mdash; FIELD INSTRUMENT &middot; ON TRIAL</div>
    <h1>{d.title}</h1>
    <p class="subtitle">{d.subtitle}</p>
    <p class="unit-note">All amounts on every invoice below are stated in {d.unit}.</p>

    <p class="standing-note">
      <strong>Standing.</strong> Both companies report in full compliance with the GHG Protocol
      Scope&nbsp;2 standard. This work puts the <em>standard</em> on trial &mdash; not the
      companies&rsquo; conduct; it alleges no wrongdoing, breach, or deception. Every figure below
      is transcribed from the companies&rsquo; own published disclosures, each linked at its exhibit.
    </p>

    <div class="instrument-name">INSTRUMENT ON TRIAL: {instrument.name}</div>

    <div class="quote-block quote-requirement">
      <div class="quote-label">THE REQUIREMENT (verbatim)</div>
      <blockquote>{instrument.what_it_requires_verbatim}</blockquote>
    </div>

    <div class="quote-block quote-purpose">
      <div class="quote-label">THE STATED PURPOSE, &sect;7.4 (verbatim)</div>
      <blockquote>{instrument.what_it_promises_verbatim}</blockquote>
      <div class="benefits-label">stated benefits (verbatim):</div>
      <ul class="benefits-list">
        {instrument.stated_benefits_verbatim.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    </div>

    <div class="quote-block quote-discretion">
      <div class="quote-label">THE DISCRETION CLAUSE (verbatim)</div>
      <blockquote>{instrument.what_it_leaves_free_verbatim}</blockquote>
    </div>

    <p class="source-line">
      Source: <a href={instrument.source_url} target="_blank" rel="noreferrer">{instrument.source_url}</a>
    </p>

    <div class="reading-block">
      <div class="reading-label">THE COLLECTIVE&rsquo;S READING</div>
      <p>{instrument.reading}</p>
    </div>

    <div class="test-block">
      <div class="test-label">THE TEST THIS WORK APPLIES &mdash; the collective&rsquo;s own, not the standard&rsquo;s</div>
      <p>{instrument.the_test_applied}</p>
    </div>
  </header>

  {companies.map((company) => (
    <section class="company-block" data-company={company.name}>
      <div class="company-head">
        <h2>{company.name}</h2>
        <div class="year-basis-badge">{company.year_basis_display}</div>
      </div>
      <p class="company-source">Source: {company.source} &mdash; <a href={company.source_url} target="_blank" rel="noreferrer">{company.source_url}</a></p>

      {company.headline_quote && (
        <div class="quote-block quote-inline">
          <div class="quote-label">QUOTED IN THE REPORT &mdash; headline framing</div>
          <blockquote>{company.headline_quote.text}</blockquote>
          <p class="quote-attribution">{company.headline_quote.attribution}</p>
        </div>
      )}

      {company.goal_anchor_quote && (
        <div class="quote-block quote-inline">
          <div class="quote-label">QUOTED IN THE REPORT &mdash; the goal anchor</div>
          <blockquote>{company.goal_anchor_quote.text}</blockquote>
          <p class="quote-attribution">{company.goal_anchor_quote.attribution}</p>
          {company.goal_anchor_quote.note && (
            <p class="quote-note">{company.goal_anchor_quote.note}</p>
          )}
        </div>
      )}

      <div class="exhibit-box">
        <div class="exhibit-label">EXHIBIT</div>
        <p>{company.exhibit}</p>
      </div>

      <div class="year-controls" data-role="year-controls">
        <button type="button" class="yc-prev">&larr; prev year</button>
        <span class="yc-position">showing all {company.rows.length} years</span>
        <button type="button" class="yc-next">next year &rarr;</button>
        <button type="button" class="yc-all">show all years</button>
      </div>

      <div class="invoice-run">
        {company.rows.map((row, i) => (
          <div class="invoice-row" data-year={row.year} data-active="true" data-index={i}>
            <div class="invoice-pair">
              <div class="invoice invoice-market">
                <div class="invoice-band">METER A</div>
                <div class="invoice-label">{meters.market_based.label}</div>
                <div class="invoice-account">ACCOUNT: {company.name} &middot; PERIOD: {row.year}</div>
                <div class="invoice-subline">{meters.market_based.invoice_subline}</div>
                <div class="invoice-line invoice-amount-line">
                  <span class="line-label">AMOUNT</span>
                  <span class="line-fill"></span>
                  <span class="line-value">{fmt(row.market_based)} tCO2e</span>
                </div>
                <div class="invoice-yearbasis">{company.year_basis_display}</div>
              </div>

              <div class="invoice invoice-location">
                <div class="invoice-band">METER B</div>
                <div class="invoice-label">{meters.location_based.label}</div>
                <div class="invoice-account">ACCOUNT: {company.name} &middot; PERIOD: {row.year}</div>
                <div class="invoice-subline">{meters.location_based.invoice_subline}</div>
                <div class="invoice-line invoice-amount-line">
                  <span class="line-label">AMOUNT</span>
                  <span class="line-fill"></span>
                  <span class="line-value">{fmt(row.location_based)} tCO2e</span>
                </div>
                <div class="invoice-yearbasis">{company.year_basis_display}</div>
              </div>
            </div>

            <div class="reconciliation">
              <span class="recon-label">RECONCILIATION</span>
              <span class="recon-gap">GAP: {fmt(row.gap)} tCO2e</span>
              <span class="recon-ratio">RATIO (B &divide; A): {fmtRatio(row.ratio)}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="trend-block">
        <div class="trend-label">TREND, {company.trend_first_to_last.window_label}</div>
        <div class="trend-stats">
          <span>market-based: {fmtPct(company.trend_first_to_last.market_based_pct)}</span>
          <span>location-based: {fmtPct(company.trend_first_to_last.location_based_pct)}</span>
        </div>
        <p>{company.trend_first_to_last.sentence}</p>
        {company.trend_first_to_last.window_note && (
          <p class="window-note">{company.trend_first_to_last.window_note}</p>
        )}
      </div>
    </section>
  ))}

  <section class="finding-block">
    <div class="finding-label">FINDING</div>
    <ol class="finding-points">
      {finding.points.map((p) => (
        <li>{p}</li>
      ))}
    </ol>
    <div class="conjecture-box">
      <div class="conjecture-label">CONJECTURE FLAG</div>
      <p>{finding.conjecture_flag}</p>
    </div>
  </section>

  <section class="audit-strip">
    <div class="audit-label">AUDIT STRIP &mdash; check the arithmetic on the face of the work</div>
    <div class="audit-formulas">
      <div><span class="formula-name">gap</span> {d.derivation_formulas.gap}</div>
      <div><span class="formula-name">ratio</span> {d.derivation_formulas.ratio}</div>
      <div><span class="formula-name">trend</span> {d.derivation_formulas.trend}</div>
    </div>
    <div class="audit-examples">
      <div class="audit-examples-label">worked examples</div>
      <ul>
        {d.derivation_formulas.worked_examples.map((ex) => (
          <li>{ex}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="crosscheck-block">
    <div class="crosscheck-label">INDEPENDENT CROSS-CHECK</div>
    <p class="crosscheck-name">{crosscheck.name}</p>
    <p class="crosscheck-url"><a href={crosscheck.url} target="_blank" rel="noreferrer">{crosscheck.url}</a></p>
    <blockquote class="crosscheck-quote">{crosscheck.verbatim}</blockquote>
    <p class="crosscheck-recomp-label">its recomputation:</p>
    <blockquote class="crosscheck-quote">{crosscheck.recomputation_quote}</blockquote>
    <p class="crosscheck-divergences-label">divergences found (reported both ways):</p>
    <p>{crosscheck.divergences_found}</p>
  </section>

  <section class="caveats-block">
    <div class="caveats-label">CAVEATS</div>
    <ul>
      {d.caveats.map((c) => (
        <li>{c}</li>
      ))}
    </ul>
  </section>

  <footer class="footnote">
    {d.seed_note}
  </footer>
</section>

<script>
// @ts-nocheck — engine work script shielded from the site TS gate (sandboxed display code, vetted by the collective gauntlet + checkForbidden + astro build). A missing type annotation must never turn the whole site build red — see work 011, 2026-07-06.
  const root = document.querySelector(".two-meters");
  if (root) {
    root.classList.add("js");

    const companyBlocks = root.querySelectorAll(".company-block");
    companyBlocks.forEach((block) => {
      const rows = Array.from(block.querySelectorAll(".invoice-row"));
      const prevBtn = block.querySelector(".yc-prev");
      const nextBtn = block.querySelector(".yc-next");
      const allBtn = block.querySelector(".yc-all");
      const posEl = block.querySelector(".yc-position");
      if (!rows.length || !prevBtn || !nextBtn || !allBtn) return;

      let index = rows.length - 1;
      let mode = "all";

      function render() {
        if (mode === "all") {
          rows.forEach((r) => {
            r.setAttribute("data-active", "true");
          });
          if (posEl) posEl.textContent = "showing all " + rows.length + " years";
        } else {
          rows.forEach((r, i) => {
            r.setAttribute("data-active", i === index ? "true" : "false");
          });
          const activeYear = rows[index] ? rows[index].getAttribute("data-year") : "";
          if (posEl) {
            posEl.textContent = "year " + (index + 1) + " of " + rows.length + ": " + activeYear;
          }
        }
      }

      prevBtn.addEventListener("click", () => {
        mode = "single";
        index = (index - 1 + rows.length) % rows.length;
        render();
      });
      nextBtn.addEventListener("click", () => {
        mode = "single";
        index = (index + 1) % rows.length;
        render();
      });
      allBtn.addEventListener("click", () => {
        mode = "all";
        render();
      });

      render();
    });
  }
</script>

<style>
