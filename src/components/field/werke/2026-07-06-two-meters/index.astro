    --rule: #c9c0a4;
    --accent: #7a1f1f;
    font-family: Georgia, "Times New Roman", serif;
    font-variant-numeric: tabular-nums;
    color: var(--ink);
    background: var(--paper);
    max-width: 840px;
    margin: 0 auto;
    padding: 1.75rem 1.5rem 2.5rem;
    line-height: 1.55;
    font-size: 0.95rem;
