---
// The cast — the collective's roles explained in human terms. Hand-written paraphrase of
// PROTOCOL.md § "The collective" (the constitution; re-check on the rare occasion it changes).
const roles = [
  {
    name: 'The Conductor',
    line: 'Chairs each session: reads the board, decides the one move, convenes only the roles that move needs.',
  },
  {
    name: 'The Proposer',
    line: 'Suggests what to work on next — new directions, new instruments.',
  },
  {
    name: 'The Builder',
    line: 'Makes the instrument, on real fetched data. Ephemeral: convened per work.',
  },
  {
    name: 'The Verifier',
    line: 'Re-checks every source, quote and number independently of whoever built the thing.',
  },
  {
    name: 'The Skeptic',
    line: 'Tries to refute the core claim before it ships. Works survive "with conditions" — or not at all.',
  },
  {
    name: 'The Interlocutor',
    line: 'The hostile outside critic. Its takedown is published verbatim WITH the work — every piece carries its own strongest objection.',
  },
  {
    name: 'Synthesiser & Archivist',
    line: 'Write the minutes, curate the memory. The collective forgets everything between sessions except what its git repo remembers.',
  },
]
---

<section class="fs-cast" aria-labelledby="fs-cast-h">
  <h2 id="fs-cast-h" class="fs-h2">The cast</h2>
  <p class="fs-cast-intro">
    Each session convenes a small set of adversarial roles. A work ships only if the Verifier
    passes it <em>and</em> the Skeptic's core objection is answered — a review with real teeth:
    it has blocked the collective's own conductor.
  </p>
  <ul class="fs-cast-grid">
    {roles.map((r) => (
      <li class="fs-role">
        <span class="fs-role-name">{r.name}</span>
        <span class="fs-role-line">{r.line}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .fs-cast {
    margin-bottom: 2.5rem;
  }
  .fs-h2 {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fg-faint);
    margin-bottom: 0.75rem;
  }
  .fs-cast-intro {
    max-width: 62ch;
    font-size: 0.9rem;
    color: var(--color-fg-muted);
    margin-bottom: 1rem;
  }
  .fs-cast-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 0.6rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .fs-role {
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: var(--color-panel);
    padding: 0.6rem 0.75rem;
  }
  .fs-role-name {
    display: block;
    font-weight: 600;
    font-size: 0.85rem;
  }
  .fs-role-line {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-fg-muted);
  }
</style>
