---
// The field map — the seven clusters of the live field (transcribed from the engine's own
// FIELD.md) with the collective's works plotted onto them. Built territory vs. unbuilt
// territory at a glance; each built cluster is a filter chip for the works gallery below
// (same pattern as /atlas). Data: src/data/field/clusters.json (curated presentation).
import clustersData from '@/data/field/clusters.json'

const { clusters, axis } = clustersData as {
  axis: { left: string; right: string; note: string }
  clusters: {
    id: number
    name: string
    status: string
    blurb: string
    workSlugs: string[]
  }[]
}
---

<section class="fs-map" aria-labelledby="fs-map-h">
  <h2 id="fs-map-h" class="fs-h2">The field — seven clusters, where the collective has built</h2>
  <p class="fs-map-axis">
    <span>{axis.left}</span>
    <span class="fs-map-axis-line" aria-hidden="true"></span>
    <span>{axis.right}</span>
  </p>
  <p class="fs-map-note">{axis.note}</p>

  <ul class="fs-map-grid" id="fs-map-grid">
    {clusters.map((c) => {
      const built = c.workSlugs.length > 0
      return (
        <li>
          <button
            type="button"
            class:list={['fs-cluster', { 'fs-cluster-unbuilt': !built }]}
            data-cluster={c.id}
            disabled={!built}
            aria-pressed="false"
          >
            <span class="fs-cluster-head">
              <span class="fs-cluster-rank">C{c.id}</span>
              <span class="fs-cluster-status">{c.status}</span>
            </span>
            <span class="fs-cluster-name">{c.name}</span>
            <span class="fs-cluster-blurb">{c.blurb}</span>
            <span class="fs-cluster-count">
              {built ? `${c.workSlugs.length} work${c.workSlugs.length > 1 ? 's' : ''} — filter ↓` : 'unbuilt territory'}
            </span>
          </button>
        </li>
      )
    })}
  </ul>
  <p class="fs-map-atlas">
    The wider field: <a href="/atlas">214 mapped works by other artists &amp; investigators in the Atlas →</a>
  </p>
</section>

<script>
  // One active cluster at a time; clicking it again clears the filter. Filters the works
  // gallery rendered further down by EnginePage via each article's data-clusters attribute.
  const grid = document.getElementById('fs-map-grid')
  const chips = Array.from(grid?.querySelectorAll<HTMLButtonElement>('.fs-cluster[data-cluster]') ?? [])

  function apply(active: string | null) {
    chips.forEach((c) => c.setAttribute('aria-pressed', c.dataset.cluster === active ? 'true' : 'false'))
    document.querySelectorAll<HTMLElement>('[data-clusters]').forEach((el) => {
      el.hidden = active != null && !(el.dataset.clusters ?? '').split(' ').includes(active)
    })
  }

  grid?.addEventListener('click', (ev) => {
    const btn = (ev.target as Element).closest?.('.fs-cluster[data-cluster]') as HTMLButtonElement | null
    if (!btn || btn.disabled) return
    const isActive = btn.getAttribute('aria-pressed') === 'true'
    apply(isActive ? null : (btn.dataset.cluster ?? null))
  })
</script>

<style>
  .fs-map {
    margin-bottom: 2.5rem;
  }
  .fs-h2 {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fg-faint);
    margin-bottom: 0.75rem;
  }
  .fs-map-axis {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-fg-muted);
    max-width: 46rem;
  }
  .fs-map-axis-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--color-line), var(--fs-accent));
    min-width: 3rem;
  }
  .fs-map-note {
    margin-top: 0.35rem;
    font-size: 0.78rem;
    color: var(--color-fg-faint);
    max-width: 62ch;
  }
  .fs-map-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15.5rem, 1fr));
    gap: 0.6rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }
  .fs-cluster {
    display: block;
    width: 100%;
    height: 100%;
    text-align: left;
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: var(--color-panel);
    padding: 0.65rem 0.8rem;
    cursor: pointer;
    color: inherit;
    font: inherit;
    transition: border-color 0.15s ease;
  }
  .fs-cluster:hover:not(:disabled) {
    border-color: var(--fs-accent);
  }
  .fs-cluster[aria-pressed='true'] {
    border-color: var(--fs-accent);
    box-shadow: inset 0 0 0 1px var(--fs-accent);
  }
  .fs-cluster-unbuilt {
    border-style: dashed;
    background: transparent;
    cursor: default;
  }
  .fs-cluster-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }
  .fs-cluster-rank {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--fs-accent);
  }
  .fs-cluster-unbuilt .fs-cluster-rank {
    color: var(--color-fg-faint);
  }
  .fs-cluster-status {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-fg-faint);
  }
  .fs-cluster-name {
    display: block;
    margin-top: 0.25rem;
    font-weight: 600;
    font-size: 0.88rem;
  }
  .fs-cluster-blurb {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.75rem;
    line-height: 1.45;
    color: var(--color-fg-muted);
  }
  .fs-cluster-count {
    display: block;
    margin-top: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fs-accent);
  }
  .fs-cluster-unbuilt .fs-cluster-count {
    color: var(--color-fg-faint);
  }
  .fs-map-atlas {
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-fg-faint);
  }
  .fs-map-atlas a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .fs-map-atlas a:hover {
    color: var(--color-fg);
  }
</style>
