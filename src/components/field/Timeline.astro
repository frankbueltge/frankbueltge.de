---
// The project pulse — every research session as one glyph on a strip, chronological.
// Shape AND color encode the session's move (redundant coding, not color-only); a red ring
// marks sessions where the collective's own review issued a blocking FAIL. Clicking a glyph
// fills the shared detail pane below (no hover tooltips — works on touch); "Read the full
// entry" deep-links into the unedited journal further down the page (EnginePage opens the
// matching <details> via the hash). No animation by design — nothing to reduce for
// prefers-reduced-motion. Data: the merged chronicle (curated + engine self-reports).
import type { ChronicleEntry } from '@/lib/field/chronicle'

interface Props {
  entries: ChronicleEntry[]
}
const { entries } = Astro.props
const sorted = [...entries].sort((a, b) => a.seq - b.seq)
const latest = sorted[sorted.length - 1]

// day separators: index of first entry per date
const dayStarts = new Set<number>()
let prevDate = ''
sorted.forEach((e, i) => {
  if (e.date !== prevDate) {
    dayStarts.add(i)
    prevDate = e.date
  }
})

const GLYPHS: Record<string, string> = {
  // 18×18 viewBox shapes, fill = currentColor
  build: '<rect x="4" y="4" width="10" height="10" rx="1.5"/>',
  gauntlet: '<path d="M9 2.2 15.8 9 9 15.8 2.2 9Z"/>',
  ship: '<path d="M9 2.5 16 15.5H2Z"/>',
  verify: '<circle cx="9" cy="9" r="5.5"/>',
  consolidation: '<rect x="3" y="7" width="12" height="4" rx="1.5"/>',
  steer: '<path d="M4 2.5 13.5 9 4 15.5V2.5Z"/>',
  other: '<circle cx="9" cy="9" r="3.2"/>',
}
const MOVE_LABEL: Record<string, string> = {
  build: 'build',
  gauntlet: 'review',
  ship: 'ship',
  verify: 'verify',
  consolidation: 'housekeeping',
  steer: 'steering',
  other: 'other',
}
const sessionLabel = (e: ChronicleEntry) =>
  e.collective_session != null ? `Session ${e.collective_session}` : `Day-one session ${e.seq}`

// pane payload for the client script — data island, CSP-clean
const paneData = sorted.map((e) => ({
  seq: e.seq,
  date: e.date,
  label: sessionLabel(e),
  move: e.move,
  moveLabel: MOVE_LABEL[e.move] ?? e.move,
  verdict: e.verdict,
  fail: e.fail,
  summary: e.summary,
  works: e.works,
  anchor: e.anchor,
}))
---

<section class="fs-timeline" aria-labelledby="fs-tl-h">
  <h2 id="fs-tl-h" class="fs-h2">The story so far — every session, one mark</h2>

  <div class="fs-tl-scroll">
    <ol class="fs-tl-strip" id="fs-tl-strip">
      {sorted.map((e, i) => (
        <li class:list={['fs-tl-item', { 'fs-tl-daystart': dayStarts.has(i) && i !== 0 }]}>
          {dayStarts.has(i) && <span class="fs-tl-date" aria-hidden="true">{e.date.slice(5)}</span>}
          <button
            type="button"
            class:list={['fs-tl-btn', `fs-move-${e.move}`, { 'fs-fail': e.fail }]}
            data-seq={e.seq}
            aria-pressed={e.seq === latest.seq ? 'true' : 'false'}
            aria-label={`${sessionLabel(e)}, ${e.date}, ${MOVE_LABEL[e.move] ?? e.move}${e.fail ? ', review said no' : ''}`}
          >
            <svg viewBox="0 0 18 18" aria-hidden="true" set:html={GLYPHS[e.move] ?? GLYPHS.other} />
          </button>
        </li>
      ))}
    </ol>
  </div>

  <p class="fs-tl-legend" aria-hidden="true">
    {Object.entries(MOVE_LABEL).map(([move, label]) => (
      <span class={`fs-legend-item fs-move-${move}`}>
        <svg viewBox="0 0 18 18" set:html={GLYPHS[move]} />
        {label}
      </span>
    ))}
    <span class="fs-legend-item fs-legend-fail"><span class="fs-fail-ring"></span> review said no</span>
  </p>

  {/* shared detail pane — server-rendered with the latest entry so it works without JS */}
  <div class="fs-pane" id="fs-pane" aria-live="polite">
    <p class="fs-pane-head">
      <strong id="fs-pane-label">{sessionLabel(latest)}</strong>
      <span id="fs-pane-date" class="fs-pane-date">{latest.date}</span>
      <span id="fs-pane-move" class={`fs-pane-badge fs-move-${latest.move}`}>{MOVE_LABEL[latest.move] ?? latest.move}</span>
      <span id="fs-pane-verdict" class:list={['fs-pane-badge', 'fs-pane-verdict', { 'fs-pane-verdict-fail': latest.fail, hidden: !latest.verdict }]}>
        {latest.verdict ?? ''}
      </span>
    </p>
    <p class="fs-pane-summary" id="fs-pane-summary">{latest.summary}</p>
    <p class="fs-pane-links">
      <span id="fs-pane-works">
        {latest.works.map((w) => (
          <a class="fs-pane-work" href={`/field/werke/${w}`}>{w.replace(/^\d{4}-\d{2}-\d{2}-/, '')}</a>
        ))}
      </span>
      <a id="fs-pane-journal" class="fs-pane-journallink" href={`#${latest.anchor}`}>Read the full journal entry →</a>
    </p>
  </div>

  <script type="application/json" id="fs-tl-data" set:html={JSON.stringify(paneData)} />
</section>

<script>
  const dataEl = document.getElementById('fs-tl-data')
  const strip = document.getElementById('fs-tl-strip')
  const entries: any[] = dataEl ? JSON.parse(dataEl.textContent ?? '[]') : []
  const bySeq = new Map(entries.map((e) => [String(e.seq), e]))

  const el = (id: string) => document.getElementById(id)

  function show(seq: string) {
    const e = bySeq.get(seq)
    if (!e) return
    const label = el('fs-pane-label')
    const date = el('fs-pane-date')
    const move = el('fs-pane-move')
    const verdict = el('fs-pane-verdict')
    const summary = el('fs-pane-summary')
    const worksEl = el('fs-pane-works')
    const journal = el('fs-pane-journal') as HTMLAnchorElement | null
    if (label) label.textContent = e.label
    if (date) date.textContent = e.date
    if (move) {
      move.textContent = e.moveLabel
      move.className = `fs-pane-badge fs-move-${e.move}`
    }
    if (verdict) {
      verdict.textContent = e.verdict ?? ''
      verdict.classList.toggle('hidden', !e.verdict)
      verdict.classList.toggle('fs-pane-verdict-fail', !!e.fail)
    }
    if (summary) summary.textContent = e.summary
    if (worksEl) {
      worksEl.replaceChildren(
        ...e.works.map((w: string) => {
          const a = document.createElement('a')
          a.className = 'fs-pane-work'
          a.href = `/field/werke/${w}`
          a.textContent = w.replace(/^\d{4}-\d{2}-\d{2}-/, '')
          return a
        }),
      )
    }
    if (journal) journal.href = `#${e.anchor}`
    strip?.querySelectorAll('.fs-tl-btn').forEach((b) => {
      b.setAttribute('aria-pressed', (b as HTMLElement).dataset.seq === seq ? 'true' : 'false')
    })
  }

  strip?.addEventListener('click', (ev) => {
    const btn = (ev.target as Element).closest?.('.fs-tl-btn') as HTMLElement | null
    if (btn?.dataset.seq) show(btn.dataset.seq)
  })

  // Arrow-key navigation along the strip.
  strip?.addEventListener('keydown', (ev) => {
    if (ev.key !== 'ArrowLeft' && ev.key !== 'ArrowRight') return
    const buttons = Array.from(strip.querySelectorAll<HTMLElement>('.fs-tl-btn'))
    const idx = buttons.indexOf(document.activeElement as HTMLElement)
    if (idx === -1) return
    const next = buttons[idx + (ev.key === 'ArrowRight' ? 1 : -1)]
    if (next) {
      next.focus()
      if (next.dataset.seq) show(next.dataset.seq)
      ev.preventDefault()
    }
  })

  // Start the strip scrolled to the newest entry (it is the preselected one).
  const scroller = document.querySelector('.fs-tl-scroll')
  if (scroller) scroller.scrollLeft = scroller.scrollWidth
</script>

<style>
  .fs-timeline {
    margin-bottom: 2.5rem;
  }
  .fs-h2 {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fg-faint);
    margin-bottom: 0.75rem;
  }

  .fs-tl-scroll {
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }
  .fs-tl-strip {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    margin: 0;
    padding: 1.4rem 0 0.2rem;
    list-style: none;
    min-width: max-content;
  }
  .fs-tl-item {
    position: relative;
  }
  .fs-tl-daystart {
    margin-left: 14px;
  }
  .fs-tl-daystart::before {
    content: '';
    position: absolute;
    left: -8px;
    top: -0.2rem;
    bottom: 0;
    border-left: 1px dashed var(--color-line);
  }
  .fs-tl-date {
    position: absolute;
    top: -1.15rem;
    left: 0;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    color: var(--color-fg-faint);
    white-space: nowrap;
  }
  .fs-tl-btn {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    color: var(--fs-move, var(--color-fg-faint));
    cursor: pointer;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .fs-tl-btn svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
  .fs-tl-btn:hover {
    border-color: var(--color-line);
    background: var(--color-panel);
  }
  .fs-tl-btn[aria-pressed='true'] {
    border-color: currentColor;
    background: var(--color-panel);
  }
  .fs-tl-btn.fs-fail {
    box-shadow: inset 0 0 0 2px var(--fs-fail);
    border-radius: 8px;
  }

  /* move → color (tokens defined on [data-field-story] in FieldPage; remapped for light theme) */
  .fs-move-build { --fs-move: var(--fs-build); }
  .fs-move-gauntlet { --fs-move: var(--fs-gauntlet); }
  .fs-move-ship { --fs-move: var(--fs-ship); }
  .fs-move-verify { --fs-move: var(--fs-verify); }
  .fs-move-consolidation { --fs-move: var(--fs-consolidation); }
  .fs-move-steer { --fs-move: var(--fs-steer); }
  .fs-move-other { --fs-move: var(--fs-consolidation); }

  .fs-tl-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1rem;
    margin: 0.5rem 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-fg-faint);
  }
  .fs-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-fg-faint);
  }
  .fs-legend-item svg {
    width: 11px;
    height: 11px;
    fill: var(--fs-move, currentColor);
  }
  .fs-fail-ring {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 3px;
    box-shadow: inset 0 0 0 2px var(--fs-fail);
  }

  .fs-pane {
    border: 1px solid var(--color-line);
    border-radius: 12px;
    background: var(--color-panel);
    padding: 1rem 1.15rem;
    max-width: 46rem;
  }
  .fs-pane-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.9rem;
  }
  .fs-pane-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-fg-faint);
  }
  .fs-pane-badge {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid currentColor;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    color: var(--fs-move, var(--color-fg-muted));
  }
  .fs-pane-verdict {
    color: var(--color-fg-muted);
  }
  .fs-pane-verdict-fail {
    color: var(--fs-fail);
  }
  .fs-pane-verdict.hidden {
    display: none;
  }
  .fs-pane-summary {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-fg);
    text-wrap: pretty;
  }
  .fs-pane-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.7rem;
  }
  .fs-pane-work {
    display: inline-block;
    margin-right: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    border: 1px solid var(--color-line);
    border-radius: 5px;
    padding: 0.12rem 0.45rem;
    text-decoration: none;
    color: var(--color-fg-muted);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .fs-pane-work:hover {
    color: var(--color-fg);
    border-color: var(--color-fg-faint);
  }
  .fs-pane-journallink {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fs-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
