---
import { getRelativeLocaleUrl } from 'astro:i18n'
import type { Locale } from '@/lib/site'

interface Props { locale: Locale }
const { locale } = Astro.props
const de = locale === 'de'
const workUrl = getRelativeLocaleUrl(locale, '/beifang')
const kommgesUrl = 'https://journals.sub.uni-hamburg.de/hup2/kommges/article/view/1643'
const easyprivacyLicenceUrl = 'https://easylist.to/pages/licence.html'
const ddgTdsUrl = 'https://github.com/duckduckgo/tracker-blocklists'
const infraListUrl = 'https://github.com/frankbueltge/frankbueltge.de/blob/main/src/data/beifang/wissenschaft-infra.json'

const txt = {
  h1: de ? 'Methodenblatt — Der Beifang' : 'Method sheet — The Bycatch',
  s1: de ? '1. Was das ist' : '1. What this is',
  s1body: de
    ? 'Zweites Instrument der Linie „Gegenmessung" (nach The Consensus). Es überprüft empirisch den Befund von Fadeeva, Blume, Matuszkiewicz und Wrzesinski (kommges 2024): wie viel Drittanbieter-Tracking eine wissenschaftliche Artikelseite lädt — bevor überhaupt einer Einwilligung zugestimmt wurde.'
    : 'Second instrument in the „Counter-Measurement" line (after The Consensus). It empirically checks the finding of Fadeeva, Blume, Matuszkiewicz and Wrzesinski (kommges 2024): how much third-party tracking a scholarly article page loads — before any consent is given at all.',
  s2: de ? '2. Quellen & Lizenzen' : '2. Sources & licences',
  s2body: de
    ? 'Panel: 60 Artikelseiten — die fünf größten Wissenschaftsverlage (Elsevier, Springer Nature, Wiley, Taylor & Francis, SAGE) mit je 10 Artikeln via Crossref, gegen 10 Diamond-OA-Journals als Kontrollgruppe, darunter der Anlass-Artikel selbst. Auswahlkriterium, wörtlich aus dem committeten Panel: „Verlagsgruppe: je Verlag die 10 jüngsten Artikel des OA-Flaggschiff-Journals (Crossref, type journal-article) zum Aufnahmezeitpunkt. Kontrollgruppe: je Diamond-OA-Journal der jüngste Artikel; kommges fest: der Anlass-Artikel (Fadeeva et al. 2024)." Zwei Kontroll-Tausche sind im committeten panel.json protokolliert (log): jdsr statt weizenbaum-journal, jtei statt zfdg — beide Ersatz-Journals sind DataCite- statt Crossref-registriert und damit für die Crossref-basierte Panel-Methodik unsichtbar. Tracker-Listen: EasyPrivacy (GPLv3/CC BY-SA 3.0 dual lizenziert) und die DuckDuckGo-Tracker-Blockliste (TDS). Listen-Stände (Abrufdatum, SHA-256) werden je Sitzung im Archiv mitgeführt.'
    : 'Panel: 60 article pages — the five largest scholarly publishers (Elsevier, Springer Nature, Wiley, Taylor & Francis, SAGE) with 10 articles each via Crossref, against 10 diamond-OA journals as a control group, including the very article that prompted this instrument. Selection criterion, quoted verbatim from the committed panel: "Publisher group: for each publisher, the 10 most recent articles of the OA flagship journal (Crossref, type journal-article) at intake time. Control group: for each diamond-OA journal, its most recent article; kommges fixed: the prompting article (Fadeeva et al. 2024)." Two control-journal swaps are logged in the committed panel.json (log): jdsr in place of weizenbaum-journal, jtei in place of zfdg — both replacement journals are DataCite- rather than Crossref-registered and therefore invisible to the Crossref-based panel methodology. Tracker lists: EasyPrivacy (dual-licensed GPLv3/CC BY-SA 3.0) and the DuckDuckGo tracker blocklist (TDS). List states (retrieval date, SHA-256) travel with the archive per session.',
  s3: de ? '3. Takt' : '3. Cadence',
  s3body: de
    ? 'Wöchentlich, montags 02:17 UTC, per GitHub Actions. Jeder Lauf schreibt genau einen Commit ins Archiv (src/content/beifang/‹jahr›/‹datum›.json), committet unter der Workflow-Identität „Gegenmessung". Archiv-JSONs sind unantastbar — nie editiert, nur die Darstellung wird korrigiert — und es gibt keinen Backfill vergangener Sitzungen.'
    : 'Weekly, Mondays 02:17 UTC, via GitHub Actions. Each run writes exactly one commit to the archive (src/content/beifang/‹year›/‹date›.json), committed under the workflow identity „Gegenmessung" ("counter-measurement"). Archive JSONs are untouchable — never edited, only the display is corrected — and there is no backfill of past sessions.',
  s4: de ? '4. Verarbeitung' : '4. Processing',
  s4body: de
    ? 'Headless-Chromium über Playwright, Standard-Browserprofil, keine Interaktion (kein Consent-Klick, kein Scroll), festes Nachlade-Fenster — gemessen wird der Pre-Consent-Zustand. Die Klassifikation läuft zweistufig: Tracker-Erkennung eng ist die Vereinigung aus EasyPrivacy und den Keys der TDS-„trackers"-Sektion; Firmen-Zuordnung breit ist die Domain-zu-Firma-Zuordnung aus den TDS-Sektionen „domains"/„entities", ergänzt um die Owner-Angaben aus „trackers". Kein Match in beiden Stufen ⇒ unklassifiziert, nie geraten. Erfasste Kennzahlen je Seite: Drittanbieter-Hosts, -Requests, -Bytes, erkannte Tracker-Hosts, zugeordnete Firmen, Cookies (First-/Third-Party). Ergänzend zur TDS-Zuordnung führt die Darstellung eine kuratierte, quellenbelegte Liste für Wissenschafts-Infrastruktur, die der Ad-Tech-fokussierte Tracker-Radar nicht als Firma kennt (z. B. ReadCube, Altmetric, Dimensions — allesamt Digital Science / Holtzbrinck; self-hosted Matomo/Umami der Herausgeber). Auflösungsreihenfolge: erst die TDS-Zuordnung des Laufs, dann die kuratierte Liste; jeder Eintrag trägt eine Beleg-URL. Diese Benennung ist reine Darstellung — die Archiv-JSONs bleiben unverändert.'
    : 'Headless Chromium via Playwright, default browser profile, no interaction (no consent click, no scroll), a fixed reload window — the pre-consent state is what gets measured. Classification runs in two tiers: narrow tracker detection is the union of EasyPrivacy and the keys of the TDS "trackers" section; broad company attribution is the domain-to-company mapping from the TDS "domains"/"entities" sections, augmented with the owner data from "trackers". No match at either tier ⇒ unclassified, never guessed. Metrics captured per page: third-party hosts, requests, bytes, detected tracker hosts, attributed companies, cookies (first-/third-party). In addition to the TDS attribution, the display uses a curated, source-backed list for scholarly infrastructure that the ad-tech-focused tracker radar does not know as a company (e.g. ReadCube, Altmetric, Dimensions — all Digital Science / Holtzbrinck; self-hosted Matomo/Umami run by the publishers). Resolution order: first the run\'s TDS attribution, then the curated list; every entry carries a source URL. This naming is display only — the archive JSONs stay unchanged.',
  s4leakLabel: de ? 'Leak-Nachweis (pre-consent):' : 'DOI leak evidence (pre-consent):',
  s4leak: de
    ? 'Für jede erreichbare Seite wird geprüft, ob die DOI (Kennung des Artikels) den ausgehenden Drittanbieter-Requests beiliegt — im Klartext, URL-kodiert oder als md5/sha1/sha256. Ein Hash-Treffer der DOI ist fälschungssicher. Titel/Schlagwörter gelten als schwächeres Signal (ganzer Phrasenabgleich, keine Einzelwörter). Gemessen wird vor jeder Cookie-Einwilligung (keine Interaktion mit der Seite); ob daraus ein Rechtsverstoß folgt, ist eine juristische Frage, die dieses Instrument nicht beurteilt — es dokumentiert nur den jeweiligen Request als Beweis. Der Nachweis läuft auf beiden Gruppen (Verlage und Kontrolle) und aus beiden Standpunkten. Aus Automatensicht (2026-07-03) fiel die DOI vor allem bei den erreichbaren gebührenfreien Journals auf (Altmetric, Dimensions, Google Analytics). Aus Lesersicht (echtes Chrome, Wohnanschluss, 2026-07-05) zeigt sich das eigentliche Bild: Auch die vier großen Verlage — die den Automaten aussperren — geben die DOI beim echten Aufruf breit an Metrik-Dienste und Werbe-Tracker weiter (Taylor & Francis, Wiley, Springer Nature, Elsevier). Die Beobachtung folgt dem eingebundenen Skript, nicht dem Geschäftsmodell; die meisten Diamond-OA-Journals bleiben sauber, einzelne nicht. Die DOI reist dabei im Query-String bzw. URL-Pfad aktiver Requests, nicht über den Referer; vor der Einwilligung werden kaum Third-Party-Cookies gesetzt — der Transfer läuft über den Request. Dokumentiert ist der Zustand dieser Abrufe, kein verallgemeinerbares Urteil über einen Anbieter.'
    : 'For every reachable page, the outgoing third-party requests are checked for whether the DOI (the article\'s identifier) rides along — in plain text, URL-encoded, or as an md5/sha1/sha256 hash. A DOI hash match is tamper-proof. Title/keywords count as a weaker signal (whole-phrase match only, never single words). Measurement happens before any cookie consent (no interaction with the page); whether that constitutes a legal violation is a legal question this instrument does not judge — it only documents each request as evidence. The check runs on both groups (publishers and control) and from both vantages. From the automaton\'s view (2026-07-03) the DOI stood out mainly at the reachable fee-free journals (Altmetric, Dimensions, Google Analytics). From the reader\'s view (real Chrome, residential line, 2026-07-05) the real picture emerges: the four big publishers too — the ones that lock out the automaton — hand the DOI broadly to metrics services and ad trackers on an actual visit (Taylor & Francis, Wiley, Springer Nature, Elsevier). The observation follows the embedded script, not the business model; most diamond-OA journals stay clean, some do not. The DOI travels in the query string or URL path of active requests, not via the referer; before consent almost no third-party cookies are set — the transfer goes through the request. What is documented is the state of these retrievals, not a generalisable verdict about any provider.',
  s5: de ? '5. Grenzen der Methode' : '5. Limits of the method',
  s5items: de
    ? [
        'Zwei Standpunkte: der Automat (headless-Chromium, GitHub Actions, wöchentlich) misst den automatisierten Prüfblick; der Leser (echtes Google Chrome, lokal auf Zuruf via `npm run beifang:leser`) misst, was ein realer Leser ausgeliefert bekommt. Die Differenz beider ist der Befund — und reproduzierbar: jeder kann den Leser-Lauf mit denselben Panel-URLs nachstellen.',
        'Machbarkeit (empirisch belegt): Die Blockade ist eine UND-Bedingung aus IP-Reputation und Browser-Fingerprint — nur ein Wohnanschluss UND echtes Chrome kommen durch. Ein Datacenter-VPS ändert nichts (dieselbe Sperre wie GitHub Actions); Geografie ist nicht der Hebel. Ein residentieller Standpunkt genügt: der eigene Rechner.',
        'Echter Browser ist kein Umgehen: der Leser-Standpunkt nutzt normales Chrome ohne Stealth-Tricks (navigator.webdriver bleibt sichtbar) — kein Hebeln von Schutz, sondern schlicht, was ein Mensch sieht. SAGE bleibt auch für den echten Leser gesperrt und wird nie umgangen — die Blockade ist selbst ein Befund.',
        'Misst die öffentliche Artikelseite, nicht den institutionellen Zugriff (Uni-Netz, SeamlessAccess) — das Instrument liefert die Untergrenze.',
        'Ein festes Panel misst diese 60 Seiten, nicht „den Verlag" als Ganzes.',
        'Der Listen-Abgleich erkennt nur Bekanntes — kein Fingerprinting-Nachweis in v1.',
      ]
    : [
        'Two vantages: the automaton (headless Chromium, GitHub Actions, weekly) measures the automated audit view; the reader (real Google Chrome, run locally on demand via `npm run beifang:leser`) measures what a real reader is served. The difference between the two is the finding — and reproducible: anyone can repeat the reader run with the same panel URLs.',
        'Feasibility (empirically established): the block is an AND condition of IP reputation and browser fingerprint — only a residential line AND real Chrome get through. A datacenter VPS changes nothing (the same block as GitHub Actions); geography is not the lever. A residential vantage suffices: your own machine.',
        'A real browser is not circumvention: the reader vantage uses ordinary Chrome without stealth tricks (navigator.webdriver stays visible) — not a way around protection, simply what a human sees. SAGE stays blocked even for the real reader and is never circumvented — the block is itself a finding.',
        'Measures the public article page, not institutional access (university network, SeamlessAccess) — the instrument gives the lower bound.',
        'A fixed panel measures these 60 pages, not „the publisher" as a whole.',
        'List matching detects only the known — no fingerprinting evidence in v1.',
      ],
  s6: de ? '6. Compute-Fußabdruck' : '6. Compute footprint',
  s6body: de
    ? 'Rund 60 Seitenaufrufe pro Woche, ein GitHub-Actions-Job von wenigen Minuten Laufzeit. Die genaue Zahl wird nach dem ersten Lauf beziffert.'
    : 'About 60 page loads per week, one GitHub Actions job running a few minutes. The exact figure will be quantified after the first run.',
  s7: de ? '7. Änderungsprotokoll' : '7. Change log',
  s7items: de
    ? [
        'Startfassung (2026-07-02) — Panel: Big 5 × 10 vs. 10 Diamond-OA-Kontrolle, EasyPrivacy + DuckDuckGo-TDS, US-Blickwinkel.',
        '2026-07-02: Leak-Audit ergänzt (Identitäts-Exfiltration statt reinem Tracker-Zensus).',
        '2026-07-03: Kontrollgruppen-Leaks sichtbar; These präzisiert (der Leak folgt dem Skript, nicht dem Geschäftsmodell).',
        '2026-07-04: Empfänger-Benennung — kuratierte Wissenschafts-Infrastruktur-Liste (quellenbelegt): ReadCube/Altmetric/Dimensions als Digital Science benannt; Kanal (Query-String/URL-Pfad) und Pre-Consent-Cookie-Befund ergänzt.',
        '2026-07-05: Zweiter Standpunkt „Leser" (echtes Chrome, lokal) neben dem Automat; die Differenz wird der Befund. Machbarkeit belegt (Blockade = residentielle IP + echtes Chrome); EU-/Datacenter-Vantage verworfen.',
      ]
    : [
        'First edition (2026-07-02) — panel: Big 5 × 10 vs. 10 diamond-OA control, EasyPrivacy + DuckDuckGo TDS, US vantage.',
        '2026-07-02: leak audit added (identity exfiltration instead of a pure tracker census).',
        '2026-07-03: control-group leaks made visible; thesis sharpened (the leak follows the script, not the business model).',
        '2026-07-04: recipient naming — curated, source-backed scholarly-infrastructure list: ReadCube/Altmetric/Dimensions named as Digital Science; channel (query string/URL path) and pre-consent cookie finding added.',
        '2026-07-05: second vantage „reader" (real Chrome, local) alongside the automaton; the difference becomes the finding. Feasibility established (block = residential IP + real Chrome); EU/datacenter vantage discarded.',
      ],
  s7note: de
    ? 'Weitere Panel- bzw. Listenänderungen erscheinen hier — protokolliert im committeten panel.json (log).'
    : 'Further panel or list changes appear here — logged in the committed panel.json (log).',
  toWork: de ? 'Zum Experiment' : 'To the experiment',
}
---

<div class="mx-auto max-w-2xl px-4 py-14">
  <h1 class="mb-8 text-xl font-semibold">{txt.h1}</h1>

  <section class="mb-10 border border-line bg-panel/60 p-5">
    <h2 class="mb-2 font-semibold">{txt.s1}</h2>
    <p class="leading-relaxed">{txt.s1body}</p>
    <p class="mt-2">
      <a href={kommgesUrl} class="font-mono text-xs text-fg-faint transition-colors hover:text-fg" rel="noopener">{kommgesUrl}</a>
    </p>
  </section>

  <section class="mb-8">
    <h2 class="mb-2 font-semibold">{txt.s2}</h2>
    <p class="leading-relaxed text-fg-muted">{txt.s2body}</p>
    <p class="mt-2 space-x-3">
      <a href={easyprivacyLicenceUrl} class="font-mono text-xs text-fg-faint transition-colors hover:text-fg" rel="noopener">→ EasyPrivacy licence</a>
      <a href={ddgTdsUrl} class="font-mono text-xs text-fg-faint transition-colors hover:text-fg" rel="noopener">→ DuckDuckGo TDS</a>
    </p>
  </section>

  <section class="mb-8"><h2 class="mb-2 font-semibold">{txt.s3}</h2><p class="leading-relaxed text-fg-muted">{txt.s3body}</p></section>

  <section class="mb-8">
    <h2 class="mb-2 font-semibold">{txt.s4}</h2>
    <p class="leading-relaxed text-fg-muted">{txt.s4body}</p>
    <p class="mt-2 leading-relaxed text-fg-muted"><span class="font-semibold text-fg">{txt.s4leakLabel}</span> {txt.s4leak}</p>
    <p class="mt-2 space-x-3">
      <a href="https://github.com/frankbueltge/frankbueltge.de/tree/main/pipelines/beifang"
        class="font-mono text-xs text-fg-faint transition-colors hover:text-fg" rel="noopener">→ pipelines/beifang</a>
      <a href={infraListUrl}
        class="font-mono text-xs text-fg-faint transition-colors hover:text-fg" rel="noopener">→ {de ? 'kuratierte Firmenliste' : 'curated company list'}</a>
    </p>
  </section>

  <section class="mb-8">
    <h2 class="mb-2 font-semibold">{txt.s5}</h2>
    <ul class="list-disc space-y-1 pl-5 text-fg-muted">{txt.s5items.map((i) => <li>{i}</li>)}</ul>
  </section>

  <section class="mb-8"><h2 class="mb-2 font-semibold">{txt.s6}</h2><p class="leading-relaxed text-fg-muted">{txt.s6body}</p></section>

  <section class="mb-8">
    <h2 class="mb-2 font-semibold">{txt.s7}</h2>
    <ul class="list-disc space-y-1 pl-5 text-fg-muted">{txt.s7items.map((i) => <li>{i}</li>)}</ul>
    <p class="mt-2 text-sm text-fg-muted">{txt.s7note}</p>
  </section>

  <a href={workUrl} class="text-sm text-fg-muted transition-colors hover:text-fg">→ {txt.toWork}</a>
</div>
