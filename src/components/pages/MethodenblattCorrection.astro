---
import { getRelativeLocaleUrl } from 'astro:i18n'
import type { Locale } from '@/lib/site'
import type { RevisionData } from '@/lib/revision/types'
import data from '@/data/revision/latest.json'

interface Props { locale: Locale }
const { locale } = Astro.props
const de = locale === 'de'
const d = data as unknown as RevisionData
const workUrl = getRelativeLocaleUrl(locale, '/correction')

const txt = {
  h1: de ? 'Methodenblatt — The Correction' : 'Method sheet — The Correction',
  revealHead: de ? 'Worum es geht' : 'What this is',
  reveal: de
    ? 'Es gibt nicht „die Zahl". Die Beschäftigung, auf die Märkte und Politik in Echtzeit reagieren, ist vorläufig — und wurde zuletzt millionenweise nach unten korrigiert. Kein eigenes Modell, keine Spekulation: Gegenmessung zeigt nur die Lücke zwischen dem, was verkündet wurde, und dem, was die Quelle selbst später daraus machte.'
    : 'There is no "the number". The employment figure markets and politics react to in real time is provisional — and was lately revised down by the million. No model, no speculation: counter-measurement only shows the gap between what was announced and what the source itself later made of it.',
  s1: de ? '1. Quellen & Lizenzen' : '1. Sources & licences',
  s1body: de
    ? `${d.source.name} (${d.source.license}). Die Vintage-Datenbank speichert jede „Ausgabe" einer Zahl — so liefert sie die „as-of-then"-Fassung gleich mit.`
    : `${d.source.name} (${d.source.license}). The vintage database stores every "issue" of a number — so it ships the "as-of-then" version with it.`,
  s2: de ? '2. Kadenz' : '2. Cadence',
  s2body: de
    ? 'Monatlich neue Meldung, jährlich „Benchmark"-Revision gegen Steuerdaten. Der Build holt die jeweils jüngsten Vintages. Kanonisches Artefakt: versionierte JSON in src/data/revision/ — Git ist das Archiv.'
    : 'A new monthly report, an annual "benchmark" revision against tax records. The build pulls the latest vintages each time. Canonical artefact: versioned JSON in src/data/revision/ — git is the archive.',
  s3: de ? '3. Verarbeitung' : '3. Processing',
  s3body: de
    ? 'Deterministisch, kein Nowcast: Erst-Meldung = früheste Ausgabe mit Wert; Korrektur = jüngste Ausgabe. Revision = Korrektur − Erst-Meldung. „Systematisch" = Anteil der letzten Monate, die nach unten gingen. Die Schlagzeile ist die stärkste Revision seit 2024. XLSX-Quelle, geparst mit pandas/openpyxl.'
    : 'Deterministic, no nowcast: first report = earliest issue with a value; correction = latest issue. Revision = correction − first report. "Systematic" = share of recent months revised downward. The headline is the largest revision since 2024. XLSX source, parsed with pandas/openpyxl.',
  s4: de ? '4. Grenzen der Methode' : '4. Limits of the method',
  s4items: de
    ? [
        'US-Nonfarm-Payroll, nicht die Welt; ein Niveau (Beschäftigtenzahl), keine saisonbereinigte Feinheit.',
        '„Erst-Meldung" = früheste RTDSM-Ausgabe (≈ erste/zweite Veröffentlichung), nicht zwingend exakt die Schlagzeile am Tag X.',
        'Die großen Abwärts-Revisionen sind die jährliche Benchmark gegen Steuerdaten (QCEW) — kein „Fehler" im engen Sinn, aber die Echtzeit-Zahl ist eben vorläufig und lag zuletzt systematisch zu hoch.',
        'FRED/BLS blocken Datacenter-IPs; darum die Philadelphia-Fed-RTDSM als gleichwertige, frei zugängliche Vintage-Quelle.',
      ]
    : [
        'US nonfarm payroll, not the world; a level (headcount), not seasonal-adjustment nuance.',
        '"First report" = earliest RTDSM issue (≈ first/second release), not necessarily the exact day-X headline.',
        'The large downward revisions are the annual benchmark against tax records (QCEW) — not "error" in a narrow sense, but the real-time number is provisional and lately ran systematically high.',
        'FRED/BLS block datacenter IPs; hence the Philadelphia Fed RTDSM as an equivalent, freely accessible vintage source.',
      ],
  s5: de ? '5. Compute-Fußabdruck' : '5. Compute footprint',
  s5body: de
    ? 'Ein XLSX-Download pro Build (~2 MB), kein API-Key, kein LLM. Benötigt pandas/openpyxl. Die Site ist statisch.'
    : 'One XLSX download per build (~2 MB), no API key, no LLM. Requires pandas/openpyxl. The site is static.',
  s6: de ? '6. Änderungsprotokoll' : '6. Change log',
  s6items: de
    ? [
        'v2 (2026-06) — auf Beschäftigungs-Revisionen (Philadelphia Fed RTDSM) umgestellt; wuchtigere, marktrelevante Lücke.',
        'v1 — Grippe-Revisionen (CDC/Delphi): systematische Aufwärts-Korrektur.',
      ]
    : [
        'v2 (2026-06) — switched to employment revisions (Philadelphia Fed RTDSM); a heavier, market-relevant gap.',
        'v1 — flu revisions (CDC/Delphi): systematic upward correction.',
      ],
  toWork: de ? 'Zum Experiment' : 'To the experiment',
}
---

<div class="mx-auto max-w-2xl px-4 py-14">
  <h1 class="mb-8 text-xl font-semibold">{txt.h1}</h1>

  <section class="mb-10 border border-line bg-panel/60 p-5">
    <h2 class="mb-2 font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">{txt.revealHead}</h2>
    <p class="leading-relaxed">{txt.reveal}</p>
  </section>

  <section class="mb-8"><h2 class="mb-2 font-semibold">{txt.s1}</h2><p class="leading-relaxed text-fg-muted">{txt.s1body}</p>
    <p class="mt-2"><a href={d.source.url} class="font-mono text-xs text-fg-faint transition-colors hover:text-fg" rel="noopener">{d.source.url}</a></p>
  </section>

  <section class="mb-8"><h2 class="mb-2 font-semibold">{txt.s2}</h2><p class="leading-relaxed text-fg-muted">{txt.s2body}</p></section>

  <section class="mb-8">
    <h2 class="mb-2 font-semibold">{txt.s3}</h2>
    <p class="leading-relaxed text-fg-muted">{txt.s3body}</p>
    <p class="mt-2"><a href="https://github.com/frankbueltge/frankbueltge.de/tree/main/pipelines/revision"
      class="font-mono text-xs text-fg-faint transition-colors hover:text-fg" rel="noopener">→ pipelines/revision</a></p>
  </section>

  <section class="mb-8">
    <h2 class="mb-2 font-semibold">{txt.s4}</h2>
    <ul class="list-disc space-y-1 pl-5 text-fg-muted">{txt.s4items.map((i) => <li>{i}</li>)}</ul>
  </section>

  <section class="mb-8"><h2 class="mb-2 font-semibold">{txt.s5}</h2><p class="leading-relaxed text-fg-muted">{txt.s5body}</p></section>

  <section class="mb-8">
    <h2 class="mb-2 font-semibold">{txt.s6}</h2>
    <ul class="list-disc space-y-1 pl-5 text-fg-muted">{txt.s6items.map((i) => <li>{i}</li>)}</ul>
  </section>

  <a href={workUrl} class="text-sm text-fg-muted transition-colors hover:text-fg">→ {txt.toWork}</a>
</div>
