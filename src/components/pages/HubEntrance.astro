---
// The hub — site-v2 work order §3 (decisions doc 2026-07-16 §1.3: "Hero → aktuelle Begegnung
// (prominent) → vier Türen → 'where works travel' → 'also on this site'"). Replaces the prior
// entrance (the full score/Partitur experience, src/components/pages/BegegnungEntrance.astro),
// which now lives at its own stable URL, /begegnungen (decision doc §1.3, work order §3.2).
//
// All narrative copy (title, hero sub, conductor line, door/travel/rest descriptions) comes
// from src/config/naming.ts — ONE dictionary, approval: 'draft' until Frank signs off (see
// docs/decision-log.md). Wordings are taken verbatim from the design session's own mockup
// (research-ecology docs/design/variants-2026-07-16-hub/hub-a.html).
//
// Two pieces of data are deterministic, build-time-only derivations — no clock, no network:
//   · the pulse: committed snapshot src/data/pulse/pulse.json (scripts/fetch-pulse.ts), rendered
//     by src/lib/pulse/render.ts.
//   · each door's "last recorded" date: the newest journal entry already committed under
//     src/content/<ns>/journal/ for the three practices, and the current encounter's own
//     status.as_of for The Middle (the only committed date this repo has for it — the export
//     it renders IS research-ecology's most recent word on the encounter).
import { getRelativeLocaleUrl } from 'astro:i18n'
import type { Locale } from '@/lib/site'
import { currentEntrance } from '@/lib/begegnungen'
import { latestWorks, type EngineWorkMeta } from '@/lib/engines/latest'
import { buildPulseSvg, formatWeekRange, type PulseSnapshot } from '@/lib/pulse/render'
import pulseData from '@/data/pulse/pulse.json'
import register from '@/data/begegnungen/register.json'
import { NAMING, DRAFT_LABEL } from '@/config/naming'

const locale = (Astro.currentLocale ?? 'en') as Locale
// entrance is still the source of The Middle door's "last recorded" date (below); its score is
// no longer rendered prominently — the encounter map moved off the hero (Frank, 18.07.).
const entrance = currentEntrance

const pulse = pulseData as PulseSnapshot
const pulseSvg = buildPulseSvg(pulse)
const pulseCaption = NAMING.pulseCaption({
  weekRange: formatWeekRange(pulse.weeks),
  repoCount: pulse.repos.length,
  totalCommits: pulse.total_commits,
  asOf: pulse.as_of,
})

// The living edge: newest works across the three practices, both work kinds (astro-page works
// under src/components/<ns>/werke, html works under src/content/<ns>/works). Globs can't be
// parameterised, so each is listed; empty namespaces yield {} and drop out harmlessly. This is
// what changes daily — it replaces the static single-encounter block that used to sit here.
// import.meta.glob needs literal args (Vite analyses them statically) — options inlined per call.
const latest = latestWorks(
  [
    { ns: 'field', kind: 'astro', metas: import.meta.glob('/src/components/field/werke/*/meta.json', { eager: true, import: 'default' }) as Record<string, EngineWorkMeta> },
    { ns: 'atelier', kind: 'astro', metas: import.meta.glob('/src/components/atelier/werke/*/meta.json', { eager: true, import: 'default' }) as Record<string, EngineWorkMeta> },
    { ns: 'atelier', kind: 'html', metas: import.meta.glob('/src/content/atelier/works/*/meta.json', { eager: true, import: 'default' }) as Record<string, EngineWorkMeta> },
    { ns: 'studio', kind: 'html', metas: import.meta.glob('/src/content/studio/works/*/meta.json', { eager: true, import: 'default' }) as Record<string, EngineWorkMeta> },
  ],
  8,
)
const nsLabel: Record<string, string> = { field: 'The Field', atelier: 'The Atelier', studio: 'The Studio' }
const encounterCount = (register as unknown[]).length

// "Last recorded" per practice — from committed content, not a live git log (site-v2 work
// order §3.3: "deterministisch zur Buildzeit, KEINE Netz-/Uhr-Zugriffe"). Journal filenames are
// themselves the date (YYYY-MM-DD…), the same convention src/lib/engines/latest.ts relies on.
function latestJournalDate(glob: Record<string, unknown>): string | undefined {
  const dates = Object.keys(glob)
    .map((path) => path.match(/(\d{4}-\d{2}-\d{2})/)?.[1])
    .filter((d): d is string => Boolean(d))
  return dates.sort().at(-1)
}
const atelierJournal = import.meta.glob('/src/content/atelier/journal/*.md')
const fieldJournal = import.meta.glob('/src/content/field/journal/*.md')
const studioJournal = import.meta.glob('/src/content/studio/journal/*.md')

const lastRecorded: Record<string, string | undefined> = {
  ulysses: latestJournalDate(atelierJournal),
  meridian: latestJournalDate(fieldJournal),
  ensemble: latestJournalDate(studioJournal),
  // The Middle has no journal of its own — the encounter export's own as-of stamp is the only
  // committed date this repo carries for it.
  conductor: entrance.status.as_of,
}

const doors = NAMING.doors.items.map((d) => ({
  ...d,
  meta: d.noResident
    ? `${d.noResident} · last recorded: ${lastRecorded[d.id] ?? '—'}`
    : `resident: ${d.id.charAt(0).toUpperCase()}${d.id.slice(1)} · last recorded: ${lastRecorded[d.id] ?? '—'}`,
}))

const isDraft = NAMING.approval !== 'approved'
---

<main id="main" class="mx-auto w-full max-w-7xl flex-1 px-6 pb-24 pt-16 sm:pt-24">
  <section class="text-center">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-fg-muted">{NAMING.eyebrow}</p>
    <p class="mt-7 font-mono text-[11px] uppercase tracking-[0.3em] text-fg-faint">{NAMING.focusKicker}</p>
    <h1 class="mx-auto mt-3 max-w-[18ch] text-[clamp(38px,6.4vw,72px)] font-bold leading-[1.04] tracking-[-0.025em]">
      {NAMING.title}
      {isDraft && <span class="chip ml-3 align-middle text-[11px] normal-case tracking-normal text-fg-faint" title={DRAFT_LABEL}>draft</span>}
    </h1>
    <p class="mx-auto mt-5 max-w-[58ch] text-[17px] text-fg-muted">{NAMING.sub}</p>
    <p class="mx-auto mt-3 max-w-[64ch] font-mono text-xs text-fg-faint">{NAMING.conductorLine}</p>

    {/* Boxen-Konsistenz (Frank, 16.07. nachmittags): Puls und Begegnung bekommen dieselbe
        Panel-Behandlung wie die Karten weiter unten — keine schwebenden Grafiken mehr. */}
    <div class="mt-10 rounded-[10px] border border-line bg-panel px-4 py-7 sm:px-8">
      <figure class="mx-auto">
        <div class="pulse-svg" set:html={pulseSvg} />
      </figure>
      <p class="mx-auto mt-4 max-w-[86ch] font-mono text-[11px] leading-relaxed text-fg-faint">{pulseCaption}</p>
    </div>
  </section>

  <section class="mt-20 border-t border-line/60 pt-16" id="latest">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-fg-muted">
      <b class="text-fg">{NAMING.latest.kicker}</b> · {NAMING.latest.kickerSub}
    </p>
    <p class="mt-4 max-w-[64ch] font-mono text-xs leading-relaxed text-fg-faint">{NAMING.latest.note}</p>

    <ul class="mt-7 divide-y divide-line/60 overflow-hidden rounded-[10px] border border-line bg-panel">
      {latest.map((w) => (
        <li>
          <a href={getRelativeLocaleUrl(locale, w.href)} class="group flex flex-wrap items-baseline gap-x-3 gap-y-1 px-4 py-3.5 sm:px-6">
            <span class="w-[5.5em] shrink-0 font-mono text-[11px] tabular-nums text-fg-faint">{w.date}</span>
            <span class="w-[6.5em] shrink-0 font-mono text-[10px] uppercase tracking-[0.14em] text-fg-muted">{nsLabel[w.ns] ?? w.ns}</span>
            <span class="font-semibold tracking-[-0.01em] transition-opacity group-hover:opacity-70">{w.title}</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1.5 font-mono text-xs text-fg-faint">
      <a href={getRelativeLocaleUrl(locale, '/lab')} class="text-fg-muted transition-colors hover:text-fg">{NAMING.latest.labLink}</a>
      <span aria-hidden="true">·</span>
      <a href={getRelativeLocaleUrl(locale, '/encounters')} class="transition-colors hover:text-fg">{NAMING.crossings.label} ({encounterCount}) →</a>
    </div>
  </section>

  <section class="mt-20 border-t border-line/60 pt-16" id="doors">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-fg-muted">
      <b class="text-fg">{NAMING.doors.kicker}</b> · {NAMING.doors.kickerSub}
    </p>
    <div class="doors mt-7 grid gap-3.5 sm:grid-cols-2 lg:grid-cols-4">
      {doors.map((d) => (
        <a href={d.href} class:list={['door', `door-${d.id}`, 'block rounded-[10px] border border-line bg-panel p-5 pt-5 transition-colors hover:border-fg-faint']}>
          <h3 class="text-[19px] font-semibold tracking-[-0.01em]">{d.name}</h3>
          <p class="mt-2 min-h-[4.2em] text-sm text-fg-muted">{d.description}</p>
          <span class="mt-3 block font-mono text-[11px] text-fg-faint">{d.meta}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-20 border-t border-line/60 pt-16" id="travel">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-fg-muted">
      <b class="text-fg">{NAMING.travel.kicker}</b> · {NAMING.travel.kickerSub}
    </p>
    <div class="mt-7 grid gap-3.5 sm:grid-cols-2">
      {NAMING.travel.items.map((it) => (
        <a href={it.href} target="_blank" rel="noreferrer" class="rounded-[10px] border border-line bg-panel p-4.5 transition-colors hover:border-fg-faint">
          <h3 class="text-base font-semibold">{it.name}</h3>
          <p class="mt-1.5 text-sm text-fg-muted">{it.description}</p>
        </a>
      ))}
    </div>
    <p class="mt-4.5 font-mono text-xs text-fg-faint">
      {NAMING.travel.note} · <a href={getRelativeLocaleUrl(locale, NAMING.travel.allLink.href)} class="underline decoration-line underline-offset-4 transition-colors hover:text-fg">{NAMING.travel.allLink.label}</a>
    </p>
  </section>

  <section class="mt-20 border-t border-line/60 pt-16" id="rest">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-fg-muted">
      <b class="text-fg">{NAMING.rest.kicker}</b>
    </p>
    <div class="mt-7 grid gap-3.5 sm:grid-cols-2">
      {NAMING.rest.items.map((it) => (
        <a href={it.href} class="rounded-[10px] border border-line bg-panel p-4.5 transition-colors hover:border-fg-faint">
          <h3 class="text-base font-semibold">{it.name}</h3>
          <p class="mt-1.5 text-sm text-fg-muted">{it.description}</p>
        </a>
      ))}
    </div>
  </section>
</main>

<style>
  .chip {
    border: 1px solid var(--color-line);
    padding: 1px 8px;
    border-radius: 2px;
    font-family: var(--font-mono);
  }
  .pulse-svg :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  .pulse-svg :global(.pulse-note) {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--color-fg-faint);
  }
  /* Praxisfarben-Haarlinie (decisions doc 2026-07-16 §1.3): the same deliberate, gated
     exception to the site's grayscale "Mono-Skin fest" that the score map already carries
     (src/styles/score-map.css) — the four practice identities read the same colour on the hub
     as they do on the encounter map, just given their own tokens here rather than reaching into
     .score-map's scope (the doors grid sits outside it). */
  :root[data-theme='dark'] .doors {
    --hub-c-ulysses: #9085e9;
    --hub-c-meridian: #3987e5;
    --hub-c-ensemble: #d95926;
    --hub-c-conductor: #77828d;
  }
  :root[data-theme='light'] .doors {
    --hub-c-ulysses: #4a3aa7;
    --hub-c-meridian: #2a78d6;
    --hub-c-ensemble: #c1481c;
    --hub-c-conductor: #6b7684;
  }
  .door::before {
    content: '';
    display: block;
    height: 3px;
    margin: -1.25rem -1.25rem 1rem;
    border-radius: 10px 10px 0 0;
  }
  .door-ulysses::before { background: var(--hub-c-ulysses); }
  .door-meridian::before { background: var(--hub-c-meridian); }
  .door-ensemble::before { background: var(--hub-c-ensemble); }
  .door-conductor::before { background: var(--hub-c-conductor); }
</style>
