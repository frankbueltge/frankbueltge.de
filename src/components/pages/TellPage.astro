---
// Gegenmessung III — „The Tell", öffentlich „Delve into the intricate realm".
// Misst die synthetische Sättigung der Wissenschaft über die sprachlichen Fingerabdrücke
// der Maschine (LLM-Tells). Daten: src/data/tell/latest.json (PubMed; pipelines/tell/).
import { getRelativeLocaleUrl } from 'astro:i18n'
import { t } from '@/i18n/ui'
import type { Locale } from '@/lib/site'
import type { TellData } from '@/lib/tell/types'
import { foldStr, foldRound, num1 } from '@/lib/tell/format'
import { PCHART_W, PCHART_H, yearAreaPath, yearLinePath } from '@/lib/praemie/chart'
import data from '@/data/tell/latest.json'

interface Props { locale: Locale }
const { locale } = Astro.props
const de = locale === 'de'
const d = data as unknown as TellData
const h = d.headline
const methodUrl = getRelativeLocaleUrl(locale, '/werke/tell')

const pts = d.index.map((p) => ({ year: p.year, value: p.value }))
const xMin = pts[0]?.year ?? 0
const xMax = pts.at(-1)?.year ?? 0
const valMax = Math.max(...pts.map((p) => p.value), 1)
const line = yearLinePath(pts, xMin, xMax, valMax)
const area = yearAreaPath(pts, xMin, xMax, valMax)
const cgX = xMax > xMin ? ((d.chatgpt_year - xMin) / (xMax - xMin)) * PCHART_W : 0
---

<article class="tell mx-auto max-w-3xl px-4 py-14">
  <header class="mb-10">
    <h1 class="text-[clamp(30px,6vw,56px)] font-bold tracking-[-0.03em]">Delve into the intricate realm</h1>
    <p class="mt-2 max-w-xl text-fg-muted">{t(locale, 'tl.sub')}</p>
  </header>

  <section class="mb-12 flex items-baseline gap-4">
    <p class="text-[clamp(40px,8vw,72px)] font-bold leading-none tabular-nums">{foldRound(h.fold)}</p>
    <p class="max-w-sm text-sm leading-snug text-fg-muted">
      {de
        ? `So viel häufiger steht „${h.word}" heute in wissenschaftlichen Abstracts als vor ChatGPT (${num1(h.baseline_per100k, locale)} → ${num1(h.peak_per100k, locale)} je 100.000, ${h.peak_year}). Das ist der Tell der Maschine.`
        : `That's how much more often "${h.word}" now appears in scientific abstracts than before ChatGPT (${num1(h.baseline_per100k, locale)} → ${num1(h.peak_per100k, locale)} per 100,000, ${h.peak_year}). It's the machine's tell.`}
    </p>
  </section>

  <section class="mb-12">
    <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">
      {de ? 'Maschinen-Sprech-Index in PubMed-Abstracts' : 'Machine-speak index in PubMed abstracts'}
    </p>
    <svg viewBox={`0 0 ${PCHART_W} ${PCHART_H}`} class="mt-3 w-full overflow-visible text-fg-faint" role="img"
      aria-label={de ? 'Index der LLM-Marker je Jahr, Sprung nach 2022' : 'Index of LLM markers per year, jump after 2022'}>
      <path d={area} fill="rgb(var(--rgb-accent))" fill-opacity="0.1" />
      <path d={line} fill="none" stroke="rgb(var(--rgb-accent))" stroke-width="1.6" vector-effect="non-scaling-stroke" />
      <line x1={cgX} y1="0" x2={cgX} y2={PCHART_H} stroke="currentColor" stroke-width="0.5" stroke-dasharray="3 3" />
      <text x={cgX + 4} y="12" font-size="10" fill="currentColor">ChatGPT</text>
      <text x="0" y={PCHART_H} font-size="9" fill="currentColor">{xMin}</text>
      <text x={PCHART_W} y={PCHART_H} text-anchor="end" font-size="9" fill="currentColor">{xMax}</text>
    </svg>
  </section>

  <section class="mb-12">
    <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">{de ? 'Die Tells' : 'The tells'}</p>
    <ul class="mt-3 divide-y divide-line/60 border-t border-line/60 font-mono text-sm">
      {d.markers.map((m) => (
        <li class="flex items-baseline justify-between py-2">
          <span>{m.word}</span>
          <span class="flex items-baseline gap-4 text-fg-faint">
            <span class="tabular-nums">{num1(m.baseline_per100k, locale)} → {num1(m.peak_per100k, locale)}</span>
            <span class="w-14 text-right font-semibold text-fg">{foldStr(m.fold, locale)}</span>
          </span>
        </li>
      ))}
    </ul>
    <p class="mt-2 font-mono text-[11px] text-fg-faint">{de ? 'Treffer je 100.000 Abstracts; Basis ' : 'Hits per 100,000 abstracts; baseline '}{d.baseline_years[0]}–{d.baseline_years[1]}.</p>
  </section>

  <footer class="mt-12 border-t border-line pt-6">
    <p class="font-mono text-xs text-fg-faint">
      {de
        ? `Quelle: ${d.source.name}. Marker = ein Proxy; auch Menschen schreiben so — der kollektive Sprung ist der Fingerabdruck, nicht das einzelne Paper.`
        : `Source: ${d.source.name}. Markers are a proxy; humans write this way too — the collective jump is the fingerprint, not any single paper.`}
    </p>
    <nav class="mt-2">
      <a href={methodUrl} class="font-mono text-xs text-fg-faint transition-colors hover:text-fg">{t(locale, 'prot.method')} →</a>
    </nav>
  </footer>
</article>
