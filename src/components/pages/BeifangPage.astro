---
// Gegenmessung II — „Der Beifang". Misst, was das Lesen eines Fachartikels an
// Drittanbieter-Tracking mitfängt (Verlagsseiten vs. Diamond-OA-Kontrollgruppe) — gemessen
// vor jeder Cookie-Einwilligung. Daten: src/content/beifang/<jahr>/<datum>.json (wöchentlich,
// montags; pipelines/beifang/). Lücken (Blockaden, Ausfälle) sind Befund, nie stille Nullwerte.
import { getRelativeLocaleUrl } from 'astro:i18n'
import { t } from '@/i18n/ui'
import { getBeifangRuns } from '@/lib/beifang/data'
import { renderBefund } from '@/lib/beifang/befund'
import { PUBLISHER_LABELS } from '@/lib/beifang/types'
import { blockadeStats, entityTable, groupMedians, leakAuditRan, leakFindings, publisherMedians, sparkPath, timeline, usResults } from '@/lib/beifang/stats'
import { infraFor } from '@/lib/beifang/infra'

interface Props { locale: 'de' | 'en' }
const { locale } = Astro.props
const de = locale === 'de'
const runs = await getBeifangRuns()
const latest = runs[0]
const leaks = latest ? leakFindings(latest) : []
const auditRan = latest ? leakAuditRan(latest) : false
const methodUrl = getRelativeLocaleUrl(locale, '/werke/beifang')
const gm = latest ? groupMedians(latest) : null
const pm = latest ? publisherMedians(latest) : {}
const entities = latest ? entityTable(latest).slice(0, 12) : []
const blockade = latest ? blockadeStats(latest) : null
const series = timeline(runs)
const maxY = Math.max(1, ...series.flatMap((p) => [p.verlag ?? 0, p.kontrolle ?? 0]))
const okCount = latest ? usResults(latest).filter((r) => r.blocked === null && r.note === null).length : 0

// EU-Messpunkt-Vermerk: 'entfallen' ist ein eigener Zustand (Ausfall in dieser Sitzung),
// kein Synonym für 'ausstehend' (noch nicht aufgebaut) — beide brauchen eigenen Wortlaut.
const EU_STATUS_TEXT: Record<string, { de: string; en: string }> = {
  ok: { de: 'aktiv', en: 'active' },
  ausstehend: {
    de: 'ausstehend — gemessen wird bisher nur aus US-Rechenzentrumssicht; die EU-Spalte folgt, sobald der Messpunkt steht.',
    en: 'pending — measurements so far are from a US datacenter vantage only; the EU column follows once the vantage exists.',
  },
  entfallen: {
    de: 'entfallen — der EU-Messpunkt war in dieser Sitzung nicht erreichbar; Feststellung entfällt.',
    en: 'omitted — the EU vantage was unreachable this run; no determination.',
  },
}
const euStatusText = latest
  ? (EU_STATUS_TEXT[latest.vantages.eu.status] ?? EU_STATUS_TEXT.ausstehend)[de ? 'de' : 'en']
  : null

// Empfänger-Kategorien in belegte Nebenzeilen übersetzen (Tatsachen, keine Wertung).
function kategorieHinweise(f: (typeof leaks)[number], deLang: boolean): string[] {
  const hinweise: string[] = []
  const broker = f.empfaenger.filter((e) => e.kategorie === 'metrik-broker')
  const selfHosted = f.empfaenger.filter((e) => e.kategorie === 'self-hosted-analytics')
  const verlag = f.empfaenger.filter((e) => e.kategorie === 'verlagseigen')
  if (broker.length) {
    const eig = broker.find((b) => b.eigentuemer)?.eigentuemer
    const namen = broker.map((b) => b.name).join(', ')
    hinweise.push(deLang
      ? `${namen}: kommerzieller Metrik-Dienst${eig ? ` (${eig})` : ''}.`
      : `${namen}: commercial metrics service${eig ? ` (${eig})` : ''}.`)
  }
  if (selfHosted.length) {
    const namen = selfHosted.map((b) => b.name).join(', ')
    hinweise.push(deLang
      ? `${namen}: vom Herausgeber selbst betriebene, quelloffene Analyse-Software.`
      : `${namen}: open-source analytics run by the publisher itself.`)
  }
  if (verlag.length) {
    const namen = verlag.map((b) => b.name).join(', ')
    hinweise.push(deLang
      ? `${namen}: verlagseigene Domain (andere Second-Level-Domain, gleicher Verlag).`
      : `${namen}: publisher-owned domain (different second-level domain, same publisher).`)
  }
  return hinweise
}

// Kanal des Requests lesbar machen — pro Leak korrekt (die DOI reist mal im Query,
// mal im Pfad/POST), nie pauschal behauptet.
function kanalLabel(kanal: string, deLang: boolean): string {
  const map: Record<string, { de: string; en: string }> = {
    query: { de: 'Query-String', en: 'query string' },
    pfad: { de: 'URL-Pfad', en: 'URL path' },
    post: { de: 'POST-Body', en: 'POST body' },
    referer: { de: 'Referer', en: 'referer' },
  }
  return (map[kanal] ?? { de: kanal, en: kanal })[deLang ? 'de' : 'en']
}
---

<article class="beifang mx-auto max-w-3xl px-4 py-14">
  <header class="mb-10">
    <h1 class="text-[clamp(30px,6vw,56px)] font-bold tracking-[-0.03em]">{t(locale, 'bf.title')}</h1>
    <p class="mt-2 max-w-xl text-fg-muted">{t(locale, 'bf.sub')}</p>
  </header>

  {!latest && (
    <p class="text-fg-muted">
      {de
        ? 'Noch keine Messung — die erste Sitzung steht aus. Das Instrument misst wöchentlich, montags.'
        : 'No measurement yet — the first run is pending. The instrument measures weekly, on Mondays.'}
    </p>
  )}

  {latest && (
    <>
      {/* Leitbefund: die Verweigerung selbst. Wer jeden Leser trackt, sperrt den Prüfblick
          aus — die Asymmetrie des Papers, als Zahl. Aggregiert je Verlag, nicht als Einzelliste. */}
      {blockade && blockade.verlag.blocked > 0 && (
        <section class="mb-12 border-l-2 border-accent/60 pl-5">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">{de ? 'Leitbefund' : 'Headline finding'}</p>
          <p class="mt-2 text-2xl font-semibold leading-snug">
            {de
              ? `${blockade.verlag.blocked} von ${blockade.verlag.total} Verlagsseiten verweigern die Messung.`
              : `${blockade.verlag.blocked} of ${blockade.verlag.total} publisher pages refuse the measurement.`}
          </p>
          <p class="mt-2 max-w-xl leading-relaxed text-fg-muted">
            {de
              ? `Dieselben Plattformen, die jeden Leser vermessen, sperren das Instrument aus, das nachschauen will — zum Vergleich blockieren ${blockade.kontrolle.blocked} von ${blockade.kontrolle.total} Kontrollseiten. Die Blockade ist kein Ausfall, sie ist der Befund.`
              : `The same platforms that measure every reader lock out the instrument that wants to look — for comparison, ${blockade.kontrolle.blocked} of ${blockade.kontrolle.total} control pages block. The refusal is not a failure; it is the finding.`}
          </p>
          <ul class="mt-4 space-y-1 text-sm">
            {blockade.verlag.byPublisher.map((p) => (
              <li class="flex items-baseline justify-between gap-3 border-b border-line/60 py-1.5">
                <span>{PUBLISHER_LABELS[p.publisher] ?? p.publisher}</span>
                <span class="font-mono text-xs text-fg-faint">
                  {p.blocked === 0
                    ? (de ? `messbar (0/${p.total} blockiert)` : `measurable (0/${p.total} blocked)`)
                    : `${p.blocked}/${p.total} ${de ? 'blockiert' : 'blocked'}`}
                </span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {/* Leitgrafik: Kontrollgruppen-Kontrast (zwei Balken, Werte sichtbar am Balken) */}
      <section class="mb-12">
        <h2 class="mb-3 font-semibold">{de ? 'Verlagsseiten vs. Kontrollgruppe' : 'Publisher pages vs. control group'}</h2>
        {gm && gm.verlag !== null && gm.kontrolle !== null ? (
          <svg viewBox="0 0 560 64" role="img" class="w-full text-fg-muted" aria-label={de
            ? `Median Tracker-Hosts: Verlage ${gm.verlag}, Kontrollgruppe ${gm.kontrolle}`
            : `Median tracker hosts: publishers ${gm.verlag}, control ${gm.kontrolle}`}>
            {[
              { y: 6, v: gm.verlag, label: de ? 'Verlage (Big 5)' : 'Publishers (Big 5)' },
              { y: 38, v: gm.kontrolle, label: de ? 'Diamond-OA-Kontrolle' : 'Diamond-OA control' },
            ].map(({ y, v, label }) => {
              const barMax = Math.max(gm.verlag!, gm.kontrolle!, 1)
              const w = Math.round((v! / barMax) * 340)
              return (
                <>
                  <text x="0" y={y + 14} font-size="12" fill="currentColor">{label}</text>
                  <rect x="170" y={y} width={Math.max(w, 1)} height="18" fill="currentColor" />
                  <text x={170 + Math.max(w, 1) + 8} y={y + 14} font-size="12" fill="currentColor">{v}</text>
                </>
              )
            })}
          </svg>
        ) : (
          <p class="text-fg-muted">{de ? 'Feststellung entfällt — keine unblockierte Messung in einer der Gruppen.' : 'No determination — no unblocked measurement in one of the groups.'}</p>
        )}
        {/* Median je Verlag (Spec §7: Werte pro Verlag sichtbar) */}
        <ul class="mt-4 space-y-1 text-sm">
          {Object.entries(pm).map(([pub, m]) => (
            <li class="flex items-baseline justify-between gap-3 border-b border-line/60 py-1.5">
              <span>{PUBLISHER_LABELS[pub] ?? pub}</span>
              <span class="font-mono text-xs text-fg-faint">
                {m !== null
                  ? `${m} ${de ? 'Tracker-Hosts (Median)' : 'tracker hosts (median)'}`
                  : de ? 'Feststellung entfällt' : 'no determination'}
              </span>
            </li>
          ))}
        </ul>
      </section>

      {/* Befund der Woche */}
      <section class="mb-12 border-l-2 border-accent/60 pl-5">
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">{de ? 'Befund der Woche' : 'Finding of the week'}</p>
        <p class="mt-2 leading-relaxed">{renderBefund(latest.befund, locale)}</p>
      </section>

      {/* Wohin die Artikel-Kennung (DOI) geht — Beobachtung je Messung, kein Rechtsurteil */}
      <section class="mb-12">
        <h2 class="mb-3 font-semibold">{de ? 'Wohin die Artikel-Kennung (DOI) geht' : 'Where the article identifier (DOI) goes'}</h2>
        <p class="mb-4 max-w-xl leading-relaxed text-fg-muted">
          {de
            ? 'Beobachtung dieser Messung: Die DOI ging dorthin, wo Fremd-Skripte (Altmetric, Dimensions, Google Analytics u. ä.) eingebunden sind — bei Konzernverlag wie gebührenfreiem Journal. Sie folgt dem eingebundenen Skript, nicht dem Geschäftsmodell.'
            : 'Observation from this measurement: the DOI went wherever third-party scripts (Altmetric, Dimensions, Google Analytics and the like) are embedded — at a corporate publisher just as at a fee-free journal. It follows the embedded script, not the business model.'}
        </p>
        {auditRan && leaks.length > 0 && latest && (
          <p class="mb-4 font-mono text-[11px] leading-relaxed text-fg-faint">
            {de
              ? `Einzelmessung vom ${latest.date}, aus einem US-Rechenzentrum (GitHub Actions), ohne Interaktion mit der Seite. Dokumentiert ist der jeweilige Request; die rechtliche Bewertung überlässt das Instrument dir.`
              : `Single measurement of ${latest.date}, from a US datacenter (GitHub Actions), with no interaction with the page. What is documented is each request; the legal assessment is left to you.`}
          </p>
        )}
        {!auditRan ? (
          <p class="text-fg-muted">
            {de
              ? 'Der Leak-Audit lief in dieser Sitzung noch nicht — dieser Lauf war reiner Tracker-Zensus. Der Identitäts-Nachweis beginnt mit dem nächsten Lauf.'
              : 'The leak audit did not run in this session — this run was a plain tracker census. Identity detection begins with the next run.'}
          </p>
        ) : leaks.length === 0 ? (
          <p class="text-fg-muted">
            {de
              ? 'Auf den erreichbaren Seiten kein nachweisbarer DOI-Leak an Dritte — auch das ist ein Befund (und gilt nur für das Messbare; das Gros der Verlagsseiten verweigert die Messung).'
              : 'No demonstrable DOI leak to third parties on the reachable pages — itself a finding (and only for what is measurable; most publisher pages refuse measurement).'}
          </p>
        ) : (
          <div class="space-y-5">
            {leaks.map((f) => (
              <div>
                <p class="leading-relaxed">
                  <span class="font-semibold">{PUBLISHER_LABELS[f.publisher] ?? f.publisher}</span>
                  {f.group === 'kontrolle' && (
                    <span class="ml-2 rounded border border-line px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wide text-fg-faint">{de ? 'Kontrollgruppe' : 'control group'}</span>
                  )}{' '}
                  {f.empfaenger.length > 0
                    ? (de
                        ? `— in dieser Messung trug ein ausgehender Request die DOI an ${f.empfaenger.map((e) => e.name).join(', ')} (vor jeder Cookie-Einwilligung).`
                        : `— in this measurement an outgoing request carried the DOI to ${f.empfaenger.map((e) => e.name).join(', ')} (before any cookie consent).`)
                    : (de
                        ? `— in dieser Messung trug ein ausgehender Request die DOI an Dritte (${f.hosts.join(', ')}), vor jeder Cookie-Einwilligung; darunter keine über Tracker-Radar oder kuratierte Liste benannte Firma.`
                        : `— in this measurement an outgoing request carried the DOI to third parties (${f.hosts.join(', ')}), before any cookie consent; none of them a company named via the tracker radar or the curated list.`)}
                </p>
                {kategorieHinweise(f, de).map((h) => (
                  <p class="mt-1 text-sm text-fg-muted">{h}</p>
                ))}
                {f.empfaenger.length > 0 && f.hosts.length > 0 && (
                  <p class="mt-1 text-sm text-fg-muted">
                    {de ? `Außerdem an Hosts ohne benannte Firma: ${f.hosts.join(', ')}.`
                        : `Also to hosts without a named company: ${f.hosts.join(', ')}.`}
                  </p>
                )}
                <ul class="mt-2 space-y-2 text-sm">
                  {f.hard.map((l) => (
                    <li class="border-l-2 border-accent/60 pl-4">
                      <span class="font-mono text-xs text-fg-muted">
                        {l.firma ?? infraFor(l.host)?.firma ?? l.host} · {l.form} · {kanalLabel(l.kanal, de)}
                      </span>
                      <details class="mt-1">
                        <summary class="cursor-pointer text-fg-faint">{de ? 'Beweis' : 'Evidence'}</summary>
                        <code class="mt-1 block overflow-x-auto whitespace-pre-wrap break-all bg-line/30 p-2 text-[11px]">{l.beweis}</code>
                      </details>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        )}
        <p class="mt-4 font-mono text-[11px] text-fg-faint">
          {de
            ? 'Hartes Signal: die DOI (eindeutig, auch als Hash fälschungssicher). Der DOI-Resolver (doi.org) zählt nicht — er ist die Adresse, kein Empfänger. Titel/Schlagwörter wären ein schwächeres Indiz und stehen im Archiv separat.'
            : 'Hard signal: the DOI (unambiguous, tamper-proof even when hashed). The DOI resolver (doi.org) does not count — it is the address, not a recipient. Title/keywords would be a weaker indicator, kept separately in the archive.'}
        </p>
      </section>

      {/* Firmen-Tafel */}
      <section class="mb-12">
        <h2 class="mb-3 font-semibold">{de ? 'Wer mitliest' : 'Who reads along'}</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-line">
                <th scope="col" class="py-2 pr-3 text-left font-medium text-fg-muted">{de ? 'Firma' : 'Company'}</th>
                <th scope="col" class="px-1.5 py-2 text-right font-medium text-fg-muted">{de ? 'Verlagsseiten' : 'Publisher pages'}</th>
                <th scope="col" class="px-1.5 py-2 text-right font-medium text-fg-muted">{de ? 'Kontrollseiten' : 'Control pages'}</th>
              </tr>
            </thead>
            <tbody>
              {entities.map((row) => (
                <tr class="border-b border-line/60">
                  <td class="py-2 pr-3">{row.entity}</td>
                  <td class="px-1.5 py-2 text-right font-mono text-xs text-fg-muted">{row.verlag}</td>
                  <td class="px-1.5 py-2 text-right font-mono text-xs text-fg-muted">{row.kontrolle}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      {/* Zeitreihe (erst ab 2 Läufen als Grafik; vorher ehrlicher Satz) */}
      <section class="mb-12">
        <h2 class="mb-3 font-semibold">{de ? 'Verlauf' : 'Over time'}</h2>
        {series.length < 2 ? (
          <p class="text-fg-muted">{de ? 'Die Zeitreihe entsteht — bisher eine Messung.' : 'The time series is forming — one measurement so far.'}</p>
        ) : (
          <figure>
            <svg viewBox="0 0 560 100" role="img" class="w-full text-fg-muted" aria-label={de ? 'Median Tracker-Hosts über die Zeit' : 'Median tracker hosts over time'}>
              <path d={sparkPath(series.map((p) => p.verlag), 560, 80, maxY)} fill="none" stroke="currentColor" stroke-width="2" />
              <path d={sparkPath(series.map((p) => p.kontrolle), 560, 80, maxY)} fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" />
              <text x="0" y="98" font-size="11" fill="currentColor">{series[0].date}</text>
              <text x="560" y="98" font-size="11" text-anchor="end" fill="currentColor">{series[series.length - 1].date}</text>
            </svg>
            <figcaption class="mt-2 text-xs text-fg-faint">
              {de
                ? `Median Tracker-Hosts je Sitzung — durchgezogen: Verlage, gestrichelt: Kontrolle. Skala 0–${maxY}. Lücken sind Lücken.`
                : `Median tracker hosts per run — solid: publishers, dashed: control. Scale 0–${maxY}. Gaps stay gaps.`}
            </figcaption>
          </figure>
        )}
      </section>

      {/* EU-Spalte: sichtbar ausstehend (Spec §4/§6) */}
      <section class="mb-12">
        <p class="text-sm text-fg-muted">
          {de ? `EU-Messpunkt: ${euStatusText}` : `EU vantage: ${euStatusText}`}
        </p>
      </section>

      <footer class="mt-12 border-t border-line pt-6">
        <p class="font-mono text-xs text-fg-faint">
          {de
            ? `Sitzung vom ${latest.date} · ${okCount} Seiten gemessen · Panel ${latest.panel_version} · Diese Seite lädt null Drittanbieter-Requests.`
            : `Run of ${latest.date} · ${okCount} pages measured · panel ${latest.panel_version} · This page loads zero third-party requests.`}
        </p>
        <nav class="mt-2">
          <a href={methodUrl} class="font-mono text-xs text-fg-faint transition-colors hover:text-fg">{t(locale, 'prot.method')} →</a>
        </nav>
      </footer>
    </>
  )}
</article>
