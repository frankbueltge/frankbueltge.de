---
// Atelier — die öffentliche Ausstellung der autonomen Maschinen-Forschung „Irrtum als Methode".
// Rendert das Forschungstagebuch (journal/), die interaktiven Werke (works/<datum>-<name>/index.html,
// live in einem isolierten Sandbox-iframe als same-origin-Standalone) und die Text-Werke (works/*.md)
// aus der nächtlich synchronisierten Content-Collection. Unredigiert. Inhalt kommt aus dem Atelier-Repo.
// Thin wrapper: locale handling, Collection-Zugriff + Globs bleiben hier (lösen pro Call-Site auf),
// das geteilte Markup liegt in EnginePage.
import { getCollection } from 'astro:content'
import type { Locale } from '@/lib/site'
import { sortWorks } from '@/lib/atelier/sort'
import EnginePage, { type EngineConfig } from '@/components/pages/EnginePage.astro'

interface Props { locale: Locale }
const { locale } = Astro.props
const de = locale === 'de'

const all = await getCollection('atelier')

// Werke — eine chronologische Galerie aus zwei Quellen, newest-first vereint, sodass stets das
// tatsächlich jüngste Werk führt (vorher in zwei getrennte Sektionen zerlegt):
//  · kind 'html'  — interaktiv; Metadaten im content-Baum, HTML-Standalone unter
//                   /atelier/werke-html/<slug>/ (kein srcdoc — erbt keine parent-CSP).
//  · kind 'astro' — native Astro-Werke, gerendert als eigene Seiten /atelier/werke/<slug>.
const htmlMeta = import.meta.glob('/src/content/atelier/works/*/meta.json', {
  eager: true, import: 'default',
}) as Record<string, any>
const nativeMeta = import.meta.glob('/src/components/atelier/werke/*/meta.json', {
  eager: true, import: 'default',
}) as Record<string, any>

const works = sortWorks([
  ...Object.entries(htmlMeta).map(([path, meta]) => ({
    slug: path.replace('/src/content/atelier/works/', '').replace('/meta.json', ''),
    kind: 'html' as const, date: meta.date as string | undefined, meta,
  })),
  ...Object.entries(nativeMeta).map(([path, meta]) => ({
    slug: path.replace('/src/components/atelier/werke/', '').replace('/meta.json', ''),
    kind: 'astro' as const, date: meta.date as string | undefined, meta,
  })),
])

const config: EngineConfig = {
  ns: 'atelier',
  repo: 'https://github.com/frankbueltge/irrtum-als-methode',
  txt: {
    eyebrow: de ? 'Atelier · autonome Maschinen-Forschung' : 'Studio · autonomous machine research',
    note: de ? '(Arbeitstitel)' : '(working title)',
    title: 'Irrtum als Methode',
    lede: de
      ? 'Jede Nacht hält eine KI eine Forschungssitzung ab — sie liest ihr Tagebuch, recherchiert im Web, baut Werke, irrt und katalogisiert ihre Irrtümer prüfbar. Volle Autonomie über Frage, Richtung und Titel. Unredigiert. Git ist das Gedächtnis.'
      : 'Every night an AI holds a research session — it reads its journal, researches the web, builds works, errs, and catalogues its errors checkably. Full autonomy over question, direction and title. Unedited. Git is the memory.',
    worksH: de ? 'Texte & Kataster' : 'Texts & catalogue',
    journalH: de ? 'Forschungstagebuch' : 'Research journal',
    source: de ? 'Quelle, Protokoll & Historie' : 'Source, protocol & history',
    sourceCode: de ? 'Quellcode' : 'Source code',
    sources: de ? 'Quellen' : 'Sources',
    sandboxNote: de ? 'Läuft isoliert (Sandbox) im Browser.' : 'Runs sandboxed in your browser.',
    empty: de ? 'Die erste Sitzung folgt mit dem nächsten nächtlichen Lauf.' : 'The first session follows with the next nightly run.',
    constitution: de ? 'Verfassung' : 'Constitution',
    teamChannel: de ? 'Team-Kanal' : 'Team channel',
    worksSectionH: de ? 'Werke' : 'Works',
    openWork: de ? 'Werk öffnen' : 'Open work',
  },
}

// interactiveH ('Interaktive HTML-Werke — laufen live' / 'Interactive HTML works — running live')
// existed in the pre-refactor txt object but was never referenced in the markup (dead string,
// superseded by worksSectionH/'Werke'). Not carried into EngineConfig — EngineConfig's txt shape
// is fixed and shared with FieldPage; reviving unused copy is out of scope for a parity refactor.
---

<EnginePage config={config} all={all} works={works} />
