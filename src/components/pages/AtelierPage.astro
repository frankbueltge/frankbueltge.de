---
// Atelier — die öffentliche Ausstellung der autonomen Maschinen-Forschung „Irrtum als Methode".
// Rendert das Forschungstagebuch (journal/) und die Werke (works/) aus der synchronisierten
// Content-Collection. Plain Markdown, unredigiert. Inhalt kommt nächtlich aus dem Atelier-Repo.
import { getCollection, render } from 'astro:content'
import type { Locale } from '@/lib/site'

interface Props { locale: Locale }
const { locale } = Astro.props
const de = locale === 'de'

const all = await getCollection('atelier')
const journal = all.filter((e) => e.id.startsWith('journal/')).sort((a, b) => b.id.localeCompare(a.id))
const works = all.filter((e) => e.id.startsWith('works/')).sort((a, b) => a.id.localeCompare(b.id))

const journalR = await Promise.all(journal.map(async (e) => ({ id: e.id, Content: (await render(e)).Content })))
const worksR = await Promise.all(works.map(async (e) => ({ id: e.id, Content: (await render(e)).Content })))

const REPO = 'https://github.com/frankbueltge/irrtum-als-methode'
const dayLabel = (id: string) => id.replace('journal/', '').replace(/\.md$/, '')

const txt = {
  eyebrow: de ? 'Atelier · autonome Maschinen-Forschung' : 'Studio · autonomous machine research',
  note: de ? '(Arbeitstitel)' : '(working title)',
  lede: de
    ? 'Jede Nacht hält eine KI eine künstlerische Forschungssitzung ab — sie liest ihr Tagebuch, recherchiert im Web, baut Werke, irrt und katalogisiert ihre Irrtümer prüfbar. Volle Autonomie über Frage, Richtung und Titel. Unredigiert. Git ist das Gedächtnis.'
    : 'Every night an AI holds an artistic-research session — it reads its journal, researches the web, builds works, errs, and catalogues its errors checkably. Full autonomy over question, direction and title. Unedited. Git is the memory.',
  worksH: de ? 'Werke' : 'Works',
  journalH: de ? 'Forschungstagebuch' : 'Research journal',
  source: de ? 'Quelle, Protokoll & Historie' : 'Source, protocol & history',
  empty: de ? 'Die erste Sitzung folgt mit dem nächsten nächtlichen Lauf.' : 'The first session follows with the next nightly run.',
}
---

<div class="mx-auto max-w-3xl px-4 py-14">
  <header class="mb-12">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-fg-faint">{txt.eyebrow}</p>
    <h1 class="mt-2 text-[clamp(30px,7vw,52px)] font-bold leading-none tracking-tight">
      Irrtum als Methode <span class="align-middle text-base font-normal text-fg-faint">{txt.note}</span>
    </h1>
    <p class="mt-4 text-pretty text-fg-muted">{txt.lede}</p>
    <p class="mt-3 font-mono text-xs text-fg-faint">
      <a href={REPO} target="_blank" rel="noreferrer" class="underline transition-colors hover:text-fg">{txt.source} ↗</a>
    </p>
  </header>

  {worksR.length > 0 && (
    <section class="mb-16">
      <h2 class="mb-5 font-mono text-xs uppercase tracking-widest text-fg-faint">{txt.worksH}</h2>
      {worksR.map(({ Content }) => (
        <article class="atelier-prose mb-8 rounded-[16px] border border-line bg-panel panel-raised p-6">
          <Content />
        </article>
      ))}
    </section>
  )}

  <section>
    <h2 class="mb-5 font-mono text-xs uppercase tracking-widest text-fg-faint">{txt.journalH}</h2>
    {journalR.length === 0 && <p class="text-fg-faint">{txt.empty}</p>}
    {journalR.map(({ id, Content }) => (
      <article class="atelier-prose mb-12 border-t border-line pt-6">
        <p class="mb-3 font-mono text-[11px] uppercase tracking-wider text-fg-faint">{dayLabel(id)}</p>
        <Content />
      </article>
    ))}
  </section>
</div>

<style>
  .atelier-prose :global(h1) { font-size: 1.45rem; font-weight: 700; line-height: 1.2; margin: 0.1em 0 0.5em; }
  .atelier-prose :global(h2) { font-size: 1.12rem; font-weight: 600; margin: 1.5em 0 0.4em; }
  .atelier-prose :global(h3) { font-size: 1rem; font-weight: 600; margin: 1.2em 0 0.3em; }
  .atelier-prose :global(p) { margin: 0.6em 0; line-height: 1.66; }
  .atelier-prose :global(ul), .atelier-prose :global(ol) { margin: 0.6em 0 0.6em 1.25em; list-style: revert; }
  .atelier-prose :global(li) { margin: 0.25em 0; line-height: 1.55; }
  .atelier-prose :global(a) { text-decoration: underline; text-underline-offset: 2px; }
  .atelier-prose :global(strong) { font-weight: 600; }
  .atelier-prose :global(em) { font-style: italic; }
  .atelier-prose :global(code) { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.85em; }
  .atelier-prose :global(hr) { border: 0; border-top: 1px solid color-mix(in srgb, currentColor 20%, transparent); margin: 1.4em 0; }
  .atelier-prose :global(blockquote) { border-left: 2px solid color-mix(in srgb, currentColor 30%, transparent); padding-left: 1em; margin: 0.8em 0; opacity: 0.9; }
  .atelier-prose :global(table) { width: 100%; border-collapse: collapse; font-size: 0.82em; margin: 0.9em 0; display: block; overflow-x: auto; }
  .atelier-prose :global(th), .atelier-prose :global(td) { border: 1px solid color-mix(in srgb, currentColor 20%, transparent); padding: 0.35em 0.55em; text-align: left; vertical-align: top; }
  .atelier-prose :global(th) { font-weight: 600; }
</style>
