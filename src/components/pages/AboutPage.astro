---
import { t } from '@/i18n/ui'
import { aboutContent } from '@/data/about'
import { SITE, type Locale } from '@/lib/site'

const locale = (Astro.currentLocale ?? 'en') as Locale
const a = aboutContent[locale]
const links = [
  { label: 'LinkedIn', href: SITE.social.linkedin },
  { label: 'GitHub', href: SITE.social.github },
  { label: 'data-snack.com', href: SITE.projects.dataSnack },
]
---

<main id="main" class="mx-auto w-full max-w-3xl flex-1 px-6 py-16 sm:py-24">
  <p class="font-mono text-xs uppercase tracking-[0.28em] text-accent-soft">{t(locale, 'about.title')}</p>
  <h1 class="mt-5 text-[clamp(34px,5vw,56px)] font-bold tracking-[-0.03em]"><span class="bg-gradient-to-r from-accent to-cyan bg-clip-text text-transparent">Frank Bültge</span></h1>
  <p class="mt-6 max-w-2xl text-xl text-fg sm:text-2xl">{a.lede}</p>

  <div class="mt-12 space-y-10">
    {a.sections.map((s) => (
      <section>
        <h2 class="text-xl font-semibold">{s.heading}</h2>
        <div class="mt-3 space-y-3">
          {s.paragraphs.map((p) => <p class="leading-relaxed text-fg-muted">{p}</p>)}
        </div>
      </section>
    ))}
  </div>

  <h2 class="mt-12 font-mono text-xs uppercase tracking-widest text-fg-faint">Contact</h2>
  <p class="mt-3 max-w-lg text-fg-muted">
    Reachable directly by <a href={`mailto:${SITE.email}`} class="underline hover:text-fg">{SITE.email}</a>
    or on LinkedIn. For projects, conversations, or just a good question about data — see
    also <a href="/contact" class="underline hover:text-fg">/contact</a>.
  </p>

  <h2 class="mt-10 font-mono text-xs uppercase tracking-widest text-fg-faint">{t(locale, 'about.elsewhere')}</h2>
  <ul class="mt-4 flex flex-wrap gap-2">
    {links.map((l) => (
      <li><a href={l.href} target="_blank" rel="noreferrer" class="rounded-full border border-line px-3 py-1.5 text-sm text-fg-muted transition-colors hover:border-fg-muted hover:text-fg">{l.label} ↗</a></li>
    ))}
    <li><a href={`mailto:${SITE.email}`} class="rounded-full border border-line px-3 py-1.5 text-sm text-fg-muted transition-colors hover:border-fg-muted hover:text-fg">{SITE.email}</a></li>
  </ul>
</main>
