---
// EnginePage — shared presentation for the autonomous research engine pages (field, atelier,
// plenum). Renders the research journal (journal/), the interactive works
// (works/<date>-<name>/index.html, live in an isolated sandbox iframe as a same-origin
// standalone) and the text works (works/*.md) from the synced content collection. Unedited.
// Content comes from the engine's own repo. Parametrised by EngineConfig — callers (FieldPage,
// AtelierPage, PlenumPage) own collection access (getCollection + import.meta.glob cannot move
// here, they resolve at build time per call site) and pass the merged `all` entries and sorted
// `works` array in.
import { render } from 'astro:content'
import { sortJournal } from '@/lib/atelier/sort'
import { splitSessions, sessionMeta, renderMarkdown } from '@/lib/engines/journal'

export interface EngineConfig {
  ns: 'field' | 'atelier' | 'plenum'
  repo: string
  txt: {
    eyebrow: string
    note: string
    title: string
    lede: string
    worksH: string
    journalH: string
    source: string
    sourceCode: string
    sources: string
    sandboxNote: string
    empty: string
    constitution: string
    teamChannel: string
    worksSectionH: string
    openWork: string
    close: string
  }
}

interface Props {
  config: EngineConfig
  all: any[]
  works: { slug: string; kind: 'html' | 'astro'; date?: string; meta: any }[]
}

const { config, all, works } = Astro.props
const { txt } = config

// Journal newest-first (numeric: session-10 before session-9, date entries at the bottom of their day).
const journal = sortJournal(all.filter((e) => e.id.startsWith('journal/')))
// Texts newest-first.
const mdWorks = all.filter((e) => e.id.startsWith('works/')).sort((a, b) => b.id.localeCompare(a.id))

const mdWorksR = await Promise.all(mdWorks.map(async (e) => ({ id: e.id, Content: (await render(e)).Content })))

// Root docs (REQUESTS.md, PROTOCOL.md, …) the journals cite constantly: baked into the page
// as hidden templates so citations open in a modal — build-time only, no runtime fetch
// (Git is the archive; the site stays static). Everything else cited links to the repo.
const rootDocs = all.filter((e) => !e.id.includes('/'))
const rootDocsR = await Promise.all(rootDocs.map(async (e) => ({ id: e.id, Content: (await render(e)).Content })))
const mdRefs = { repo: config.repo, docs: new Set(rootDocs.map((e) => e.id)) }

const dayLabel = (id: string) => id.replace('journal/', '').replace(/\.md$/, '')

const journalDays = journal.map((e) => {
  const sessions = splitSessions(e.body ?? '')
    .map((s) => ({ ...s, ...sessionMeta(s.text), html: renderMarkdown(s.text, mdRefs) }))
    .reverse() // file order is chronological; display newest session first
  return { id: e.id, sessions }
})
---

{/* Breiter Rahmen für die interaktiven Werke (Canvas-Arbeiten brauchen Fläche);
    Header, Text-Werke und Journal bleiben in Leselinienbreite (max-w-3xl, zentriert). */}
<div class="mx-auto max-w-6xl px-4 py-14">
  <header class="mx-auto mb-12 max-w-3xl">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-fg-faint">{txt.eyebrow}</p>
    <h1 class="mt-2 text-[clamp(30px,7vw,52px)] font-bold leading-none tracking-tight">
      {txt.title} <span class="align-middle text-base font-normal text-fg-faint">{txt.note}</span>
    </h1>
    <p class="mt-4 text-pretty text-fg-muted">{txt.lede}</p>
    <p class="mt-3 font-mono text-xs text-fg-faint">
      <a href={config.repo} target="_blank" rel="noreferrer" class="underline transition-colors hover:text-fg">{txt.source} ↗</a>
    </p>
    <p class="mt-1 font-mono text-xs text-fg-faint">
      <a href={`/${config.ns}/protocol`} class="underline transition-colors hover:text-fg">{txt.constitution}</a>
      · <a href={`/${config.ns}/requests`} class="underline transition-colors hover:text-fg">{txt.teamChannel}</a>
    </p>
  </header>

  {works.length > 0 && (
    <section class="mb-16">
      <h2 class="mb-5 font-mono text-xs uppercase tracking-widest text-fg-faint">{txt.worksSectionH}</h2>
      {works.map(({ slug, kind, meta }) => kind === 'astro' ? (
        <article class="mb-12 rounded-[16px] border border-line bg-panel panel-raised p-6">
          <a href={`/${config.ns}/werke/${slug}`} class="group block">
            <h3 class="text-lg font-semibold transition-colors group-hover:text-accent-soft">
              {meta.title ?? slug}
              {meta.date && <span class="ml-2 font-mono text-xs font-normal text-fg-faint">{meta.date}</span>}
            </h3>
            {(meta.embodies ?? meta.verkoerpert) && <p class="mt-1.5 text-sm leading-relaxed text-fg-muted">{meta.embodies ?? meta.verkoerpert}</p>}
            <span class="mt-3 inline-block font-mono text-[11px] text-fg-faint underline transition-colors group-hover:text-fg">{txt.openWork} →</span>
          </a>
        </article>
      ) : (
        <article class="mb-12 rounded-[16px] border border-line bg-panel panel-raised p-6">
          <header class="mb-4">
            <h3 class="text-lg font-semibold">
              {meta.title ?? slug}
              {meta.date && <span class="ml-2 font-mono text-xs font-normal text-fg-faint">{meta.date}</span>}
            </h3>
            {(meta.embodies ?? meta.verkoerpert) && <p class="mt-2 text-sm leading-relaxed text-fg-muted">{meta.embodies ?? meta.verkoerpert}</p>}
            {meta.medium && (
              <p class="mt-2 font-mono text-[11px] text-fg-faint">
                {meta.medium}{meta.seed != null && ` · Seed ${meta.seed}`}
              </p>
            )}
          </header>

          {/*
            SECURITY: standalone same-origin file under /{ns}/werke-html/<slug>/ —
            a separate document does NOT inherit the parent <meta> CSP. sandbox="allow-scripts"
            WITHOUT allow-same-origin → null origin, no access to cookies/storage/DOM of
            frankbueltge.de. Path-specific CSP in _headers allows the work's inline scripts,
            blocks fetch/connect (no exfiltration channel).
            NEVER add allow-same-origin — that would lift the isolation.
          */}
          <iframe
            src={`/${config.ns}/werke-html/${slug}/`}
            sandbox="allow-scripts"
            loading="lazy"
            title={meta.title ?? slug}
            class="block h-[600px] w-full resize-y overflow-auto rounded-[10px] border border-line bg-white"
          ></iframe>

          <div class="mt-3 flex flex-wrap items-center justify-between gap-2 font-mono text-[11px] text-fg-faint">
            <span>{txt.sandboxNote}</span>
            <a href={`${config.repo}/tree/main/works/${slug}`} target="_blank" rel="noreferrer" class="underline hover:text-fg">{txt.sourceCode} ↗</a>
          </div>

          {Array.isArray(meta.quellen) && meta.quellen.length > 0 && (
            <details class="mt-3 font-mono text-[11px] text-fg-faint">
              <summary class="cursor-pointer select-none">{txt.sources}</summary>
              <ul class="mt-2 list-disc space-y-1 pl-4">
                {meta.quellen.map((q: string) => <li>{q}</li>)}
              </ul>
            </details>
          )}
        </article>
      ))}
    </section>
  )}

  {mdWorksR.length > 0 && (
    <section class="mx-auto mb-16 max-w-3xl">
      <h2 class="mb-5 font-mono text-xs uppercase tracking-widest text-fg-faint">{txt.worksH}</h2>
      {mdWorksR.map(({ Content }) => (
        <article class="engine-prose mb-8 rounded-[16px] border border-line bg-panel panel-raised p-6">
          <Content />
        </article>
      ))}
    </section>
  )}

  <section class="mx-auto max-w-3xl">
    <h2 class="mb-5 font-mono text-xs uppercase tracking-widest text-fg-faint">{config.txt.journalH}</h2>
    {journalDays.length === 0 && <p class="text-fg-faint">{config.txt.empty}</p>}
    {journalDays.map(({ id, sessions }, dayIdx) => (
      <div class="mb-10">
        <p class="mb-3 border-t border-line pt-6 font-mono text-[11px] uppercase tracking-wider text-fg-faint">{dayLabel(id)}</p>
        {sessions.map((s, i) => (
          <details class="engine-session mb-3 rounded-[14px] border border-line bg-panel panel-raised" open={dayIdx === 0 && i === 0}>
            <summary class="cursor-pointer select-none px-5 py-3.5">
              <span class="font-semibold">{s.heading || dayLabel(id)}</span>
              {s.move && <span class="ml-2 inline-block rounded border border-line px-1.5 py-0.5 align-middle font-mono text-[10px] uppercase tracking-wider text-fg-muted">{s.move}</span>}
              {s.voices && <span class="mt-1 block font-mono text-[11px] normal-case tracking-normal text-fg-faint">Convened: {s.voices}</span>}
            </summary>
            <div class="engine-prose border-t border-line px-5 pb-5 pt-2" set:html={s.html} />
          </details>
        ))}
      </div>
    ))}
  </section>

  {/* Doc modal — journal citations of the engine's root docs open in place. The anchors still
      point at the repo (blob/main/…), so without JS every citation remains a working link. */}
  <dialog id="mdref-modal" class="m-auto w-[min(760px,92vw)] rounded-[16px] border border-line bg-panel p-0 text-fg shadow-xl">
    <div class="flex items-center justify-between gap-3 border-b border-line px-5 py-3">
      <span id="mdref-title" class="font-mono text-xs text-fg-muted"></span>
      <div class="flex items-center gap-4">
        <a id="mdref-src" href={config.repo} target="_blank" rel="noreferrer" class="font-mono text-[11px] text-fg-faint underline transition-colors hover:text-fg">{txt.sourceCode} ↗</a>
        <button id="mdref-close" type="button" aria-label={txt.close} class="cursor-pointer font-mono text-sm text-fg-faint transition-colors hover:text-fg">✕</button>
      </div>
    </div>
    <div id="mdref-body" class="engine-prose max-h-[70vh] overflow-y-auto px-5 py-4"></div>
  </dialog>
  {rootDocsR.map(({ id, Content }) => <template data-doc-tpl={id}><Content /></template>)}
</div>

<script>
  const dlg = document.getElementById('mdref-modal') as HTMLDialogElement | null
  const title = document.getElementById('mdref-title')
  const src = document.getElementById('mdref-src') as HTMLAnchorElement | null
  const body = document.getElementById('mdref-body')

  // While the dialog is open the page must be physically unscrollable (wheel events chain
  // through the top layer in Chromium even when cancelled): fix the body in place, keep the
  // visual position via a negative top offset, restore the scroll position on close.
  const lockPage = () => {
    document.body.dataset.lockY = String(window.scrollY)
    document.body.style.top = `-${window.scrollY}px`
    document.body.style.position = 'fixed'
    document.body.style.width = '100%'
  }
  const unlockPage = () => {
    const y = Number(document.body.dataset.lockY ?? '0')
    document.body.style.position = ''
    document.body.style.top = ''
    document.body.style.width = ''
    window.scrollTo({ top: y, behavior: 'instant' })
  }

  const openDoc = (doc: string, label: string, href: string): boolean => {
    const tpl = document.querySelector<HTMLTemplateElement>(`template[data-doc-tpl="${doc}"]`)
    if (!tpl || !dlg || !title || !src || !body) return false
    title.textContent = label
    src.href = href
    body.replaceChildren(tpl.content.cloneNode(true))
    body.scrollTop = 0
    if (!dlg.open) {
      lockPage()
      dlg.showModal()
    }
    return true
  }

  document.addEventListener('click', (ev) => {
    const a = (ev.target as Element).closest?.('a')
    if (!a) return
    // Journal citations carry data-doc; relative .md links inside an opened doc resolve too.
    let doc = a.dataset.doc
    let label = a.dataset.mdref
    let href = a.href
    if (!doc && dlg?.open && body?.contains(a)) {
      const m = a.getAttribute('href')?.match(/^\.?\/?([\w-]+)\.md$/)
      if (m) {
        doc = m[1].toLowerCase()
        label = `${m[1]}.md`
        href = src?.href.replace(/\/[^/]+$/, `/${m[1]}.md`) ?? href
      }
    }
    if (doc && openDoc(doc, label ?? `${doc}.md`, href)) ev.preventDefault()
  })

  document.getElementById('mdref-close')?.addEventListener('click', () => dlg?.close())
  dlg?.addEventListener('click', (ev) => { if (ev.target === dlg) dlg.close() })
  // 'close' fires for every path (button, backdrop, Esc) — the one place to unlock the page.
  dlg?.addEventListener('close', unlockPage)

  // Wheel over the header or backdrop still scrolls the document inside the modal.
  dlg?.addEventListener('wheel', (ev) => {
    ev.preventDefault()
    if (body) body.scrollTop += ev.deltaY
  }, { passive: false })
</script>
