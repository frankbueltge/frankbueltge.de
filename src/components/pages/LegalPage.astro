---
import type { LegalPage } from '@/data/legal'

interface Props { page: LegalPage }
const { page } = Astro.props
---

<main id="main" class="mx-auto w-full max-w-2xl flex-1 px-6 py-16 sm:py-24">
  <h1 class="text-[clamp(30px,4vw,44px)] font-bold tracking-[-0.02em]">{page.heading}</h1>
  <div class="mt-6 flex gap-3 rounded-xl border border-amber-500/40 bg-amber-500/10 p-4 text-sm text-amber-200">
    <span>⚠</span><p>{page.draftNote}</p>
  </div>
  <div class="mt-10 space-y-8">
    {page.sections.map((s) => (
      <section>
        <h2 class="text-lg font-semibold">{s.heading}</h2>
        <div class="mt-3 space-y-2">
          {s.paragraphs.map((p) => <p class="text-sm leading-relaxed text-fg-muted">{p}</p>)}
        </div>
      </section>
    ))}
  </div>
</main>
