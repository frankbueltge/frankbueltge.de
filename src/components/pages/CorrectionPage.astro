---
// Gegenmessung II — „The Correction".
// Misst die Lüge der offiziellen Zahl über die Revisionen, die das Amt selbst vornimmt.
// Daten: src/data/revision/latest.json (CDC ILINet via Delphi Epidata; pipelines/revision/).
import { getRelativeLocaleUrl } from 'astro:i18n'
import { t } from '@/i18n/ui'
import type { Locale } from '@/lib/site'
import type { RevisionData } from '@/lib/revision/types'
import { signedPct, sharePct, epiweekLabel, num } from '@/lib/revision/format'
import data from '@/data/revision/latest.json'

interface Props { locale: Locale }
const { locale } = Astro.props
const de = locale === 'de'
const d = data as unknown as RevisionData
const s = d.systematic
const h = d.headline
const m = d.max_lag
const methodUrl = getRelativeLocaleUrl(locale, '/werke/correction')

// Balken: wöchentliche Revision in % — fast alle über der Null (systematisch nach oben).
const ws = d.weeks
const W = 640
const H = 120
const mid = H / 2
const maxAbs = Math.max(...ws.map((w) => Math.abs(w.pct)), 1)
const bw = ws.length ? W / ws.length : W
const bars = ws.map((w, i) => {
  const hgt = (Math.abs(w.pct) / maxAbs) * (mid - 4)
  return { x: i * bw, y: w.pct >= 0 ? mid - hgt : mid, h: hgt, up: w.pct >= 0 }
})
---

<article class="correction mx-auto max-w-3xl px-4 py-14">
  <header class="mb-10">
    <h1 class="text-[clamp(30px,6vw,56px)] font-bold tracking-[-0.03em]">The Correction</h1>
    <p class="mt-2 max-w-xl text-fg-muted">{t(locale, 'cr.sub')}</p>
  </header>

  {h && (
    <section class="mb-12 flex items-baseline gap-4">
      <p class="text-[clamp(40px,8vw,72px)] font-bold leading-none tabular-nums">{sharePct(s.revised_up_share, locale)}</p>
      <p class="max-w-sm text-sm leading-snug text-fg-muted">
        {de
          ? `der letzten ${s.weeks} wöchentlichen Grippezahlen wurden später revidiert — ${s.revised_up} davon nach oben. Die amtliche Echtzeit-Zahl ist systematisch zu niedrig.`
          : `of the last ${s.weeks} weekly flu numbers were later revised — ${s.revised_up} of them upward. The official real-time number is systematically too low.`}
      </p>
    </section>
  )}

  {ws.length > 1 && (
    <section class="mb-12">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">
        {de ? 'Wöchentliche Revision (Erst-Meldung → Korrektur)' : 'Weekly revision (first report → correction)'}
      </p>
      <svg viewBox={`0 0 ${W} ${H}`} class="mt-3 w-full" role="img"
        aria-label={de ? 'Balken der wöchentlichen Revision, fast alle nach oben' : 'Bars of weekly revision, almost all upward'}>
        {bars.map((b) => (
          <rect x={b.x + 0.5} y={b.y} width={Math.max(1, bw - 1)} height={b.h}
            fill={b.up ? 'rgb(var(--rgb-accent))' : '#dc2626'} fill-opacity={b.up ? '0.7' : '0.9'} />
        ))}
        <line x1="0" y1={mid} x2={W} y2={mid} stroke="currentColor" stroke-width="0.5" class="text-fg-faint" />
      </svg>
      <p class="mt-2 font-mono text-[11px] text-fg-faint">
        {de ? 'Über der Linie = nachträglich nach oben korrigiert.' : 'Above the line = later corrected upward.'}
      </p>
    </section>
  )}

  {h && (
    <section class="mb-10 border-l-2 border-accent/60 pl-5">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">
        {de ? 'Die Zahl, auf die alle reagierten' : 'The number everyone reacted to'}
      </p>
      <p class="mt-3 leading-relaxed">
        {de
          ? `Woche ${epiweekLabel(h.epiweek)}: Die CDC meldete zuerst ${num(h.first_cases, locale)} Grippefälle. Inzwischen hat sie das auf ${num(h.final_cases, locale)} korrigiert — ${signedPct(h.pct, locale)}.`
          : `Week ${epiweekLabel(h.epiweek)}: the CDC first reported ${num(h.first_cases, locale)} flu cases. It has since revised that to ${num(h.final_cases, locale)} — ${signedPct(h.pct, locale)}.`}
        {h.final_lag_weeks != null && (
          <span class="text-fg-muted">
            {de ? ` Die Korrektur kam ${h.final_lag_weeks} Wochen später.` : ` The correction arrived ${h.final_lag_weeks} weeks later.`}
          </span>
        )}
      </p>
    </section>
  )}

  {m && m.final_lag_weeks != null && (
    <section class="mb-12">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">{de ? 'Es gibt keine finale Zahl' : 'There is no final number'}</p>
      <p class="mt-2 leading-relaxed text-fg-muted">
        {de
          ? `Woche ${epiweekLabel(m.epiweek)} wurde noch ${m.final_lag_weeks} Wochen später verändert — fast zwei Jahre nach dem Ereignis, das sie beschreibt.`
          : `Week ${epiweekLabel(m.epiweek)} was still being changed ${m.final_lag_weeks} weeks later — almost two years after the event it describes.`}
      </p>
    </section>
  )}

  <footer class="mt-12 border-t border-line pt-6">
    <p class="font-mono text-xs text-fg-faint">
      {de ? 'Quelle: ' : 'Source: '}{d.source.name}.
      {de ? ' Erst-Meldung = Ausgabe mit 1 Woche Verzug; Korrektur = jüngste Revision.' : ' First report = issue at 1-week lag; correction = latest revision.'}
    </p>
    <nav class="mt-2">
      <a href={methodUrl} class="font-mono text-xs text-fg-faint transition-colors hover:text-fg">{t(locale, 'prot.method')} →</a>
    </nav>
  </footer>
</article>
