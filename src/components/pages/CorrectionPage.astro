---
// Gegenmessung II — „The Correction".
// Misst die Lüge der offiziellen Zahl über die Revisionen, die das Amt selbst vornimmt.
// Daten: src/data/revision/latest.json (Philadelphia Fed RTDSM; pipelines/revision/).
import { getRelativeLocaleUrl } from 'astro:i18n'
import { t } from '@/i18n/ui'
import type { Locale } from '@/lib/site'
import type { RevisionData } from '@/lib/revision/types'
import { millions, signedFull, sharePct, monthLabel } from '@/lib/revision/format'
import data from '@/data/revision/latest.json'

interface Props { locale: Locale }
const { locale } = Astro.props
const de = locale === 'de'
const d = data as unknown as RevisionData
const s = d.systematic
const h = d.headline
const methodUrl = getRelativeLocaleUrl(locale, '/werke/correction')

const mio = (thousands: number) =>
  new Intl.NumberFormat(de ? 'de-DE' : 'en-GB', { maximumFractionDigits: 1 }).format(thousands / 1000)

// Balken: monatliche Revision (Tsd. Jobs) — alle nach unten. Nulllinie oben, Balken hängen.
const rec = d.recent
const W = 640
const H = 130
const top = 10
const maxAbs = Math.max(...rec.map((r) => Math.abs(r.delta)), 1)
const bw = rec.length ? W / rec.length : W
const bars = rec.map((r, i) => ({ x: i * bw, h: (Math.abs(r.delta) / maxAbs) * (H - top - 2) }))
---

<article class="correction mx-auto max-w-3xl px-4 py-14">
  <header class="mb-10">
    <h1 class="text-[clamp(30px,6vw,56px)] font-bold tracking-[-0.03em]">The Correction</h1>
    <p class="mt-2 max-w-xl text-fg-muted">{t(locale, 'cr.sub')}</p>
  </header>

  {h && (
    <section class="mb-12 flex items-baseline gap-4">
      <p class="text-[clamp(40px,8vw,72px)] font-bold leading-none tabular-nums">{millions(h.delta, locale)}{de ? ' Mio.' : 'M'}</p>
      <p class="max-w-sm text-sm leading-snug text-fg-muted">
        {de
          ? `Jobs gestrichen. Im ${monthLabel(h.period, locale)} meldeten die USA zuerst ${mio(h.first)} Mio. Beschäftigte. Inzwischen ist die Zahl auf ${mio(h.final)} Mio. nach unten revidiert.`
          : `jobs erased. In ${monthLabel(h.period, locale)} the US first reported ${mio(h.first)} million jobs. It has since been revised down to ${mio(h.final)} million.`}
      </p>
    </section>
  )}

  {rec.length > 1 && (
    <section class="mb-12">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">
        {de ? 'Monatliche Revision der Beschäftigung (Erst-Meldung → Korrektur)' : 'Monthly revision of employment (first report → correction)'}
      </p>
      <svg viewBox={`0 0 ${W} ${H}`} class="mt-3 w-full" role="img"
        aria-label={de ? 'Balken der monatlichen Revision, alle nach unten' : 'Bars of monthly revision, all downward'}>
        <line x1="0" y1={top} x2={W} y2={top} stroke="currentColor" stroke-width="0.5" class="text-fg-faint" />
        {bars.map((b) => (
          <rect x={b.x + 0.5} y={top} width={Math.max(1, bw - 1)} height={b.h} fill="#dc2626" fill-opacity="0.8" />
        ))}
      </svg>
      <p class="mt-2 font-mono text-[11px] text-fg-faint">
        {de
          ? `Unter der Linie = nachträglich nach unten korrigiert. ${rec[0].period} – ${rec.at(-1)?.period}.`
          : `Below the line = later corrected downward. ${rec[0].period} – ${rec.at(-1)?.period}.`}
      </p>
    </section>
  )}

  <section class="mb-10 flex items-baseline gap-4">
    <p class="text-[clamp(28px,5vw,44px)] font-bold leading-none tabular-nums">{sharePct(s.revised_down_share, locale)}</p>
    <p class="max-w-sm text-sm leading-snug text-fg-muted">
      {de
        ? `der letzten ${s.months} Monate wurden nach unten revidiert. Die amtliche Beschäftigung war systematisch zu hoch — die Echtzeit-Zahl, auf die Märkte und Politik reagierten, eine vorläufige.`
        : `of the last ${s.months} months were revised downward. Official employment was systematically too high — the real-time number markets and politics reacted to was a provisional one.`}
    </p>
  </section>

  {h && (
    <section class="mb-12">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-faint">{de ? 'Es gibt keine finale Zahl' : 'There is no final number'}</p>
      <p class="mt-2 leading-relaxed text-fg-muted">
        {de
          ? `Die Beschäftigung wird jährlich gegen Steuerdaten „gebenchmarkt" — die ${monthLabel(h.period, locale)}-Zahl verlor dabei ${signedFull(h.delta, locale)} Stellen. Die Zahl, die du gelesen hast, war nie endgültig.`
          : `Employment is "benchmarked" against tax records each year — the ${monthLabel(h.period, locale)} figure lost ${signedFull(h.delta, locale)} jobs in the process. The number you read was never final.`}
      </p>
    </section>
  )}

  <footer class="mt-12 border-t border-line pt-6">
    <p class="font-mono text-xs text-fg-faint">
      {de ? 'Quelle: ' : 'Source: '}{d.source.name}.
      {de ? ' Erst-Meldung = früheste Ausgabe mit Wert; Korrektur = jüngste Ausgabe.' : ' First report = earliest issue with a value; correction = latest issue.'}
    </p>
    <nav class="mt-2">
      <a href={methodUrl} class="font-mono text-xs text-fg-faint transition-colors hover:text-fg">{t(locale, 'prot.method')} →</a>
    </nav>
  </footer>
</article>
