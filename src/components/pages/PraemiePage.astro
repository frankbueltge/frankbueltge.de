---
// Werk „Prämie — Die Police" — der dunkle Zwilling des Protokolls.
// Ein Versicherungsschein auf die Gegenwart, jede Nacht aus police.json neu gesetzt.
import { getRelativeLocaleUrl } from 'astro:i18n'
import { t } from '@/i18n/ui'
import type { Locale } from '@/lib/site'
import { renderPolice } from '@/lib/praemie/render'
import { hasData, type Police, type PolicePremiumData, type PoliceDisastersData } from '@/lib/praemie/types'
import { PCHART_H, PCHART_W, yearAreaPath, yearLinePath } from '@/lib/praemie/chart'
import police from '@/data/praemie/police.json'

interface Props { locale: Locale }
const { locale } = Astro.props
const de = locale === 'de'

// JSON-Import wird von TS strukturell zu eng inferiert — Cast über unknown ist
// hier der korrekte Weg (wie bei den anderen Werken).
const p = police as unknown as Police
const r = renderPolice(p, locale)

// Schaufenster-Zahl: der Prämienindex groß, der Anstieg darunter (§ 2).
const nf1 = new Intl.NumberFormat(de ? 'de-DE' : 'en-GB', { minimumFractionDigits: 1, maximumFractionDigits: 1 })
const premium: PolicePremiumData | null = hasData<PolicePremiumData>(p.premium) ? p.premium : null
const heroIndex = premium ? nf1.format(premium.index) : '—'
const heroChange = premium
  ? `${premium.change_pct_since_base >= 0 ? '+' : ''}${nf1.format(premium.change_pct_since_base)} % ${de ? 'seit' : 'since'} ${premium.base_year}`
  : ''
const heroLabel = de ? 'Versicherungs-Preisindex' : 'Insurance price index'
const heroBase = premium ? `${de ? 'Basis' : 'base'} ${premium.base_year} = 100` : ''

// Diagramm: Schadenskosten ($Mrd., Fläche) und Prämien-Index (Linie) über die Jahre.
// Zwei Reihen, gemeinsame Jahres-Achse, je eigene Werteskala (in der Legende benannt).
const disasters: PoliceDisastersData | null = hasData<PoliceDisastersData>(p.disasters) ? p.disasters : null
const costPts = (disasters?.series ?? []).map((s) => ({ year: s.year, value: s.cost_busd }))
const idxPts = (premium?.series ?? []).map((s) => ({ year: s.year, value: s.index }))
const showChart = costPts.length >= 2 && idxPts.length >= 2
const years = [...costPts, ...idxPts].map((d) => d.year)
const xMin = years.length ? Math.min(...years) : 0
const xMax = years.length ? Math.max(...years) : 0
const costMax = costPts.length ? Math.max(...costPts.map((d) => d.value)) : 0
const idxMax = idxPts.length ? Math.max(...idxPts.map((d) => d.value)) : 0
const costArea = yearAreaPath(costPts, xMin, xMax, costMax)
const costLine = yearLinePath(costPts, xMin, xMax, costMax)
const idxLine = yearLinePath(idxPts, xMin, xMax, idxMax)
const chartTxt = {
  heading: de ? 'Schäden und Prämie über die Zeit' : 'Damage and premium over time',
  cost: de ? 'Schadenskosten je Jahr ($ Mrd., NOAA)' : 'Disaster cost per year ($bn, NOAA)',
  index: de
    ? `Prämien-Index (${premium?.base_year ?? 1998} = 100, BLS)`
    : `Premium index (${premium?.base_year ?? 1998} = 100, BLS)`,
}

const methodUrl = getRelativeLocaleUrl(locale, '/werke/policy')
const methodLabel = de ? 'Methodenblatt' : 'Method sheet'
---

<article class="police mx-auto max-w-2xl px-4 py-14">
  <header class="mb-12 space-y-1">
    {r.kopf.map((line) => <p class="text-[15px] leading-relaxed">{line}</p>)}
  </header>

  {premium && (
    <section class="mb-12 print:hidden">
      <p class="font-mono text-xs uppercase tracking-wide text-fg-faint">{heroLabel}</p>
      <p class="py-1 text-[clamp(48px,9vw,96px)] font-bold leading-none tracking-tight tabular-nums">
        {heroIndex}
      </p>
      <p class="text-lg font-semibold text-fg-muted">{heroChange}</p>
      <p class="font-mono text-xs text-fg-faint">{heroBase}</p>
    </section>
  )}

  {showChart && (
    <section class="mb-12">
      <h2 class="mb-1 font-semibold">{chartTxt.heading}</h2>
      <svg viewBox={`0 0 ${PCHART_W} ${PCHART_H}`} class="mt-3 w-full overflow-visible text-fg-faint"
        role="img" aria-label={chartTxt.heading}>
        <path d={costArea} fill="rgb(var(--rgb-accent))" fill-opacity="0.1" stroke="none" />
        <path d={costLine} fill="none" stroke="rgb(var(--rgb-accent))" stroke-width="1" stroke-opacity="0.5" vector-effect="non-scaling-stroke" />
        <path d={idxLine} fill="none" stroke="rgb(var(--rgb-accent))" stroke-width="1.6" vector-effect="non-scaling-stroke" />
        <text x="0" y={PCHART_H} font-size="9" fill="currentColor">{xMin}</text>
        <text x={PCHART_W} y={PCHART_H} text-anchor="end" font-size="9" fill="currentColor">{xMax}</text>
      </svg>
      <ul class="mt-2 flex flex-wrap gap-x-5 gap-y-1 font-mono text-[11px] text-fg-faint">
        <li class="flex items-center gap-1.5">
          <svg width="16" height="8" aria-hidden="true"><rect width="16" height="8" fill="rgb(var(--rgb-accent))" fill-opacity="0.2" /></svg>
          {chartTxt.cost}
        </li>
        <li class="flex items-center gap-1.5">
          <svg width="16" height="8" aria-hidden="true"><line x1="0" y1="4" x2="16" y2="4" stroke="rgb(var(--rgb-accent))" stroke-width="1.6" /></svg>
          {chartTxt.index}
        </li>
      </ul>
    </section>
  )}

  {r.paragraphen.map((para) => (
    <section class="mb-8">
      <h2 class="mb-1 font-semibold">{para.nummer} — {para.titel}.</h2>
      {para.zeilen.map((line) => <p class="leading-relaxed">{line}</p>)}
      {para.quelle && <p class="mt-1 font-mono text-xs text-fg-faint">{para.quelle}</p>}
    </section>
  ))}

  <footer class="mt-12 space-y-1 border-t border-line pt-6">
    {r.schluss.map((line) => <p>{line}</p>)}
    <p class="pt-4 font-mono text-xs text-fg-faint">{r.meta}</p>
    <nav class="flex gap-4 pt-2 text-sm text-fg-muted print:hidden">
      <a href={methodUrl} class="transition-colors hover:text-fg">{methodLabel}</a>
    </nav>
  </footer>
</article>

<style>
  /* Druckfassung: Police schwarz auf weiß, Chrome ausgeblendet (wie ProtokollDoc).
     TopBar rendert als <header>, Footer als <footer>, beide direkte body-Kinder. */
  @media print {
    .police { max-width: none; padding: 0; color: #000; }
    :global(body > header), :global(body > footer) { display: none !important; }
  }
</style>
