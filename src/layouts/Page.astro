---
import Base from './Base.astro'
import TopBar from '@/components/TopBar.astro'
import Footer from '@/components/Footer.astro'

interface Props {
  title: string
  description: string
}
const { title, description } = Astro.props
---

<Base title={title} description={description}>
  <TopBar />
  <slot />
  <Footer />
</Base>
