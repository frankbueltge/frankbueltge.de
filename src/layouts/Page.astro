---
import Base from './Base.astro'
import TopBar from '@/components/TopBar.astro'
import Footer from '@/components/Footer.astro'
import AuthorByline from '@/components/AuthorByline.astro'

interface Props {
  title: string
  description: string
  noindex?: boolean
}
const { title, description, noindex } = Astro.props
---

<Base title={title} description={description} noindex={noindex}>
  <TopBar />
  <slot />
  {/* Die Byline entscheidet selbst pfadbasiert, ob die Seite eine Quelle hat (16.07.) —
      kein Layout-Gate mehr; Seiten ohne passendes Repo rendern schlicht keine Zeile. */}
  <AuthorByline />
  <Footer />
</Base>
