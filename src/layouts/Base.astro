---
import { getAbsoluteLocaleUrl } from 'astro:i18n'
// Self-hosted variable fonts (no external requests, no layout shift).
import '@fontsource-variable/space-grotesk'
import '@fontsource-variable/jetbrains-mono'
import '@/styles/global.css'
import { SITE, type Locale } from '@/lib/site'
import { t } from '@/i18n/ui'
import { ogSlug } from '@/lib/og'
import Analytics from '@vercel/analytics/astro'

// Skin fest auf mono (data-skin am <html>) — der Zyklus ist stillgelegt. Skins
// + SkinSwitcher bleiben im Repo; Reaktivierung = SkinSwitcher wieder mounten
// und data-skin dynamisch setzen.
interface Props {
  title: string
  description: string
}
const { title, description } = Astro.props
const locale = (Astro.currentLocale ?? 'de') as Locale

// canonical + hreflang via Astro's config-aware locale URLs (de at /, en at /en; x-default → de)
const pathNoLocale = Astro.url.pathname.replace(/^\/en/, '') || '/'
const href = (l: Locale) => getAbsoluteLocaleUrl(l, pathNoLocale)
const canonical = href(locale)
// Pro Seite generiertes OG-Bild (1200×630, build-time via src/pages/og/).
const ogImage = `${SITE.url}/og/${ogSlug(Astro.url.pathname)}.png`

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE.url}/#person`,
  name: SITE.name,
  alternateName: SITE.alternateName,
  url: SITE.url,
  jobTitle: SITE.role[locale],
  disambiguatingDescription:
    locale === 'de'
      ? 'Data & AI Engineer. Ein öffentliches Experimentierfeld mit Daten und Code — Versuche und erste Annäherungen, praxisbasiert, auf dem Weg zu einer künstlerischen Forschung. Macher von data-snack.com und datavism.org.'
      : 'Data & AI Engineer. A public field for experiments with data and code — attempts and first approaches, practice-based, on the way toward artistic research. Creator of data-snack.com and datavism.org.',
  knowsAbout: ['Data Engineering', 'AI Engineering', 'Data Infrastructure', 'Data Visualization', 'BigQuery', 'dbt'],
  sameAs: [SITE.social.linkedin, SITE.social.github, SITE.social.instagram, SITE.projects.dataSnack, SITE.projects.datavism],
}
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  inLanguage: locale === 'de' ? 'de-DE' : 'en',
  publisher: { '@id': `${SITE.url}/#person` },
}
---

<!doctype html>
<html lang={locale} data-skin="mono">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="de-DE" href={href('de')} />
    <link rel="alternate" hreflang="en" href={href('en')} />
    <link rel="alternate" hreflang="x-default" href={href('de')} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="The Protocol"
      href={locale === 'de' ? '/protokoll/feed.xml' : '/en/protokoll/feed.xml'}
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(person)} />
    <script type="application/ld+json" set:html={JSON.stringify(website)} />
  </head>

  <body class="flex min-h-dvh flex-col">
    <a
      href="#main"
      class="sr-only rounded-md bg-accent px-4 py-2 text-sm text-white focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50"
    >
      {t(locale, 'a11y.skip')}
    </a>
    <slot />

    {/* Cinematic vignette over everything (decorative, never blocks input). */}
    <div class="vignette" aria-hidden="true"></div>

    {/* Lenis smooth scroll — site-wide nicety, disabled for reduced-motion. */}
    <script>
      import Lenis from 'lenis'
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const lenis = new Lenis({ duration: 1.1, smoothWheel: true })
        const raf = (time: number) => { lenis.raf(time); requestAnimationFrame(raf) }
        requestAnimationFrame(raf)
      }
    </script>

    {/* Vercel Web Analytics — cookielos/anonym (DSGVO-konform); sammelt erst, wenn im Vercel-Dashboard aktiviert. */}
    <Analytics />
  </body>
</html>
