---
import { getAbsoluteLocaleUrl } from 'astro:i18n'
// Self-hosted variable fonts (no external requests, no layout shift).
import '@fontsource-variable/space-grotesk'
import '@fontsource-variable/jetbrains-mono'
import '@/styles/global.css'
import { SITE, type Locale } from '@/lib/site'
import { t } from '@/i18n/ui'
import { ogSlug } from '@/lib/og'
import { workForPath, workJsonLd } from '@/lib/structured-data'

// Skin fest auf mono (data-skin am <html>) — der Zyklus ist stillgelegt. Skins
// + SkinSwitcher bleiben im Repo; Reaktivierung = SkinSwitcher wieder mounten
// und data-skin dynamisch setzen.
interface Props {
  title: string
  description: string
  noindex?: boolean
  analytics?: boolean // false on 404 → keep dead-URL / bot hits out of stats
}
const { title, description, noindex, analytics = true } = Astro.props
const locale = (Astro.currentLocale ?? 'en') as Locale

// canonical URL via Astro's config-aware locale URL (single locale, en, unprefixed — site-v2
// work order §6: German dropped site-wide, decisions doc 2026-07-16 §1.5).
const canonical = getAbsoluteLocaleUrl(locale, Astro.url.pathname)
// Pro Seite generiertes OG-Bild (1200×630, build-time via src/pages/og/).
const ogImage = `${SITE.url}/og/${ogSlug(Astro.url.pathname)}.png`

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE.url}/#person`,
  name: SITE.name,
  alternateName: SITE.alternateName,
  url: SITE.url,
  jobTitle: SITE.role[locale],
  disambiguatingDescription:
    'Data Engineering & Analytics. A public field for experiments with data, code and AI — small experiments that measure something from open sources and disclose how they are made. Creator of data-snack.com and datavism.org.',
  knowsAbout: ['Data Engineering', 'Analytics', 'AI/ML', 'Data Infrastructure', 'Data Visualization'],
  sameAs: [SITE.social.linkedin, SITE.social.github, SITE.social.instagram, SITE.projects.dataSnack, SITE.projects.datavism],
}
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  inLanguage: 'en',
  publisher: { '@id': `${SITE.url}/#person` },
}
// Per-instrument CreativeWork, attributed to Frank — only on work pages.
const work = workForPath(Astro.url.pathname)
const workLd = work ? workJsonLd(work, locale, canonical) : null
---

<!doctype html>
<html lang={locale} data-skin="mono">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="theme-color" content="#0a0a0a" />
    <script is:inline>
      // Anti-FOUC + auto theme. Resolve the theme BEFORE first paint and stamp it
      // EXPLICITLY on <html> (data-theme is always 'light' or 'dark', never absent) so
      // component styles that key off [data-theme='dark'] / [data-theme='light'] stay in
      // lockstep with the real page. That lockstep is what prevents dark-grey-on-black
      // works (e.g. transparent, theme-adaptive pieces like The Closing Loop).
      //   localStorage 'theme':  'light' | 'dark' = the user's explicit override
      //                          absent            = AUTO → follow the OS (incl. its own
      //                                              day/night schedule; kept live by the
      //                                              controller in <body>).
      // data-theme-mode carries the *mode* (auto/light/dark) for the toggle icon.
      (function () {
        var root = document.documentElement
        var pref = null
        try { pref = localStorage.getItem('theme') } catch (e) {}
        var mode = pref === 'light' || pref === 'dark' ? pref : 'auto'
        var dark
        try { dark = mode === 'auto' ? matchMedia('(prefers-color-scheme: dark)').matches : mode === 'dark' }
        catch (e) { dark = mode === 'dark' }
        root.setAttribute('data-theme', dark ? 'dark' : 'light')
        root.setAttribute('data-theme-mode', mode)
      })()
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="The Protocol" href="/protokoll/feed.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(person)} />
    <script type="application/ld+json" set:html={JSON.stringify(website)} />
    {workLd && <script type="application/ld+json" set:html={JSON.stringify(workLd)} />}
  </head>

  <body class="flex min-h-dvh flex-col">
    <a
      href="#main"
      class="sr-only rounded-md bg-accent px-4 py-2 text-sm text-bg focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50"
    >
      {t(locale, 'a11y.skip')}
    </a>
    <slot />

    {/* Cinematic vignette over everything (decorative, never blocks input). */}
    <div class="vignette" aria-hidden="true"></div>

    {/* Lenis smooth scroll — site-wide nicety, disabled for reduced-motion. */}
    <script>
      import Lenis from 'lenis'
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const lenis = new Lenis({ duration: 1.1, smoothWheel: true })
        const raf = (time: number) => { lenis.raf(time); requestAnimationFrame(raf) }
        requestAnimationFrame(raf)
      }
    </script>

    {/* Scroll-flash: the first scroll on each page blinks the WHOLE page briefly to the light
        theme and eases back — a one-time reveal accent, not a per-scroll strobe. Fires exactly
        once per page load, then unbinds its listeners. Dark mode only (a no-op under persistent
        light mode) and never under reduced-motion. (Full-page: see global.css .theme-flash.) */}
    <script>
      const root = document.documentElement
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        let done = false
        const flash = () => {
          const prev = root.getAttribute('data-theme') // resolved theme is always set now
          if (done || prev === 'light') return
          done = true
          removeEventListener('scroll', flash)
          removeEventListener('wheel', flash)
          root.classList.add('theme-flash')
          root.setAttribute('data-theme', 'light')
          setTimeout(() => {
            root.setAttribute('data-theme', prev || 'dark') // restore, never drop the attribute
            setTimeout(() => root.classList.remove('theme-flash'), 200)
          }, 150)
        }
        addEventListener('scroll', flash, { passive: true })
        addEventListener('wheel', flash, { passive: true })
      }
    </script>

    {/* Theme controller — the single source of truth for light/dark. The head script already
        set the initial state FOUC-free; this keeps it reactive and wires the toggle (present in
        TopBar). Modes: 'auto' (default) follows the OS live, including its day/night schedule;
        'light'/'dark' are explicit user overrides. Cycling: auto → light → dark → auto. */}
    <script>
      const root = document.documentElement
      const mq = matchMedia('(prefers-color-scheme: dark)')

      const readMode = (): string => {
        try { return localStorage.getItem('theme') || 'auto' } catch (e) { return 'auto' }
      }
      const resolve = (mode: string): string => (mode === 'auto' ? (mq.matches ? 'dark' : 'light') : mode)

      const syncThemeColor = (): void => {
        const m = document.querySelector('meta[name="theme-color"]')
        const c = getComputedStyle(root).getPropertyValue('--color-bg').trim()
        if (m && c) m.setAttribute('content', c)
      }

      const apply = (mode: string): void => {
        root.setAttribute('data-theme', resolve(mode)) // what the page actually renders as
        root.setAttribute('data-theme-mode', mode) // what the toggle icon shows
        syncThemeColor()
      }

      apply(readMode()) // reconcile with the head script + set the correct theme-color

      // Auto mode: follow the OS live, so a system that flips light↔dark on a schedule flips the site too.
      mq.addEventListener('change', () => { if (readMode() === 'auto') apply('auto') })

      // Toggle cycles auto → light → dark → auto. 'auto' clears the override (back to following the OS).
      const order = ['auto', 'light', 'dark']
      document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
        const next = order[(order.indexOf(readMode()) + 1) % order.length]
        try {
          if (next === 'auto') localStorage.removeItem('theme')
          else localStorage.setItem('theme', next)
        } catch (e) {}
        apply(next)
      })
    </script>

    {/* Web Analytics — Umami, first-party via a Cloudflare Pages Function proxy (functions/stats/).
        The browser only ever requests /stats/* on this domain; the proxy forwards to our own
        self-hosted Umami instance (stats.frankbueltge.de, EU/Frankfurt on Vercel + Neon). No
        third-party request leaves the browser, so the Beifang „null Drittanbieter-Requests" claim
        still holds and no external CSP source is needed. Cookieless, no personal data, no
        third-country transfer. (Migrated from Umami Cloud to self-hosted 2026-07.) */}
    {analytics && <script defer src="/stats/script.js" data-website-id="cea1def9-863b-44e8-9f79-84837cf9cc42" data-host-url="/stats"></script>}
  </body>
</html>
