{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/mrr/schemas/falsification-plan.schema.json",
  "title": "Falsification Plan",
  "type": "object",
  "required": [
    "id",
    "api_version",
    "kind",
    "practice_id",
    "revision",
    "created_at",
    "created_by",
    "content_hash",
    "project_id",
    "design_id",
    "probes",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "api_version": {
      "type": "string",
      "const": "mrr/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "FalsificationPlan"
    },
    "practice_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "design_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "probes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "probe_id",
          "probe_type",
          "threat",
          "procedure",
          "failure_consequence"
        ],
        "properties": {
          "probe_id": {
            "type": "string"
          },
          "probe_type": {
            "type": "string"
          },
          "threat": {
            "type": "string"
          },
          "procedure": {
            "type": "string"
          },
          "pass_condition": {
            "type": "string"
          },
          "kill_condition": {
            "type": "string"
          },
          "failure_consequence": {
            "enum": [
              "warn",
              "downgrade",
              "kill_branch",
              "contest_claim",
              "require_replication"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "status": {
      "enum": [
        "draft",
        "accepted",
        "running",
        "completed",
        "invalidated"
      ]
    }
  },
  "additionalProperties": false
}
