{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/mrr/schemas/generalization-map.schema.json",
  "title": "Generalization Map",
  "type": "object",
  "required": [
    "id",
    "api_version",
    "kind",
    "practice_id",
    "revision",
    "created_at",
    "created_by",
    "content_hash",
    "project_id",
    "claim_id",
    "study_population",
    "target_population",
    "included_geographies",
    "excluded_geographies",
    "time_window",
    "transport_assumptions",
    "effect_modifiers",
    "explicit_non_claims",
    "review_by",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "api_version": {
      "type": "string",
      "const": "mrr/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "GeneralizationMap"
    },
    "practice_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "claim_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "study_population": {
      "type": "string"
    },
    "target_population": {
      "type": "string"
    },
    "included_geographies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "excluded_geographies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "time_window": {
      "type": "string"
    },
    "transport_assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "effect_modifiers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "explicit_non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "review_by": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "draft",
        "accepted",
        "contested",
        "superseded"
      ]
    }
  },
  "additionalProperties": false
}
