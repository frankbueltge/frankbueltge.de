{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/mrr/schemas/data-asset-profile.schema.json",
  "title": "Data Asset Profile",
  "type": "object",
  "required": [
    "id",
    "api_version",
    "kind",
    "practice_id",
    "revision",
    "created_at",
    "created_by",
    "content_hash",
    "project_id",
    "name",
    "owner",
    "authoritative_location",
    "access_state",
    "license_or_terms",
    "classification",
    "temporal_coverage",
    "geographic_units",
    "observational_unit",
    "variables",
    "missingness",
    "revision_history",
    "join_keys",
    "risks",
    "estimand_suitability",
    "empirical_claims_permitted"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "api_version": {
      "type": "string",
      "const": "mrr/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "DataAssetProfile"
    },
    "practice_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "name": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "authoritative_location": {
      "type": "string"
    },
    "access_state": {
      "enum": [
        "candidate",
        "metadata_verified",
        "access_requested",
        "access_granted",
        "sample_inspected",
        "quality_audited",
        "analysis_ready",
        "rejected",
        "unavailable"
      ]
    },
    "license_or_terms": {
      "type": "string"
    },
    "classification": {
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "RESTRICTED",
        "SENSITIVE",
        "PARTICIPANT_IDENTIFIABLE",
        "SYNTHETIC_TEST_FIXTURE"
      ]
    },
    "temporal_coverage": {
      "type": "string"
    },
    "geographic_units": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "observational_unit": {
      "type": "string"
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missingness": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "revision_history": {
      "type": "string"
    },
    "join_keys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "estimand_suitability": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "estimand_id",
          "rating",
          "reason"
        ],
        "properties": {
          "estimand_id": {
            "type": "string",
            "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "rating": {
            "enum": [
              "high",
              "medium",
              "low",
              "none",
              "unknown"
            ]
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "empirical_claims_permitted": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
