{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/mrr/schemas/identification-audit.schema.json",
  "title": "Identification Audit",
  "type": "object",
  "required": [
    "id",
    "api_version",
    "kind",
    "practice_id",
    "revision",
    "created_at",
    "created_by",
    "content_hash",
    "project_id",
    "design_id",
    "decision",
    "claim_ceiling",
    "identifying_assumptions",
    "testable_implications",
    "untestable_assumptions",
    "threats",
    "blocking_conditions",
    "required_diagnostics",
    "rationale"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "api_version": {
      "type": "string",
      "const": "mrr/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "IdentificationAudit"
    },
    "practice_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "design_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "decision": {
      "enum": [
        "pending",
        "pass",
        "conditional_pass",
        "downgrade",
        "fail"
      ]
    },
    "claim_ceiling": {
      "enum": [
        "causal_bounded",
        "causal_local",
        "associational_adjusted",
        "associational_unadjusted",
        "descriptive",
        "mechanism_hypothesis",
        "insufficient_evidence"
      ]
    },
    "identifying_assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "testable_implications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "untestable_assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "threats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "threat",
          "severity",
          "resolution"
        ],
        "properties": {
          "threat": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "resolution": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "blocking_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_diagnostics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
