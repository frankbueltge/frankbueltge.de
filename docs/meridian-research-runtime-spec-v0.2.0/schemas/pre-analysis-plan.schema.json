{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/mrr/schemas/pre-analysis-plan.schema.json",
  "title": "Pre Analysis Plan",
  "type": "object",
  "required": [
    "id",
    "api_version",
    "kind",
    "practice_id",
    "revision",
    "created_at",
    "created_by",
    "content_hash",
    "project_id",
    "design_id",
    "identification_audit_id",
    "status",
    "primary_estimand_ids",
    "secondary_estimand_ids",
    "sample_rules",
    "measure_construction",
    "model_specifications",
    "uncertainty_strategy",
    "missing_data_strategy",
    "diagnostics",
    "falsification_tests",
    "kill_rules",
    "amendment_policy",
    "locked_at",
    "lock_hash"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "api_version": {
      "type": "string",
      "const": "mrr/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "PreAnalysisPlan"
    },
    "practice_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "design_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "identification_audit_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "locked",
        "amended",
        "executed",
        "invalidated"
      ]
    },
    "primary_estimand_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
      }
    },
    "secondary_estimand_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
      }
    },
    "sample_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "measure_construction": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model_specifications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainty_strategy": {
      "type": "string"
    },
    "missing_data_strategy": {
      "type": "string"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "falsification_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kill_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "amendment_policy": {
      "type": "string"
    },
    "locked_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "lock_hash": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
