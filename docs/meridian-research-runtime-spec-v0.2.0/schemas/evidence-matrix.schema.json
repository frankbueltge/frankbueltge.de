{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/mrr/schemas/evidence-matrix.schema.json",
  "title": "Evidence Matrix",
  "type": "object",
  "required": [
    "id",
    "api_version",
    "kind",
    "practice_id",
    "revision",
    "created_at",
    "created_by",
    "content_hash",
    "project_id",
    "search_strategy_revision",
    "records",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "api_version": {
      "type": "string",
      "const": "mrr/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "EvidenceMatrix"
    },
    "practice_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "search_strategy_revision": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_id",
          "source_id",
          "verification_status",
          "design",
          "scope",
          "limitations"
        ],
        "properties": {
          "record_id": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          },
          "source_family_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "verification_status": {
            "enum": [
              "discovered",
              "extracted",
              "verified",
              "rejected",
              "unavailable"
            ]
          },
          "design": {
            "type": "string"
          },
          "estimand": {
            "type": [
              "string",
              "null"
            ]
          },
          "scope": {
            "type": "string"
          },
          "effect_summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "identification_assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "replication_status": {
            "type": "string"
          },
          "anchors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "frozen",
        "superseded"
      ]
    }
  },
  "additionalProperties": false
}
