{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/mrr/schemas/concept-measurement-charter.schema.json",
  "title": "Concept Measurement Charter",
  "type": "object",
  "required": [
    "id",
    "api_version",
    "kind",
    "practice_id",
    "revision",
    "created_at",
    "created_by",
    "content_hash",
    "project_id",
    "question_model_id",
    "status",
    "concepts",
    "relations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "api_version": {
      "type": "string",
      "const": "mrr/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "ConceptMeasurementCharter"
    },
    "practice_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "question_model_id": {
      "type": "string",
      "pattern": "^urn:mrr:[a-z0-9-]+:[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "accepted",
        "superseded"
      ]
    },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "concept_id",
          "name",
          "working_definition",
          "construct_type",
          "operationalizations"
        ],
        "properties": {
          "concept_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "working_definition": {
            "type": "string"
          },
          "excluded_meanings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "construct_type": {
            "enum": [
              "observed",
              "latent",
              "constructed",
              "classified"
            ]
          },
          "contested_alternatives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "operationalizations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "operation_id",
                "name",
                "formula_or_rule",
                "level",
                "scale",
                "missingness_policy",
                "measurement_error"
              ],
              "properties": {
                "operation_id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "formula_or_rule": {
                  "type": "string"
                },
                "level": {
                  "type": "string"
                },
                "scale": {
                  "type": "string"
                },
                "source_fields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "missingness_policy": {
                  "type": "string"
                },
                "measurement_error": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "comparability_conditions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "taxonomy_version": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "type",
          "rationale"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "type": {
            "enum": [
              "equivalent",
              "complementary",
              "proxy_for",
              "incompatible_with",
              "unknown_relation"
            ]
          },
          "rationale": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
