# public/_headers — Cloudflare Pages
# frame-ancestors kann nicht per <meta http-equiv> gesetzt werden → muss als HTTP-Header kommen.
# X-Frame-Options ist Legacy-Fallback für ältere Browser.

# Standalone-Werke: Inline-Scripts erlaubt (generative Kunst), kein Fetch/Connect (kein Exfiltration-Kanal).
# Sandbox im iframe gibt zusätzlich null-origin → liest nichts aus frankbueltge.de.
/atelier/werke-html/*
  Content-Security-Policy: default-src 'none'; script-src 'unsafe-inline'; style-src 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: frame-ancestors 'self'
