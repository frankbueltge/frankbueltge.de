# public/_headers — Cloudflare Pages
# frame-ancestors kann nicht per <meta http-equiv> gesetzt werden → muss als HTTP-Header kommen.
# X-Frame-Options ist Legacy-Fallback für ältere Browser.

# Standalone-Werke: Inline-Scripts erlaubt (generative Kunst), kein Fetch/Connect (kein Exfiltration-Kanal).
# Sandbox im iframe gibt zusätzlich null-origin → liest nichts aus frankbueltge.de.
/atelier/werke-html/*
  Content-Security-Policy: default-src 'none'; script-src 'unsafe-inline' 'self'; style-src 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:

/field/werke-html/*
  Content-Security-Policy: default-src 'none'; script-src 'unsafe-inline' 'self'; style-src 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:

/plenum/werke-html/*
  Content-Security-Policy: default-src 'none'; script-src 'unsafe-inline' 'self'; style-src 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:

# Öffentlicher Chronik-Feed des Field-Projekts: bewusst offener CORS (read-only JSON,
# konsumiert von data-snack.com "Wareneingang" und datavism.org — eine Quelle, drei Flächen).
/field/chronicle.json
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: frame-ancestors 'self'
