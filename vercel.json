{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/werke", "destination": "/lab", "permanent": true },
    { "source": "/en/werke", "destination": "/en/lab", "permanent": true }
  ]
}
